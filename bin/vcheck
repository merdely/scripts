IMAGE_SEARCH+=("filestash_docker|/filestash")
filestash_docker() {
  docker_compose_exec curl -s "http://127.0.0.1:8334/about" | \
    awk '/<h1> Filestash .+ <\/h1>/{print $3;exit}'
}

filestash_latest() { # no_auto
  local app_version build_date
  app_version=$(curl -s "https://raw.githubusercontent.com/mickael-kerjean/filestash/refs/heads/master/server/common/constants.go" | \
    awk -F '"' '/^[[:space:]]*APP_VERSION[[:space:]]+=[[:space:]]+"/{print $2;exit}')
  build_date=$(skopeo inspect docker://machines/filestash:latest | jq -r '.Created' 2> /dev/null)
  build_date=$(echo "$build_date" | \
    awk -F'[-T]' '/^[[:digit:]]{4}-[[:digit:]]{2}-[[:digit:]]{2}T/{print "." $1 $2 $3;exit}')
  echo "$app_version$build_date"
}

