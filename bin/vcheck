IMAGE_SEARCH+=("php_fpm_docker|php.*fpm")
php_fpm_docker() {
  if docker_compose_exec test -f /etc/alpine-release &> /dev/null; then
    alpine_docker_package "php[0-9]+-fpm"
  else
    docker_compose_exec php-fpm -v | awk '/^PHP [0-9]/ {print "php-" $2;exit}'
  fi
}

php_fpm_alpine_latest() {
  if [[ -z "$minver" ]]; then
    alpine_package_latest 'php*-common'
  else
    local M=${minver%%.*}
    local m=${minver##*.}
    alpine_package_latest "php$M$m-common"
  fi
}

php_latest() { # no_auto
  curl -s "https://www.php.net/downloads.php?usage=web&os=linux&osvariant=linux-debian&version=default&source=Y" | \
    awk -F '["/]' '/<a href="\/distributions\/php-[^"]+\.tar\.gz">/{gsub(/\.tar\.gz/,"",$4);print $4;exit}'
}

