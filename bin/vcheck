privatebin() {
  local out
  out=$(curl_api)
  [[ -n "$out" ]] && \
    awk -F '[><]' '/<p class="col-md-1 col-xs-4 text-center">[^<]+<\/p>/{print $3;exit}' <<< "$out"
}

privatebin_latest() {
  github_project PrivateBin/PrivateBin
}

