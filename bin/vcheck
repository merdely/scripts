## END CHECK FUNCTIONS

usage() { # utility_function
  echo "usage: $PROGNAME [Options] SOFTWARE"
  echo "Options:"
  echo "  -h|--help     : print help text"
  echo "  --version     : print version number and exit"
  echo "  -d          + : print debug info"
  echo "  -v          + : be verbose"
  echo "  -q          + : be quiet"
  echo
  echo "Program-related options:"
  # Second line indent
  local ss=18
  usage_fold -s $ss -- "-c RCFILE     : path to RCFILE file (default: $rcfile)"
  usage_fold -s $ss -- "-u USER     x : drop privileges to USER if run as root (default: none)"
  usage_fold -s $ss -- "-p PRINTOPT   : print information (${bu}help${ubu} for option list)"
  usage_fold -s $ss -- "-1            : print information in a single column with '-p PRINTOPT'"
  usage_fold -s $ss -- "-w WAIT     x : latest checks results are cached for WAIT minutes (default: $cache_lifetime minutes)"
  usage_fold -s $ss -- "-r RETRY    x : delay between check retries for RETRY seconds (default: $retry_delay seconds)"
  usage_fold -s $ss -- "-P PRINTER  x : ip address for printer (for SOFTWARE == ink)"
  usage_fold -s $ss -- "-R REGEX   +x : a regex for commands that need sudo"
  usage_fold -s $ss -- "-C COMPOSE  x : Use docker compose file COMPOSE for docker compose commands"
  usage_fold -s $ss -- "-S SECONDS  x : number of SECONDS for docker container updates (default: $docker_seconds seconds)"
  usage_fold -s $ss -- "-X FUNC       : Run check with sudo"
  usage_fold -s $ss -- "-x SUDOUSER x : User to run sudo command as for -X (default: none)"
  echo
  # Check related options
  usage_fold -s $ss -- "-L LIST       : use LIST for each SOFTWARE argument as if LIST:SOFTWARE give as arguments"
  usage_fold -s $ss -- "-D            : print versions for docker containers that started in last (-S) SECONDS seconds"
  usage_fold -s $ss -- "-V MINVER   x : when getting a version, use the minor version MINVER (e.g ${bu}1.2${ubu} to find ${bu}1.2.4${ubu})"
  usage_fold -s $ss -- "-f SOFTWARE + : force updating latest SOFTWARE (default: update if cache expired)"
  usage_fold -s $ss -- "-F            : force updating all latest software (default: update if cache expired)"
  echo
  echo " Output related options:"
  usage_fold -s $ss -- "-o FILE     x : save JSON output to FILE instead"
  usage_fold -s $ss -- "-j          x : print output in JSON format to screen"
  usage_fold -s $ss -- "-t          x : print output in text format to screen"
  usage_fold -s $ss -- "-m          x : publish output to mqtt server"
  usage_fold -s $ss -- "-i          x : include invalid version results ('---') when updating (default: skip)"
  usage_fold -s $ss -- "-T            : Test Mode: print what would happen in a run"

  echo
  echo "MQTT-related Options:"
  usage_fold -s $ss -- "-M            : mqtt test mode: do not publish to mqtt; print instead"
  usage_fold -s $ss -- "-H HOST_NAME  : when prepending key names, use host_name (default: ${bu}${host_name}_${ubu})"
  usage_fold -s $ss -- "-I INK_TOPIC  : use INK_TOPIC when publishing printer_ink_check to MQTT (default: $ink_topic)"
  usage_fold -s $ss -- "-n          x : prepend mqtt key name with ${bu}${host_name}_${ubu} (default with ${bu}all${ubu})"
  usage_fold -s $ss -- "-N          x : do not prepend mqtt key name with ${bu}${host_name}_${ubu} (default with ${bu}latest${ubu})"
  echo "+ : option can be used more than once"
  echo "x : overrides config settings"
  echo
  echo "Notes:"
  usage_fold -f 1 --  "- By default, when using an output file, $PROGNAME detects if it is a json file (-j|-J overrides)"
  usage_fold -f 1 --  "- SOFTWARE options: all docker latest ink applist (${bu}$PROGNAME -p functions${ubu} applist)"
  usage_fold -f 1 --  "- SOFTWARE can be LIST:SOFTWARE: update LIST output with SOFTWARE (default: output full LIST)"
  usage_fold -f 1 --  "- If SOFTWARE matches key in [$PROGNAME] in RCFILE, the given list will be checked (i.e. custom software list)"
  usage_fold -f 1 --  "- ${bu}all${ubu} is a special list that prepends checks with ${bu}HOST_NAME${ubu} (mqtt) and adds $PROGNAME to checks"
  usage_fold -f 1 --  "- ${bu}docker${ubu} is a special list that is all checks for docker containers that have checks defined"
  exit "${1:-0}"
} # usage()

# Main program code
main() { # utility_function
  print_opts=(help apps remote_apps latest_apps non_auto_apps helper_functions functions docker example_config version)
  print_opt_descriptions=(
    "This help text"
    "Application/Service List"
    "Remote Host Application/Service List"
    "Latest Application List"
    "Non-Automatic/Disabled Latest Application List"
    "All Helper Functions"
    "All Application Version Check Functions"
    "List of Docker Checks"
    "Example Configuration File with all options documented"
    "Application Version"
  )

  # Set up ansi escape codes
  e=$'\e'
  b="${e}[1m"
  ub="${e}[22m"
  u="${e}[4m"
  uu="${e}[24m"
  bu="${b}${u}"
  ubu="${uu}${ub}"
  # Set default delay and wait values
  args_orig=("$@")
  cache_lifetime=60    # Number of minutes to wait between _latest checks
  retry_delay=1        # Number of seconds to wait between retries
  max_retries=1        # Number of times to try getting version
  unset docker_seconds # Look for containers that started within restart_delay seconds

  # Set some variables
  rcfile=$HOME/.config/"${PROGNAME}"rc
  [[ ! -r $rcfile && -r "$PROGDATA"/"${PROGNAME}"rc ]] && rcfile="$PROGDATA"/"${PROGNAME}"rc
  list_reserved_words=(docker user cache_dir cache_lifetime retry_delay max_retries compose_file docker_seconds sudo_regex sudo_user printer)

  if command -v hostname > /dev/null 2>&1; then
    host_name=$(hostname)
  else
    host_name=$(hostnamectl hostname)
  fi
  host_name=${host_name%%.*}
  host_name=$(echo "$host_name" | tr '[:upper:]' '[:lower:]')
  cache_dir="$HOME"/.cache/"$PROGNAME"

  # App Lists
  mapfile -t helper_list < <(awk '/^[^#].+[(]) {[[:space:]]+#[[:space:]]*helper_function/ && ! /[[:space:]]+#[[:space:]]*(utility_function|alias)/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t helper_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_helper/ && ! /[[:space:]]+#[[:space:]]*utility_function/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t no_auto_list < <(awk '/^[^#].+[(]) {[[:space:]]+#[[:space:]]*no_auto/ && ! /[[:space:]]+#[[:space:]]*(utility_function|alias)/ { gsub(/\(\).*$/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t no_auto_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_no_auto/ && ! /[[:space:]]+#[[:space:]]*utility_function/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t remote_list < <(awk '/^[^#].+[(]) {[[:space:]]+#[[:space:]]*remote_host/ && ! /[[:space:]]+#[[:space:]]*(utility_function|alias)/ { gsub(/\(\).*$/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t remote_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_remote/ && ! /[[:space:]]+#[[:space:]]*utility_function/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t app_list < <(awk '/^[^#].+[(]) {$/ && ! /[(]) {[[:space:]]+#[[:space:]]*helper_function/ && $1 !~ /_latest\(\)$/ && ! /[[:space:]]+#[[:space:]]*(utility_function|alias)/ {gsub(/\(\)$/,"",$1);print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t app_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_app/ && ! /[[:space:]]+#[[:space:]]*utility_function/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t latest_list < <(awk '/^[^#].+[(]) {$/ && ! /[(]) {[[:space:]]+#[[:space:]]*helper_function/ && ! /[(]) {[[:space:]]+#[[:space:]]*no_auto/ && $1 ~ /_latest\(\)/ && ! /[[:space:]]+#[[:space:]]*(utility_function|alias)/ {gsub(/\(\)$/,"",$1);print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t latest_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_latest/ && /[[:space:]]+#[[:space:]]*helper_alias/ && ! /[[:space:]]+#[[:space:]]*utility_function/ {sub(/^alias[[:space:]]+/,"");sub(/=.*$/,"");print}' "${SOURCED_LIBS[@]}")
  mapfile -t function_list < <(awk '/^[^#].+[(]) {/ && ! /[(]) {[[:space:]]+#[[:space:]]*helper_function/ && ! /[[:space:]]+#[[:space:]]*alias/ && ! /[[:space:]]+#[[:space:]]*utility_function/ {gsub(/\(\).*$/,"",$1);print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t function_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_/ && ! /[[:space:]]+#[[:space:]]*utility_function/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t utility_list < <(awk '/^[^#].+[(]) {[[:space:]]+#[[:space:]]*utility_function/ && ! /[[:space:]]+#[[:space:]]*(alias)/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")
  mapfile -t utility_alias_list < <(awk '/^[^#].+[(]) {.*}[[:space:]]+#[[:space:]]*alias_utility/ && ! /[[:space:]]+#[[:space:]]*utility_function/ { gsub(/\(\)/,"",$1); print $1}' "${SOURCED_LIBS[@]}")

  # Make sure mqtt commands are found
  check_prog curl || exit 1
  check_prog awk || exit 1
  check_prog sed || exit 1
  check_prog grep || exit 1
  check_prog printf || exit 1

  for a in "$@"; do [[ "$a" == "--help" ]] && usage verbose; done
  for a in "$@"; do [[ "$a" == "--version" ]] && echo "Version $PROGVER" && exit ; done
  debug=0
  verbose=0
  quiet=0
  cache_lifetime_set=false
  compose_file_set=false
  docker_seconds=30
  docker_seconds_set=false
  force_all=false
  force_list=()
  host_name_set=false
  include_invalid=false
  include_invalid_set=false
  ink_topic=ink2mqtt
  ink_topic_set=false
  mqtt_test=false
  output_file=/dev/stdout
  output_file_set=false
  output_mode=text
  output_mode_set=false
  prepend_name=false
  prepend_set=false
  printer_set=false
  print_single='-m'
  printonly=false
  rcfile_set=false
  retry_delay_set=false
  sudo_regexes=()
  sudo_regex_set=false
  sudo_user_set=false
  update=false
  unset compose_file sudo_user exec_user PRINTER minver print_opt update_list
  while getopts ":hdvqc:u:p:1w:r:P:R:C:S:X:x:LD:V:f:Fo:OtjmiTMH:INn" opt; do
    case $opt in
      # Base options
      :) case $OPTARG in
           *) log -e "-$OPTARG requires an argument" ; usage 1 ;;
         esac ;;
      d) debug=$(( debug + 1 )) ; quiet=0 ;;
      v) verbose=$(( verbose + 1 )) ; quiet=0 ;;
      q) quiet=$(( quiet + 1 )) ; verbose=0 ;;

      # Program-related options
      c) rcfile=$OPTARG ; rcfile_set=true ;;
      u) [[ $(id -u) != 0 ]] && log -e "-u only works for root" && exit 1
         if id "$OPTARG" &> /dev/null; then
           exec_user=$OPTARG
         else
           log -e "Invalid user for -u ($OPTARG)"
           exit 1
         fi ;;
      p) print_opt=$(echo "$OPTARG" | tr '[:upper:]' '[:lower:]') ;;
      1) print_single='-1' ;;
      w) if [[ $OPTARG =~ ^[0-9]+$ ]]; then
           cache_lifetime=$OPTARG
           cache_lifetime_set=true
         fi ;;
      r) if [[ $OPTARG =~ ^([0-9]+|\.[0-9]+|[0-9]+\.[0-9]+)$ ]]; then
           retry_delay=$OPTARG
           docker_seconds=$OPTARG
           retry_delay_set=true
         fi ;;
      P) PRINTER=$OPTARG ; printer_set=true ;;
      R) sudo_regexes+=("$OPTARG") ; sudo_regex_set=true ;;
      C) compose_file="$OPTARG" ; compose_file_set=true ;;
      S) if [[ $OPTARG =~ ^([0-9]+|\.[0-9]+|[0-9]+\.[0-9]+)$ ]]; then
           docker_seconds=$OPTARG
           docker_seconds_set=true
           update=true
         else
           log -e "Invalid value for SECONDS ($OPTARG)" && usage 1
         fi ;;
      X) shift ; sudo_exec "$@" ; exit $? ;;
      x) sudo_user=$OPTARG ;;

      # Check related options
      L) update_list=$OPTARG ; update=true ;;
      V) if [[ $OPTARG =~ ^[0-9]+\.?[0-9]+$ ]]; then
           minver=$OPTARG
         fi ;;
      f) force_list+=("$OPTARG") ;;
      F) force_all=true ;;

      # Output Options
      o) output_file=$OPTARG     ; output_file_set=true ; output_mode=json ; output_mode_set=true ;;
      j) output_file=/dev/stdout ; output_file_set=true ; output_mode=json ; output_mode_set=true ;;
      t) output_file=/dev/stdout ; output_file_set=true ; output_mode=text ; output_mode_set=true ;;
      m) output_file=/dev/stdout ; output_file_set=true ; output_mode=mqtt ; output_mode_set=true ;;
      i) include_invalid=true ; include_invalid_set=true ;;
      T) printonly=true ;;

      # MQTT Options
      M) mqtt_test=true ;;
      H) host_name=$OPTARG ; host_name_set=true ;;
      I) ink_topic=$OPTARG ; ink_topic_set=true ;;
      n) prepend_name=true  ; prepend_set=true ;;
      N) prepend_name=false ; prepend_set=true ;;

      # Catch everything else
      *) usage ;;
    esac
  done # while getopts OPTS_LIST opt; do
  shift $(( OPTIND - 1 ))

  # If -c passed and rcfile cannot be read, die
  if $rcfile_set && [[ ! -r "$rcfile" ]]; then
    log -e "Cannot read rcfile"
    exit 1
  fi

  if [[ -n "$rcfile" && -s "$rcfile" ]]; then
    log -d "Using $rcfile for configfile"
  fi
  if [[ ! -s "$rcfile" ]]; then
    log -d -d "Not using a config file (rcfile=$rcfile)"
  fi

  # Validate output_mode
  case "$output_mode" in json);;mqtt)output_file=/dev/stdout;; *)output_mode=text;output_file=/dev/stdout;; esac

  # Read configuration settings
  if [[ -z "$exec_user" && -s "$rcfile" ]]; then
    mapfile -t arr < <(get_config_value "$rcfile" "$PROGNAME" user)
    (( ${#arr[@]} > 0 )) && exec_user=${arr[-1]}
    unset arr
  fi

  # Drop privileges if running as root and $exec_user is defined
  [[ $(id -u) == 0 && -n "$exec_user" ]] && drop_privs "$exec_user" "${args_orig[@]}"

  local rcvalue=()
  # Read configuration file options
  if [[ -s "$rcfile" ]]; then
    rcvalue=(); mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" cache_dir)
    (( ${#rcvalue[@]} > 0 )) && cache_dir=${rcvalue[-1]}

    rcvalue=() ; ! $cache_lifetime_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" cache_lifetime)
    [[ ${#rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^[0-9]+$ ]] && cache_lifetime=${rcvalue[-1]}

    rcvalue=() ; ! $retry_delay_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" retry_delay)
    [[ ${#rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^([0-9]+|\.[0-9]+|[0-9]+\.[0-9]+)$ ]] && retry_delay=${rcvalue[-1]}

    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" max_retries)
    [[ ${#rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^[0-9]+$ ]] && max_retries=${rcvalue[-1]}

    rcvalue=() ; ! $compose_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" compose_file)
    (( ${#rcvalue[@]} > 0 )) && compose_file=${rcvalue[-1]}

    rcvalue=() ; ! $docker_seconds_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" docker_seconds)
    [[ ${rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^[0-9]+$ ]] && docker_seconds=${rcvalue[-1]}

    rcvalue=() ; ! $printer_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" printer)
    (( ${#rcvalue[@]} > 0 )) && PRINTER=${rcvalue[-1]}

    rcvalue=() ; ! $sudo_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" sudo_user)
    (( ${#rcvalue[@]} > 0 )) && sudo_user=${rcvalue[-1]}

    # Deal with multiple sudo_regex lines
    local rcsudo_regex
    if ! $sudo_regex_set; then
      rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" sudo_regex)
      for rcsudo_regex in "${rcvalue[@]}"; do
        sudo_regexes+=("$rcsudo_regex")
      done
    fi

    local rcmqtt_server=() rcmqtt_username=() rcmqtt_password=()
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt server)
    (( ${#rcvalue[@]} > 0 )) && mqtt_server=${rcvalue[-1]}
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt username)
    (( ${#rcvalue[@]} > 0 )) && mqtt_username=${rcvalue[-1]}
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt password)
    (( ${#rcvalue[@]} > 0 )) && mqtt_password=${rcvalue[-1]}

    rcvalue=() ; ! $host_name_set && mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt host_name)
    [[ ${#rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^[0-9]+$ ]] && host_name=${rcvalue[-1]}
    rcvalue=() ; ! $ink_topic_set && mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt ink_topic)
    [[ ${#rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^[0-9]+$ ]] && ink_topic=${rcvalue[-1]}
    rcvalue=() ; ! $prepend_name_set && mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt prepend_name)
    [[ ${#rcvalue[@]} -gt 0 && ${rcvalue[-1]} =~ ^[0-9]+$ ]] && prepend_name=${rcvalue[-1]}

  fi # if [[ -s "$rcfile" ]]; then

  local i=0 n=0 checks=()
  if [[ -n "$print_opt" ]]; then
    case "$print_opt" in
      help)
          echo "Available print options (-p PRINT_OPTION):"
          n=$(get_longest "${print_opts[@]}")
          for i in "${!print_opts[@]}"; do
            printf '    %-*s : %s\n' "$n" "${print_opts[i]}" "${print_opt_descriptions[i]}"
          done
          exit ;;
          # print_list "$print_single" -l "Available print options" "${print_opts[@]}" ; exit ;;
      a*) n=$(get_longest "${app_list[@]}" "${app_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "Host/Service Applications" "${app_list[@]}"
          print_list "$print_single" -n "$n" -l "Host/Service Aliases" "${app_alias_list[@]}"
          exit ;;
      r*) n=$(get_longest "${remote_list[@]}" "${remote_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "Remote Host Applications" "${remote_list[@]}"
          print_list "$print_single" -n "$n" -l "Remote Host Aliases" "${remote_alias_list[@]}"
          exit ;;
      l*) n=$(get_longest "${latest_list[@]}" "${latest_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "Automatic Latest Applications" "${latest_list[@]}"
          print_list "$print_single" -n "$n" -l "Automatic Latest Aliases" "${latest_alias_list[@]}"
          exit ;;
      n*) n=$(get_longest "${no_auto_list[@]}" "${no_auto_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "Non-Automatic Latest Applications" "${no_auto_list[@]}"
          print_list "$print_single" -n "$n" -l "Non-Automatic Latest Aliases" "${no_auto_alias_list[@]}"
          exit ;;
      h*) n=$(get_longest "${helper_list[@]}" "${helper_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "Helper Functions" "${helper_list[@]}"
          print_list "$print_single" -n "$n" -l "Helper Aliases" "${helper_alias_list[@]}"
          exit ;;
      f*) n=$(get_longest "${function_list[@]}" "${function_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "All Application Functions" "${function_list[@]}"
          print_list "$print_single" -n "$n" -l "All Application Aliases" "${function_alias_list[@]}"
          exit ;;
      d*) mapfile -t checks < <(docker_checks) || { log "There are no ${bu}docker${ubu} checks" ; exit 0 ; }
          print_list "$print_single" -l "${bu}docker${ubu} List Checks" "${checks[@]}"
          exit ;;
      u*) n=$(get_longest "${utility_list[@]}" "${utility_alias_list[@]}")
          print_list "$print_single" -n "$n" -l "Utility Functions" "${utility_list[@]}"
          print_list "$print_single" -n "$n" -l "Utility Aliases" "${utility_alias_list[@]}"
          exit ;;
      v*) echo Version $PROGVER ; exit 0 ;;
      e*) # Add new options for [$PROGNAME] to list_reserved_words array above
          echo "Example RCFILE (for \$HOME/.config/${PROGNAME}rc or $PROGDATA/${PROGNAME}rc)"
          echo "  [$PROGNAME]"
          echo "  user: username                $(printf '%*s' "${#PROGNAME}" " ") # no default; only used when run as root"
          echo "  cache_dir: /var/lib/$PROGNAME/.cache    # defaults to \$HOME/.cache/$PROGNAME"
          echo "  cache_lifetime: minutes       $(printf '%*s' "${#PROGNAME}" " ") # defaults to $cache_lifetime"
          echo "  retry_delay: seconds          $(printf '%*s' "${#PROGNAME}" " ") # defaults to $retry_delay"
          echo "  max_retries: number           $(printf '%*s' "${#PROGNAME}" " ") # defaults to $max_retries"
          echo "  compose_file: /home/u/compose.yml   # no default"
          echo "  docker_seconds: seconds       $(printf '%*s' "${#PROGNAME}" " ") # defaults to $docker_seconds"
          echo "  include_invalid: true/false   $(printf '%*s' "${#PROGNAME}" " ") # defaults to $include_invalid"
          echo "  sudo_regex: _latest$          $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  sudo_regex: ^sudo             $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  sudo_user: username           $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  printer: ip/name              $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  # custom list names cannot be 'docker' or any of the other above config options"
          echo "  all: sw1 sw2 sw3 sw4          $(printf '%*s' "${#PROGNAME}" " ") # no default; ${bu}all${ubu} list"
          echo "  my_custom_list: sw2 sw5       $(printf '%*s' "${#PROGNAME}" " ") # no default; custom list"
          echo "  my_other_list: sw3 sw7 sw9    $(printf '%*s' "${#PROGNAME}" " ") # no default; custom list"
          echo
          echo "  [$PROGNAME:list_name]"
          echo "  output_file: file"
          echo "  output_mode: text/json/mqtt"
          echo "  include_invalid: true/false"
          echo "  compose_file: /home/u/project.yaml"
          echo
          echo "  [$PROGNAME:version_check_function_name]"
          echo "  output_file: file"
          echo "  output_mode: text/json/mqtt"
          echo "  include_invalid: true/false"
          echo "  use_sudo: true/false"
          echo "  sudo_user: username"
          echo "  cache_lifetime: minutes"
          echo "  retry_delay: seconds"
          echo "  max_retries: number"
          echo "  compose_file: /home/u/software.yaml"
          echo
          echo "  [mqtt]"
          echo "  server: mqtt.example.com"
          echo "  username: mqtt"
          echo "  password: mypassword"
          echo "  host_name: hostname"
          echo "  ink_topic: topicname"
          echo "  prepend_name: true/false      # defaults to false"
          echo
          echo "  [github|codeberg|forgejo|gitea|gitlab]"
          echo "  token: github_pat_TOKEN"
          echo
          echo "  [flip_2_dnd_pro] # This is for making the pro version installable from obtainium"
          echo "  repo_url: private_repo_for_flip_2_dnd_pro local copy"
          echo
          echo "  [joplin|private_aur|plex|privatebin|yourls]"
          echo "  url: server_url"
          echo "  # for yourls, create a ver.php that prints the version"
          echo "  # example in the yourls() function in ${bu}$(realpath "$0")${ubu}"
          echo
          echo "  [routeros]"
          echo "  url: routeros_device_url"
          echo "  username: routeros_username"
          echo "  password: routeros_password"
          echo
          echo "  [slzb]"
          echo "  url: slzb_device_url"
          echo "  username: slzb_device_username"
          echo "  password: slzb_device_password"
          echo "  chip: number            # 0=slzb-06p10"
          echo "  type: number            # 0=coordinator"
          echo "  esp_type: TYPE          # type=0=ESP vs. ESPs3 for type>SLZB_06MR4[14]"
          echo
          echo "  [tasmota]"
          echo "  device_name: tasmota_device_name"
          echo "  device_ip: tasmota_device_ip"
          echo "  username: tasmota_device_username"
          echo "  password: tasmota_device_password"
          echo
          echo "  [truenas]"
          echo "  url: truenas_server_url"
          echo "  apikey: truenas_server_api_key"
          echo
          exit ;;
      *) log -e "Invalid option for -p ($print_opt)" && usage 1 ;;
    esac # case "$print_opt" in
  fi

  # If -L was given and no software was listed, add 'docker' to software list
  [[ -n "$update_list" ]] && (( $# == 0 )) && set -- "$update_list"
  (( $# == 0 )) && usage

  # Set up software list from command line arguments, substitute _ for -
  mapfile -t software < <(printf '%s\n' "$@" | sort -u)

  # Prepare cache_dir
  CACHE_DIR_PREPARED=false
  # Warn if wait is extreme
  (( cache_lifetime < 30 )) && log -q "Warning: Latest update WAIT set to under 30 minutes"
  (( cache_lifetime > 1440 )) && log -q "Warning: Latest update WAIT set to over $(( cache_lifetime / 60 )) hours/$(( cache_lifetime / 60 / 24 )) days (WAIT is in minutes)"

  # Print debug info
  if (( debug > 1 )); then
    log -d "[GLOBAL SETTINGS] running as $(id -un)"
    log -d "[GLOBAL SETTINGS] rcfile=$rcfile"
    log -d "[GLOBAL SETTINGS] cache_dir=$cache_dir"
    log -d "[GLOBAL SETTINGS] cache_lifetime=$cache_lifetime"
    log -d "[GLOBAL SETTINGS] printonly=$printonly"
    log -d "[GLOBAL SETTINGS] output_file=$output_file"
    log -d -d "[GLOBAL SETTINGS] output_file_set=$output_file_set"
    log -d "[GLOBAL SETTINGS] output_mode=$output_mode"
    log -d -d "[GLOBAL SETTINGS] output_mode_set=$output_mode_set"
    log -d "[GLOBAL SETTINGS] software=${software[*]}"
    log -d "[GLOBAL SETTINGS] compose_file=$compose_file"
    log -d "[GLOBAL SETTINGS] docker_seconds=$docker_seconds"
    log -d "[GLOBAL SETTINGS] retry_delay=$retry_delay"
    log -d "[GLOBAL SETTINGS] printer=$PRINTER"
    log -d "[GLOBAL SETTINGS] include_invalid=$include_invalid"
    log -d "[GLOBAL SETTINGS] force_all=$force_all"
    (( ${#force_list[@]} > 0 ))     && log -d "[GLOBAL SETTINGS] force_list=${force_list[*]}"
    [[ -n "$sudo_user" ]]           && log -d "[GLOBAL SETTINGS] sudo_user=$sudo_user"
    (( ${#sudo_regexes[@]} > 0 ))   && printf "[DEBUG] [GLOBAL SETTINGS]" && set | grep ^sudo_regexes= >&2
    [[ -n "$mqtt_server" ]]         && log -d "[GLOBAL SETTINGS] mqtt_server=$mqtt_server"
    [[ -n "$mqtt_username" ]]       && log -d "[GLOBAL SETTINGS] mqtt_username=$mqtt_username"
    [[ -n "$mqtt_password" ]]       && log -d -d -d "[GLOBAL SETTINGS] mqtt_password='$mqtt_password'"
    [[ -n "$mqtt_server" && -n "$prepend_name" ]] && log -d "[GLOBAL SETTINGS] prepend_name=$prepend_name"
    [[ -n "$mqtt_server" && -n "$ink_topic" ]]    && log -d "[GLOBAL SETTINGS] ink_topic=$ink_topic"
    echo
    (( debug > 3 )) && exit
  fi

  # Prep variables
  printlist=()
  json_string="[]" # json string for printing to the screen
  saved_prepend_name=$prepend_name
  saved_output_file=$output_file
  saved_output_mode=$output_mode
  saved_include_invalid=$include_invalid
  saved_docker_seconds=$docker_seconds
  saved_compose_file=$compose_file

  local tmpstring sw_skip_vflag=() sw_jq=() sw_search=() sw_sed=()
  local sw_name sw_check_set tmp_name sw_orig sw_tag sw_project

  # TODO: Turn into function?
  # Process software list
  log -d -d "Software list: ${software[*]}"
  for list in "${software[@]}"; do
    [[ -z "$list" ]] && continue
    prepend_name=$saved_prepend_name
    output_file=$saved_output_file
    output_mode=$saved_output_mode
    include_invalid=$saved_include_invalid
    docker_seconds=$saved_docker_seconds
    compose_file=$saved_compose_file
    sw_list=()

    # If list=docker, load docker checks
    if [[ "$list" == "docker" ]]; then
      mapfile -t sw_list < <(docker_checks)
      log -d "Setting software list to '${sw_list[*]}'"
      if (( ${#sw_list[@]} == 0 )); then
        log "There are no ${bu}docker${ubu} checks"
        exit
      fi

    # If command line parameter is "list:sw", do update
    elif [[ -n "$update_list" || "$list" =~ ^[0-9a-zA_Z_-]+: ]]; then
      sw_list=("${list#*:}")
      if [[ "$list" == "$update_list" && -s "$rcfile" ]]; then
        log -d "Reading configfile for software list for ${list//\\/\\\\} (update_list)"
        read -ra sw_list <<< "$(get_config_value "$rcfile" "$PROGNAME:${list//\\/\\\\}" "list" | tr '\n' ' ')"
        log -d "Setting software list to '${sw_list[*]}' for $list"
      fi
      [[ -n "$update_list" ]] && list=$update_list
      list=${list%:*}

      log -d "Processing an update of ${sw_list[*]} for $list"
      update=true

    # If sw is a list defined in the config, load its software in sw list
    elif [[ " ${list_reserved_words[*]} " != *" $list "* && -s "$rcfile" ]]; then
      log -d "Reading configfile for software list for ${list//\\/\\\\}"
      read -ra sw_list <<< "$(get_config_value "$rcfile" "$PROGNAME:${list//\\/\\\\}" "list" | tr '\n' ' ')"
      log -d "Setting software list to '${sw_list[*]}' for $list"
      # Add check for this program if list=all
      [[ "$list" == "all" ]] && { sw_list+=("$PROGNAME") ; log -d "Adding self to all sw_list" ; }
    fi # if [[ "$list" == "docker" ]]; then

    log -d -d "Defaulting software list to $list for $list"
    (( ${#sw_list[@]} == 0 )) && sw_list=("$list")

    unset rcoutput_file rcoutput_mode
    if [[ -s "$rcfile" ]]; then
      # output_mode
      rcvalue=() ; ! $output_mode_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"${list//\\/\\\\}" output_mode)
      (( ${#rcvalue[@]} > 0 )) && output_mode=${rcvalue[-1]} && \
        case "$output_mode" in json);;mqtt)output_file=/dev/stdout;; *)output_mode=text;output_file=/dev/stdout;; esac

      # output_file
      rcvalue=() ; ! $output_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"${list//\\/\\\\}" output_file)
      (( ${#rcvalue[@]} > 0 )) && output_file=${rcvalue[-1]} && output_mode=json
      log -d "Reading ${list//\\/\\\\} config settings: output_file='$output_file' output_mode='$output_mode'"

      # prepend_name
      rcvalue=() ; ! $prepend_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"${list//\\/\\\\}" prepend_name)
      (( ${#rcvalue[@]} > 0 )) && prepend_name=${rcvalue[-1]}

      # include_invalid
      rcvalue=() ; ! $include_invalid_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"${list//\\/\\\\}t" include_invalid)
      (( ${#rcvalue[@]} > 0 )) && include_invalid=${rcvalue[-1]}

      rcvalue=() ; ! $compose_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"${list//\\/\\\\}" compose_file)
      (( ${#rcvalue[@]} > 0 )) && compose_file=${rcvalue[-1]}
    fi

    # If -L docker was given and docker_seconds is set, only look for checks
    # related to containers that were restarted within docker_seconds seconds
    if $update && [[ "$list" == docker ]]; then
      docker_seconds_local=$docker_seconds
      if [[ -s "$rcfile" ]]; then
        rcvalue=() ; ! $docker_seconds_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$list" docker_seconds)
        (( ${#rcvalue[@]} > 0 )) && docker_seconds_local=${rcvalue[-1]}
      fi

      if [[ -n "$docker_seconds_local" ]]; then
        log -d "Checking age for docker containers"
        # Loop through checks (in this case all container checks) and find
        # containers that were restarted within docker_seconds seconds, then
        # reverse check back for the check name and add it to the list
        container_list=()
        for sw_list_item in "${sw_list[@]}"; do
          mapfile -t containers < <(image_search -C "$sw_list_item")

          for container in "${containers[@]}"; do
            log -d "Checking age for docker container: $container"
            started_at=$(docker inspect --format '{{.State.StartedAt}}' "$container")
            [[ ! $started_at =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?Z$ ]] && continue
            started_secs=$(date -d "$started_at" +%s)
            [[ ! $started_secs =~ ^[0-9]+$ ]] && log -e "$started_secs not a number" && continue
            now=$(date +%s)
            log -d "Container Mode ($container): now=$now seconds=$started_secs diff=$(( now - started_secs )) docker_seconds_local=$docker_seconds_local"
            (( now - started_secs > docker_seconds_local )) && { log -d -d -d "$container not old enough" ; continue ; }
            log -d -d "Adding $container ($sw_list_item) to sw_list"
            [[ " ${container_list[*]} " != *" $sw_list_item "* ]] && container_list+=("$sw_list_item")
          done # for container in "${containers[@]}"; do
        done # for sw in "${sw_list[@]}"; do
        log -d -d "container_list=${container_list[*]}"
        sw_list=("${container_list[@]}")
      fi # if [[ -n "$docker_seconds_local" ]]; then
    fi # if $update && [[ "$list" == docker ]]; then

    mapfile -t sw_list < <(printf '%s\n' "${sw_list[@]}" | sort -u)
    log -d -d "Sorting software list: ${sw_list[*]}"

    case "$list" in
      all)
        log -d "Applying 'all' specific settings"
        [[ "${sw_list[*]}" == "all" ]] && log -e "'list' property not defined in [$PROGNAME:all] section of RCFILE" && exit 1
        ! $prepend_set && prepend_name=true
        ;;
      latest)
        log -d "Applying 'latest' specific settings"
        ! $prepend_set && prepend_name=false
        sw_list=("${latest_list[@]}" "${latest_alias_list[@]}" "${sw_list[@]}")
        ;;
    esac

    if (( debug > 1 )); then
      [[ "$output_file" != "$saved_output_file" ]] && log -d "[$list SETTINGS] output_file=$output_file"
      [[ "$output_mode" != "$saved_output_mode" ]] && log -d "[$list SETTINGS] output_mode=$output_mode"
      [[ "$include_invalid" != "$saved_include_invalid" ]] && log -d "[$list SETTINGS] include_invalid=$include_invalid"
      [[ "$docker_seconds" != "$saved_docker_seconds" ]] && log -d "[$list SETTINGS] docker_seconds=$docker_seconds"
      [[ "$compose_file" != "$saved_compose_file" ]] && log -d "[$list SETTINGS] compose_file=$compose_file"
      log -d "[$list SETTINGS] list=${sw_list[*]}"
      echo
      (( debug > 3 )) && exit
    fi

    for sw in "${sw_list[@]}"; do
      [[ -z "$sw" ]] && continue
      sw_check_set=false
      sw_skip_vflag=(-V)
      sw_search=()
      sw_jq=()
      sw_sed=()

      log -d "Starting $sw"
      listname=$list
      [[ "$listname" == "$sw" ]] && unset listname
      tmp_name=$sw

      rcvalue=() ; [[ -s "$rcfile" ]] && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"${sw//\\/\\\\}" check)
      (( ${#rcvalue[@]} > 0 )) && sw=${rcvalue[-1]} && sw_check_set=true && \
        log -d "Read check '$sw' for $tmp_name"
      sw_orig=$sw

      # For dynamic/auto checks, strip off preceding 
      sw_name=$sw
      sw_tag=$(grep -Po "(?<=/)$AUTO_CHECKS$" <<< "$sw_name")
      while [[ "$sw_name" =~ ^(jq=|postsed=|remove=|search=|noskip_version_filter|skip_version_filter) ]]; do
        case "$sw_name" in
          jq=*)
            tmpstring=${sw_name%%/*}
            sw_name=${sw_name#jq=*/}
            sw_jq+=(-j "${tmpstring#jq=}")       # The last one will be used
            ;;
          postsed=*)
            tmpstring=${sw_name%%/*}
            sw_name=${sw_name#postsed=*/}
            sw_sed+=(-S "${tmpstring#postsed=}")  # The last one will be used
            ;;
          remove=*)
            tmpstring=${sw_name%%/*}
            sw_name=${sw_name#remove=*/}
            sw_search+=(-r "${tmpstring#remove=}")
            ;;
          search=*)
            tmpstring=${sw_name%%/*}
            sw_name=${sw_name#search=*/}
            sw_search+=(-s "${tmpstring#search=}")
            ;;
          noskip_version_filter*)
            sw_name=${sw_name#noskip_version_filter/}
            sw_skip_vflag=(-V)
            ;;
          skip_version_filter*)
            sw_name=${sw_name#skip_version_filter/}
            sw_skip_vflag=(-v)
            ;;
          *) ;;
        esac
      done
      sw_project=${sw_name%/$sw_tag}
      ! $sw_check_set && tmp_name=$sw_project
      sw_name=$tmp_name

      log -d -d "list=$list"
      log -d -d "listname=$listname"
      log -d -d "sw_name=$sw_name"
      log -d -d "tmp_name=$tmp_name"
      log -d -d "sw_check_set=$sw_check_set"
      log -d -d "sw_tag=$sw_tag"
      log -d -d "sw_project=$sw_project"
      log -d -d "sw_skip_vflag=${sw_skip_vflag[*]}"
      log -d -d "sw_jq=${sw_jq[*]}"
      log -d -d "sw_search=${sw_search[*]}"
      log -d -d "sw_sed=${sw_sed[*]}"
      log -d -d "sw_orig=$sw_orig"

      log -d "Processing $sw_name${listname:+ for "$listname"}"

      unset rcoutput_file rcoutput_mode
      if [[ -s "$rcfile" ]]; then
        # See if check is defined
        # rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$list" check)
        # (( ${#rcvalue[@]} > 0 )) && sw=${rcvalue[-1]} && \
        #   log -d "Read check '$sw' for $sw_name"

        # output_mode
        rcvalue=() ; ! $output_mode_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" output_mode)
        (( ${#rcvalue[@]} > 0 )) && output_mode=${rcvalue[-1]} && \
          case "$output_mode" in json);;mqtt)output_file=/dev/stdout;; *)output_mode=text;output_file=/dev/stdout;; esac

        # output_file
        rcvalue=() ; ! $output_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" output_file)
        (( ${#rcvalue[@]} > 0 )) && output_file=${rcvalue[-1]} && output_mode=json
        log -d "Reading $sw_name config settings: output_file='$output_file' output_mode='$output_mode'"

        # prepend_name
        rcvalue=() ; ! $prepend_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" prepend_name)
        (( ${#rcvalue[@]} > 0 )) && prepend_name=${rcvalue[-1]}

        rcvalue=() ; ! $compose_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" compose_file)
        (( ${#rcvalue[@]} > 0 )) && compose_file=${rcvalue[-1]}
      fi

      # Set COMPOSE_FILE if necessary
      [[ -n "$compose_file" ]] && export COMPOSE_FILE=$compose_file

      found=false
      [[ "$sw_orig" =~ /$AUTO_CHECKS ]] && found=true
      if ! $found && ! function_exists "$sw"; then
        for tag in docker git flatpak appimage pacman arch command; do
          if function_exists "$sw"_"$tag"; then
            sw=${sw}_$tag
            found=true
            break
          fi
        done
      else
        found=true
      fi
      log -d -d "Validating function for $sw exists (exists=$found)"
      ! $found && log -e "Invalid software: $sw" && continue

      # If software is "ink" but printer is not set, go to the next software
      if [[ "$sw" == "printer_ink_check" && -z "$PRINTER" ]]; then
        log -e "No printer defined for $sw"
        continue
      fi

      # Reset lifetime to cache_lifetime, delay to retry_delay and retries to max_retries
      lifetime=$cache_lifetime
      delay=$retry_delay
      retries=$max_retries

      if [[ -s "$rcfile" ]]; then
        log -d "Reading cache_lifetime retry_delay max_retries settings from config for $sw_name"
        # Check if this version check has a setting for cache_lifetime and use it if it does
        rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" cache_lifetime)
        (( ${#rcvalue[@]} > 0 )) && lifetime=${rcvalue[-1]}

        # Check if this version check has a setting for retry_delay and use it if it does
        rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" retry_delay)
        (( ${#rcvalue[@]} > 0 )) && delay=${rcvalue[-1]}

        # Check if this version check has a setting for max_retries and use it if it does
        rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" max_retries)
        (( ${#rcvalue[@]} > 0 )) && retries=${rcvalue[-1]}
      fi

      # If printonly mode, add to list and continue to next
      $printonly && printlist+=("$sw") && continue

      if (( debug > 1 )) && [[ "$listname" != "$sw_name" ]]; then
        [[ "$output_file" != "$saved_output_file" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] output_file=$output_file"
        [[ "$output_mode" != "$saved_output_mode" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] output_mode=$output_mode"
        [[ "$include_invalid" != "$saved_include_invalid" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] include_invalid=$include_invalid"
        [[ "$docker_seconds" != "$saved_docker_seconds" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] docker_seconds=$docker_seconds"
        [[ "$compose_file" != "$saved_compose_file" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] compose_file=$compose_file"
        [[ "$lifetime" != "$cache_lifetime" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] lifetime=$lifetime"
        [[ "$delay" != "$retry_delay" ]]       && log -d "[${listname:+$listname:}$sw_name SETTINGS] delay=$delay"
        [[ "$retries" != "$max_retries" ]]     && log -d "[${listname:+$listname:}$sw_name SETTINGS] retries=$retries"
        log -d "[${listname:+$listname:}$sw_name SETTINGS] sw=$sw_name"
        echo
        (( debug > 3 )) && exit
      fi

      # If not-force and check is for latest version, respect timestamp
      i=0
      unset update_time
      while (( i <= retries )); do
        # If a retry, sleep for $delay
        (( i > 0 )) && log -v "Retrying for $sw_name (try $i of $retries) after $delay wait" && sleep "$delay"

        unset ret version
        [[ "$sw" == *"_latest" ]] && prepare_cache_dir "$cache_dir"

        # If -f and -F not used, user is not root, sw IS a latest check, and 
        # cache_file is readable, read the cache file if not stale
        if ! $force_all && [[ $(id -u) != 0 && \
          " ${force_list[*]} " != *" $sw_name "* && " ${force_list[*]} " != *" $sw "* && \
            "$sw" == *"_latest" && -r "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}" ]]; then
          stamp=$(stat -c "%Y" "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}")
          now=$(date +%s)

          # If the timestamp is less than 1 hour
          if (( now - stamp < lifetime * 60 - 1 )) ; then
            log -v "$sw_name was updated $(( (now - stamp) / 60 )) minutes ago, using cache ($lifetime minutes)"
            log -d "Reading $sw_name info from cache ($(( (now - stamp) / 60 )) of $lifetime minutes)"
            version=$(cat "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}")
            ret=$?
            update_time=$stamp
          fi
        else
          (( debug > 0 )) && $force_all && log -d "Forced update"
          (( debug > 0 )) && [[ " ${force_list[*]} " == *" $sw "* ]] && log -d "Forced update"

          use_sudo=false
          # Loop through sudo_regexes to see if $sw_name matches a regex to use sudo
          for regex in "${sudo_regexes[@]}"; do
            [[ "$sw" =~ $regex ]] && use_sudo=true
          done
          log -d -d "Checking to see if $sw should be run with sudo (use_sudo=$use_sudo)"

          if [[ -s "$rcfile" ]]; then
            # Read config file to see if there are specific settings for $sw
            rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" use_sudo)
            (( ${#rcvalue[@]} > 0 )) && use_sudo=${rcvalue[-1]}
            rcvalue=() ; $use_sudo && ! $sudo_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME":"$sw_name" sudo_user)
            (( ${#rcvalue[@]} > 0 )) && sudo_user=${rcvalue[-1]}
          fi

          if $use_sudo && (( $(id -u) != 0 )); then
            [[ -z "$sudo_user" ]] && log -e "Cannot use sudo for $sw_name: No sudo_user defined (-x username)" && exit 1
            unset dflags
            log -v -v "Using sudo as $sudo_user to check $sw_name version"
            rp=$(realpath "$0")
            debug_args=()
            for (( i = 0 ; i < debug ; i++ )); do debug_args+=("-d"); done
            log -d "[sudo] running 'sudo -n -u $sudo_user $rp -X $sw ${debug_args[*]}'"
            version=$(sudo -n -u "$sudo_user" "$rp" -X "$sw" "${debug_args[@]}")
            ret=$?
            update_time=$(date +%s)
            (( ret != 0 )) && log -e "Could not get $sw_name version with sudo" && continue
          else
            if [[ "$sw" =~ /$AUTO_CHECKS && " ${app_list[*]} ${app_alias_list[*]} " != *" $sw "* ]]; then
              log -d -d "Running '_auto_check -p $sw_project -t $sw_tag ${sw_skip_vflag[*]} ${sw_jq[*]} ${sw_search[*]} ${sw_sed[*]} $sw_name' to get version"
              version=$(_auto_check -p "$sw_project" -t "$sw_tag" \
                "${sw_skip_vflag[@]}" "${sw_jq[@]}" "${sw_search[@]}" "${sw_sed[@]}" "$sw_name")
            else
              log -d -d -d "Running $sw to get version"
              version=$($sw)
            fi
            ret=$?
            update_time=$(date +%s)
          fi

          if [[ "$ret" != "0" || -z "$version" || "$version" == "null" ]]; then
            if [[ "$sw" == "printer_ink_check" ]]; then
              log -d "Could not get printer info for $sw, returning error json"
            else
              log -d "Could not get a version for $sw, returning '---'"
              version="---"
            fi
            update_time=$(date +%s)
            rm -f "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
            break
          fi

          if [[ "$sw" == *"_latest" ]]; then
            log -d "Writing latest update for $sw_name to cache"
            echo "$version" > "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
            # shellcheck disable=SC2153
            (( $(id -u) == 0 )) && chown "$SUDO_USER":"$(id -g "$SUDO_USER")" "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
          fi
        fi
        # If version is set, move on
        [[ "$ret" == "0" && -n "$version" && "$version" != "null" ]] && break
        # Otherwise, set to --- and delete cache file
        version="---"
        rm -f "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
        i=$(( i + 1 ))
      done # while (( i <= retries )); do

      # Strip leading v
      version=${version#v}
      version=${version#V}

      # Prepare Output
      log -d "${listname:+$listname:}$sw_name printing $output_mode to $output_file"

      # Output text immediately and go to next software
      if (( quiet == 0 )) && [[ "$output_mode" == "text" || "$output_file" != "/dev/stdout" ]]; then
        if [[ "$sw" == "printer_ink_check" ]]; then
          # If cannot print using jq, use echo + some tr's
          if ! jq -rn --arg n "$sw" --argjson j "$version" \
            '$j | "\($n): \(.printer) - cyan=\(.cyan) magenta=\(.magenta) yellow=\(.yellow) black=\(.black) photoblack=\(.photoblack 2> /dev/null)"'; then
            echo "$out" | tr -d '\n' | tr -s ' '
          fi
        else
          echo "$sw_name: $version"
        fi
      fi
      [[ "$output_mode" == "text" ]] && continue
      if [[ "$output_mode" == "mqtt" ]]; then
        local mqtt_output
        check_prog mosquitto_pub || continue
        log -d -d "Publishing MQTT version info for ${listname:+$listname:}$sw_name"
        printf -v mqtt_output '{ "$version": "%s" }' "$version"
        [[ "$sw" == "printer_ink_check" ]] && mqtt_output=$version

        if ! $prepend_set && [[ "$sw" == *"_latest" || " ${remote_list[*]} " == *" $sw "* ]]; then
          prepend_name=false
        fi

        if ! $prepend_set && [[ " ${app_list[*]} " == *" $sw "* ]]; then
          prepend_name=true
        fi

        # Set up MQTT topic
        if $prepend_name; then
          topic="software_versions/${host_name}_$sw_name"
        else
          topic="software_versions/$sw_name"
        fi
        [[ "$sw" == "printer_ink_check" ]] && topic="$ink_topic/$printer"

        log -d -d "$sw_name = $mqtt_output"
        if $mqtt_test; then
          printf '%s: %s\n' "$topic" "$version"
        else
          log -v "$sw_name: $version"
          mosquitto_pub -r -h "${mqtt_server:?}" -u "${mqtt_username:?}" -P "${mqtt_password:?}" \
            -i "$PROGNAME" -t "${topic:?}" -m "${mqtt_output:?}"
        fi
        log -v "Version published to MQTT"
        ! $mqtt_test && log -v "Updated $topic: $version"
        continue
      fi

      # Printing to screen
      if [[ "$output_file" == "/dev/stdout" ]]; then
        tmpjson=${json_string:-"[]"}
      # Printing to json file
      elif [[ -s "$output_file" ]] && jq -r '.[]' "$output_file" &> /dev/null; then
        tmpjson=$(jq -r '.' "$output_file" 2> /dev/null)
      fi

      # If tmpjson is not valid json with "[ ... ]", reset to "[]"
      if ! jq -n --argjson j "$tmpjson" '$j[]' &> /dev/null; then
        tmpjson="[]"
      fi

      # Save printer ink info to json string
      if [[ "$sw" == "printer_ink_check" ]]; then
        ! $include_invalid && grep -q '^[[:space:]]*"error":' <<< "$version" && continue
        tmpjson=$(jq -n --argjson j "$tmpjson" --argjson new "$version" '
          if $j | any(.[]; .name == $new.name and .ip == $new.ip)
          then $j | map(if .name == $new.name and .ip == $new.ip then $new else . end)
          else $j + [$new]
          end | sort_by(.name | ascii_downcase)
        ' 2> /dev/null)
      # Save software version info to json string
      else
        ! $include_invalid && [[ "$version" == "---" ]] && continue
        tmpjson=$(jq -n --argjson j "$tmpjson" --arg n "$sw_name" --arg v "$version" --arg t "${update_time:-$(date +%s)}" '
          if $j | any(.[]; .name == $n)
          then $j | map(if .name == $n then {name: $n, version: $v, time: ($t|tonumber)} else . end)
          else $j + [{name: $n, version: $v, time: ($t|tonumber)}]
          end | sort_by(.name | ascii_downcase)
        ' 2> /dev/null)
      fi

      # Could not generate valid json string
      # shellcheck disable=SC2181
      if (( $? != 0 )); then
        log -e "Could not add $sw_name to $listname json string"
        continue
      # Generated valid json for ouput
      else
        local direct_write=false
        # If printing to screen, save to global json_string
        if [[ "$output_file" == "/dev/stdout" ]]; then
          json_string=$tmpjson
        # Printing to a file
        else
          log -d -d "Removing $output_file.new"
          if [[ -e "$output_file".new ]]; then
            rm -f "$output_file".new
          fi
          # Could not delete .new file
          if [[ -e "$output_file".new ]]; then
            log -d -d "Could not remove $output_file.new"
            direct_write=true
          else
            log -d -d "Writing to $output_file.new"
            jq -rn --argjson j "$tmpjson" '$j' 2> /dev/null > "$output_file".new
            if [[ ! -s "$output_file".new ]]; then
              log -d -d "Could not write to $output_file.new"
              direct_write=true
            else
              log -d -d "Moving $output_file.new to $output_file"
              mv "$output_file".new "$output_file" || \
                log -e "Error: Could not move .new to $output_file"
            fi
          fi
          if $direct_write; then
            log -d -d "Writing directly to $output_file"
            jq -rn --argjson j "$tmpjson" '$j' 2> /dev/null > "$output_file" || \
              log -e "Error: Could not write to file $output_file"
          fi
          if [[ -s "$output_file" ]]; then
            log -v "JSON Output saved to '$output_file'"
          else
            log -e "Could not write '$tmpjson' to '$output_file'"
            continue
          fi
        fi
      fi
    done # for sw in "${sw_list[@]}"; do
  done # for list in "${software[@]}"; do

  # Print global json_string to the screen
  if [[ "$output_mode" == "json" && "$output_file" == "/dev/stdout" ]]; then
    log -d "Printing json string to the screen"
    jq -rn --argjson j "$json_string" '$j'
  fi

  # If in Print Only mode, print list of software
  if $printonly && (( ${#printlist[@]} > 0 )); then
    print_list "$print_single" -s -l "[Test Mode] List of checks" "${printlist[@]}"
  fi
}

if (return 2> /dev/null); then
  # If included as a library
  return 0
else
  # If run as a program
  main "$@"
fi

