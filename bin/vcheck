IMAGE_SEARCH+=("registry_docker|registry")
registry_docker() {
  docker_logs registry 2>&1 | \
    awk '
      /service=registry version=v/ {
        v = substr($0, index($0, "service=registry version=v") + 26)
      }
      END {
        gsub(/[ \t]+/,"", v)
        print v
      }'
}

registry_docker_latest() { # no_auto
  docker_tags -s '^v?[0-9][0-9.]+$' registry
}

registry_latest() { # no_auto
  github_project distribution/distribution
}

