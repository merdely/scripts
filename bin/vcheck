snapcast() {
  if command -v snapclient > /dev/null 2>&1; then
    snapclient --version | awk '/snapclient/{print $2;exit}'
  elif command -v snapserver > /dev/null 2>&1; then
    snapserver --version | awk '/snapserver/{print $2;exit}'
  else
    echo "{ \"Error\": \"snapcast not installed\" }" && return 1
  fi
}

snapcast_latest() {
  github_project snapcast/snapcast | sed -r 's/p[0-9]+" }$/" }/'
}

