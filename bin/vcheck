IMAGE_SEARCH+=("jellyfin_vue_docker|jellyfin/jellyfin_vue")
jellyfin_vue_docker() {
  check_prog js-beautify || return 1
  local tmp
  tmp=$(maketemp -d)

  # Copy container files to temp directory
  docker_compose_cp /usr/share/nginx/html/assets "$tmp"

  # Get js-beautify'd output from the main-*.js file
  local jsb
  jsb=$(cat "$tmp"/assets/main-*.js | js-beautify 2>&1)
  [[ -z "$jsb" ]] && log -e "Could not get js-beautify'd output for ${FUNCNAME[0]}" && return 1

  # Get the version string for Jellyfin Vue
  local version=
  version=$(echo "$jsb" | \
    awk '/name: ["`'"'"']Jellyfin Web.*Vue/{on=1}on==1&&$1=="version:"{print $2;exit}')
  [[ -z "$version" ]] && log -e "Could not get version string for ${FUNCNAME[0]}" && return 1

  # Get the version number from version string
  echo "$jsb" | awk -F'["`'"'"']' -v v="$version" '$1 ~ v " ?= ?"{print $2;exit}'
}

jellyfin_vue_docker_latest() { # no_auto
  docker_tags -s '^stable-rc.[0-9][0-9.]+' jellyfin/jellyfin-vue
    sed 's/^stable-rc\.//'
}

jellyfin_vue_latest() { # no_auto
  github_tags jellyfin/jellyfin-vue
}

