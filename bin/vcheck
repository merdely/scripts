slzb_core() { # remote_host
  check_prog jq || return 1
  local out
  out=$(curl_api)
  jq -rn --argjson j "$out" '$j.Info.sw_version' 2> /dev/null
}

slzb_core_latest() {
  check_prog jq || return 1

  [[ ! -s "$rcfile" ]] && { log -e "Cannot read $rcfile for ${FUNCNAME[0]}" ; return 1; }
  local url esptype out
  mapfile -t url     < <(get_config_value "$rcfile" "${FUNCNAME[0]}" url)
  mapfile -t esptype < <(get_config_value "$rcfile" "${FUNCNAME[0]}" esp_type)
  (( ${#url[@]} == 0 ))     && { log -e "Could not read ${FUNCNAME[0]} URL from $rcfile" ; return 1 ; }
  (( ${#esptype[@]} == 0 )) && { log -e "Could not read ${FUNCNAME[0]} EspType from $rcfile" ; return 1 ; }

  local fw_url
  fw_url=$(curl -s --compressed "${url[-1]}" 2>&1 | \
    awk -F"'" '/^const espFwInfoUrl[[:space:]]*=/{print $2;exit}')
  log -d -d "fw_url = $fw_url"
  [[ ! $fw_url =~ ^https?:// ]] && { log -e "Could not get firmware url from ${url[-1]}" ; return 1 ; }
  log -d -d "fw_url=${fw_url}${esptype[-1]}" >&2
  out=$(curl -s "${fw_url}${esptype[-1]}")
  log -d -d "Curl Output: $out"
  [[ -n "$out" ]] && out=$(jq -rn --argjson j "$out" '$j.["fw"][] | select(.dev == false) | .ver' 2> /dev/null)
  log -d -d "Jq Output: $out"
  [[ -n "$out" ]] && sort -V <<< "$out" | \
    tail -n1
}

slzb_radio() { # remote_host
  check_prog jq || return 1
  local out
  out=$(curl_api)
  jq -rn --argjson j "$out" '$j.Info.zb_version' 2> /dev/null
}

slzb_radio_latest() {
  check_prog jq || return 1

  [[ ! -s "$rcfile" ]] && { log -e "Cannot read $rcfile for ${FUNCNAME[0]}" ; return 1; }
  local url chip type
  mapfile -t url  < <(get_config_value "$rcfile" "${FUNCNAME[0]}" url)
  mapfile -t chip < <(get_config_value "$rcfile" "${FUNCNAME[0]}" chip)
  mapfile -t type < <(get_config_value "$rcfile" "${FUNCNAME[0]}" "type")
  (( ${#url[@]} == 0 ))  && { log -e "Could not read ${FUNCNAME[0]} URL from $rcfile" ; return 1 ; }
  (( ${#chip[@]} == 0 )) && { log -e "Could not read ${FUNCNAME[0]} Chip from $rcfile" ; return 1 ; }
  (( ${#type[@]} == 0 )) && { log -e "Could not read ${FUNCNAME[0]} Type from $rcfile" ; return 1 ; }

  local fw_url
  fw_url=$(curl -s --compressed "${url[-1]}" 2>&1 | \
    awk -F"'" '/^const zbFwInfoUrl[[:space:]]*=/{print $2;exit}')
  [[ ! $fw_url =~ ^https?:// ]] && return 1
  curl -s "$fw_url" | \
    jq -r --arg chip "${chip[-1]}" --arg type "${type[-1]}" \
      '.[$chip][] | select(.type == $type) | .rev' 2> /dev/null| \
    sort -V | \
    tail -n1
}

