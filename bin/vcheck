splunk() {
  if [[ -x /opt/splunk/bin/splunk ]]; then
    awk -F= '/^VERSION/{print $2;exit}' /opt/splunk/etc/splunk.version
  elif [[ -x /opt/splunkforwarder/bin/splunk ]]; then
    awk -F= '/^VERSION/{print $2;exit}' /opt/splunkforwarder/etc/splunk.version
  fi
}

IMAGE_SEARCH+=("splunk_docker|splunk:")
splunk_latest() {
  curl -s "https://www.splunk.com/en_us/download/splunk-enterprise.html" | \
    awk -F'[<>]' '/<span class="version">/{print $3;exit}'
}

splunk_forwarder() {
  if [[ -x /opt/splunkforwarder/bin/splunk ]]; then
    awk -F= '/^VERSION/{print $2;exit}' /opt/splunkforwarder/etc/splunk.version
  elif [[ -x /Applications/splunkforwarder/bin/splunk ]]; then
    awk -F= '/^VERSION/{print $2;exit}' /Applications/splunkforwarder/etc/splunk.version
  fi
}

splunk_forwarder_latest() {
  curl -s "https://www.splunk.com/en_us/download/universal-forwarder.html" | \
    awk -F'[<>]' '/<span class="version">/{print $3;exit}'
}

