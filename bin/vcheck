IMAGE_SEARCH+=("plex_docker|plexinc/pms-docker")
plex_docker() {
  local out
  out=$(curl_api)
  [[ -n "$out" ]] && \
  awk '
    /^<MediaContainer/ {
      for (i = 2; i < NF; i++) {
        split($i, a, "=")
        if (a[1] == "version") {
          split(substr(a[2], 2, length(a[2]) - 2), v, "-")
          print v[1]
        }
      }
      exit
    }' <<< "$out"
}

plex_docker_latest() { # no_auto
  docker_tags -s '^v?[0-9][0-9.]+[0-9.-]+([0-9a-f]+)?$' plexinc/pms-docker | \
    sed -r 's/-[0-9a-f]+$//'
}

plex_latest() { # no_auto
  check_prog jq || return 1
  curl -s "https://plex.tv/pms/downloads/5.json?channel=plexpass" | \
    jq -r '.["computer"]["Linux"].version' 2> /dev/null | \
    awk -F- '{print $1;exit}'
}

