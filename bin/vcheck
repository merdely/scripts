#!/usr/bin/env bash

set -o nounset

# Define variables for this program
vcheck() { echo "$PROGVER"; } # Define check for this program
PROGNAME=vcheck               # The name of this program
PROGDATA=/etc/vcheck          # Default program data directory
PROGVER=1.1.0                 # Program version
ALPINE_VER=""                 # Global placeholder for current Alpine Linux version
SUDO_EXEC=false               # Is this being run through sudo_exec
DEBUG_EXIT=5                  # Number of -d flags to print debug info and exit
DEBUG=0
QUIET=0
VERBOSE=0
readonly DOCKER_TOO_OLD=19
export PROGNAME PROGVER PROGDATA ALPINE_VER SUDO_EXEC DEBUG_EXIT
export DEBUG DEBUG_EXIT QUIET VERBOSE

# Array of sourced libraries
[[ "${BASH_SOURCE[0]:-}" == "$0" ]] && SOURCED_LIBS=("$0")

# Add common bin dirs to the PATH
PATH=$PATH:/bin:/usr/bin:/usr/local/bin:/sbin:/usr/sbin:/usr/local/sbin:$HOME/.local/bin
export PATH

# Define a SEMVER_REGEX to be used in functions to validate version strings
# From https://semver.org/#is-there-a-suggested-regular-expression-regex-to-check-a-semver-string
# Their major, minor, patch, and prerelease groups break bookstack because of its leading 0
# Changed 0|[1-9] to [0-9] and removed the "?P<tag>" python-specific regex
SEMVER_MAJOR='([0-9][0-9]*)'
SEMVER_MINOR='\.([0-9][0-9]*)'
SEMVER_PATCH='(\.([0-9][0-9]*))?'
SEMVER_PRERELEASE='(-(([0-9][0-9]*|[0-9]*[a-zA-Z-][0-9a-zA-Z-]*)(\.([0-9][0-9]*|[0-9]*[a-zA-Z-][0-9a-zA-Z-]*))*))?'
SEMVER_BUILDMETA='(\+([0-9a-zA-Z-]+(\.[0-9a-zA-Z-]+)*))?'
HOTFIX='(\.([0-9][0-9]*))?'
VER_YMD='([0-9]{4})[\._-]([01]?[0-9])[\._-]([0123]?[0-9])'
LSVER='(-(ls[0-9]+))?'
SEMVER_REGEX="($SEMVER_MAJOR$SEMVER_MINOR$SEMVER_PATCH$HOTFIX|$VER_YMD)$SEMVER_PRERELEASE$SEMVER_BUILDMETA$LSVER"
export SEMVER_REGEX

# TODO automate this similar to how _latest was done before
# Define list of check types
CHECK_LIST='(alpine_repo|appimage|aur|cat|codeberg|codeberg_tags|command|curl|curlapi|docker_copy|docker_exec|docker_inspect|docker_inspect_image|docker_logs|docker_printenv|docker_tags|flatpak|flathub|forgejo|forgejo_tags|gitdescribe|gitea|gitea_tags|gittags|github|github_tags|gitlab|gitlab_tags|pacman|pacman_repo)(_latest)?'
CHECK_MODIFIERS='(prejq=|postjq=|xml=|presed=|postsed=|remove=|search=|noskip_version_filter|skip_version_filter)'
export CHECK_LIST CHECK_MODIFIERS

# Store all temp files in a tempdir and delete the directory on exit
TEMPDIR=$(mktemp -d)
_cleanup() {
  local ret=$?
  log -d -d -d "Cleaning up $TEMPDIR"
  [[ -n "$TEMPDIR" && -d "$TEMPDIR" ]] && rm -Rf -- "$TEMPDIR"
  exit "$ret"
}
trap '_cleanup' EXIT
trap 'exit 1' INT TERM

## FUNCTIONS

# Older versions of bash don't have mapfile
if ! command -v mapfile &> /dev/null; then
  mapfile() {
    local _mapfile_trim=0 _mapfile_var="" _mapfile_line="" _mapfile_i=0
    # Only handle the -t flag (strip trailing carriage returns)
    [[ "${1:-}" == "-t" ]] && { _mapfile_trim=1; shift; }
    # If var name not passed, use MAPFILE as the variable
    _mapfile_var=${1:-MAPFILE}

    # Validate variable name: must be a legal identifier (no array syntax, no special chars)
    if [[ ! "$_mapfile_var" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
      log -e "mapfile: \`$_mapfile_var': not a valid identifier"
      return 1
    fi

    # Clear the array using indirect reference via read trick
    unset "$_mapfile_var"
    while IFS= read -r _mapfile_line; do
      (( _mapfile_trim )) && _mapfile_line=${_mapfile_line%$'\r'}
      # eval is restricted: only the value is variable, and it's single-quoted with internal
      # single quotes escaped, so no shell metacharacters in the value can escape the quoting
      _mapfile_line=${_mapfile_line//"'"/"'\\''"}
      eval "${_mapfile_var}[${_mapfile_i}]='${_mapfile_line}'"
      (( _mapfile_i++ ))
    done

    # Capture final line if input didn't end with newline
    if [[ -n "$_mapfile_line" ]]; then
      _mapfile_line=${_mapfile_line//"'"/"'\\''"}
      eval "${_mapfile_var}[${_mapfile_i}]='${_mapfile_line}'"
    fi
  }
fi

# Log messages respecting -d, -v, -q, and -e
log() { # utility_function
  # Comment out printing Running here because it is too noisy
  # (( DEBUG == 3 )) && echo "[DEBUG] (${FUNCNAME[0]}) Running: ${FUNCNAME[0]} $*" >&2
  local opt="" OPTARG="" OPTIND=1
  local print_error=false check_debug=0 check_quiet=0 check_verbose=0 prepend=""
  while getopts ":edwqv" opt; do
    case "$opt" in
      e) print_error=true ; prepend="[ERROR] (${FUNCNAME[1]}): " ;;
      d) check_debug=$(( check_debug + 1 )) ; ! $print_error && prepend="[DEBUG] (${FUNCNAME[1]}): " ;;
      q) check_quiet=$(( check_quiet + 1 )) ;;
      v) check_verbose=$(( check_verbose + 1 )) ;;
      w) prepend="[WARNING] (${FUNCNAME[1]}): " ;;
      *) echo "[WARNING] Invalid flag ($OPTARG)" >&2 ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  ! $print_error && (( check_quiet < QUIET )) && return 0
  ! $print_error && (( check_debug > DEBUG )) && return 0
  ! $print_error && (( check_verbose > VERBOSE && check_verbose > QUIET )) && ! $mqtt_test && return 0
  echo "${prepend}$*" >&2
  return 0
}

# Get the fields from a bearer string
get_bearer_field() {
  local field=${1:-} str=${2:-} out=""
  # Try quoted form first: field="value"
  out=$(sed -n "s/.*${field}=\"\\([^\"]*\\)\".*/\\1/p" <<< "$str")
  [[ -n "$out" ]] && { echo "$out"; return; }
  # Fall back to unquoted form: field=value
  sed -n "s/.*${field}=\\([^,]*\\).*/\\1/p" <<< "$str"
}

# Read a config value (optionally from a section) from a config file
get_config_value() { # utility_function
  # No section: variable=( $(get_config_value file key) )
  # Section:    variable=( $(get_config_value file section key) )

  local ltrim=1 rtrim=1 localdebug=false ncm=false
  local opt="" OPTARG="" OPTIND=1
  [[ "${debug:-}" ]] && localdebug=$debug
  [[ "${DEBUG:-}" ]] && localdebug=$DEBUG

  # Try to respect a global debug variable; supports true/on/yes/debug/1-999 or false/0
  shopt -q nocasematch && ncm=true ; shopt -s nocasematch
  case "$localdebug" in true|debug|y|yes|on|[1-9]|[1-9]0|[0-9][1-9]|[1-9][0-9]0|[0-9][0-9][1-9])localdebug=true;;*)localdebug=false;;esac
  ! $ncm && shopt -u nocasematch ; ncm=false

  # Handle options -L and -T for preserving leading/trailing whitespace in values
  while getopts ":LT" opt;do case "$opt" in L)ltrim=0;;T)rtrim=0;;*);;esac;done;shift $((OPTIND-1))

  # Require at least two arguments (file and key with section being optional)
  (( $# < 2 )) && return 1

  local configfile=${1:-} section="" key=${2:-}
  # Replace ^~ with $HOME
  [[ "$configfile" == ~* ]] && configfile=$HOME${configfile#~}

  # Validate that configfile can be read
  if [[ ! -r "$configfile" ]]; then
    $localdebug && echo "Warning: Cannot read ${configfile##*/} for ${section:+[$section] }$key" >&2
    return 1
  fi

  # If 3 arguments provided
  (( $# >= 3 )) && section=${2:-} && key=${3:-}

  if [[ -n "$section" ]]; then
    awk -v section="$section" -v key="$key" -v ltrim="${ltrim:-1}" -v rtrim="${rtrim:-1}" '
      BEGIN {
        in_section = 0
        section_header = "[" section "]"
        # Build key matcher: key followed by optional space then : or =
      }
      {
        # Left-trim the line for comparisons
        ltrimmed = $0
        sub(/^[[:space:]]+/, "", ltrimmed)
      }
      /^[[:space:]]*\[/ {
        in_section = (index(ltrimmed, section_header) == 1 && \
                      substr(ltrimmed, length(section_header) + 1) ~ /^[[:space:]]*$/)
        next
      }
      in_section {
        # Check if line starts with key followed by optional whitespace then : or =
        if (index(ltrimmed, key) == 1) {
          rest = substr(ltrimmed, length(key) + 1)
          if (rest ~ /^[[:space:]]*[:=]/) {
            sub(/^[^:=]+[:=]/, "", ltrimmed)
            if (ltrim == 1) sub(/^[[:space:]]+/, "", ltrimmed)
            if (rtrim == 1) sub(/[[:space:]]+$/, "", ltrimmed)
            print ltrimmed
          }
        }
      }' "$configfile"
  else
    awk -v key="$key" -v ltrim="${ltrim:-1}" -v rtrim="${rtrim:-1}" '
      {
        # Left-trim the line for comparisons
        ltrimmed = $0
        sub(/^[[:space:]]+/, "", ltrimmed)
      }
      {
        # Check if line starts with key followed by optional whitespace then : or =
        if (index(ltrimmed, key) == 1) {
          rest = substr(ltrimmed, length(key) + 1)
          if (rest ~ /^[[:space:]]*[:=]/) {
            sub(/^[^:=]+[:=]/, "", ltrimmed)
            if (ltrim == 1) sub(/^[[:space:]]+/, "", ltrimmed)
            if (rtrim == 1) sub(/[[:space:]]+$/, "", ltrimmed)
            print ltrimmed
          }
        }
      }' "$configfile"
  fi
}

# Calculate the number of seconds from docker's Created/RunningFor fields
calc_seconds() { # utility_function
  [[ ! "${1:-}" =~ ^[0-9]+" "[^[:space:]]+" ago"$ ]] && { echo 0 ; return 1 ; }

  case "${1:-}" in
    *second*) echo "${1%% *}" ;;
    *minute*) echo $((${1%% *}*60)) ;;
    *hour*)   echo $((${1%% *}*60*60)) ;;
    *day*)    echo $((${1%% *}*60*60*24)) ;;
    *week*)   echo $((${1%% *}*60*60*24*7)) ;;
    *month*)  echo $((${1%% *}*60*60*24*30)) ;;
    *)        echo $((${1%% *}*60*60*24*365)) ;;  # everything else should be years
  esac
}

# check if a program is installed and print an error message if not
check_prog() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { echo "usage: check_prog prog" ; return 1 ; }
  local dirs="" dir="" prog=${1:-} func="${FUNCNAME[1]:+ (needed for "${FUNCNAME[1]}")}"
  [[ -n "${2:-}" ]] && func=" (needed for ${2:-})"
  [[ -z "${2:-}" && "${FUNCNAME[1]:-main}" == "main" ]] && func=""
  IFS=: read -ra dirs <<< "$PATH"
  for dir in "${dirs[@]}"; do
    if [[ -x "$dir"/"$prog" ]]; then
      return 0
    fi
  done
  log -e "$prog command not found$func"
  return 1
}

# Drop privileges and run this program as $exec_user
drop_privs() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  [[ "${BASH_SOURCE[0]:-}" != "$0" ]] && { log -e "Cannot drop privs with a sourced script" ; return 1 ; }
  (( $# < 2 )) && { log -d "Not enough arguments" ; return 1 ; }
  local exec_user=${1:?} user_id=0 args=() prev=false arg="" full_command=""
  shift
  user_id=$(id -u 2> /dev/null)
  if (( user_id != 0 )) || ! id "$exec_user" &> /dev/null; then
    log -d -d -d "Executing user must be root (is $user_id) and $exec_user must exist"
    return 1
  fi
  for arg in "$@"; do
    [[ "$arg" =~ ^-(u|c)$ ]] && prev=true && continue
    $prev && prev=false && continue
    args+=("$arg")
  done

  full_command=$(realpath "$0")
  local su_cmd=""
  su_cmd=$(printf '%q' "$full_command")
  for arg in "${args[@]}"; do
    su_cmd+=" $(printf '%q' "$arg")"
  done
  echo "Dropping privileges to $exec_user to run: $su_cmd"

  cd /
  if command -v sudo &> /dev/null; then
    exec sudo -i -u "$exec_user" "$full_command" "${args[@]}"
  else
    case "$(uname -s)" in
      Linux)
        if command -v runuser &> /dev/null; then
          exec runuser -l -u "$exec_user" -- "$full_command" "${args[@]}"
        else
          exec su - -s "$(command -v bash)" "$exec_user" -c "$su_cmd"
        fi ;;
      *)
        exec su - -m "$exec_user" -c "$su_cmd" ;;
    esac
  fi
}

# Generate an authstring for curl from a token in the config file
# Called with 'gen_authstring github'
gen_authstring() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Site parameter missing" ; return 1 ; }
  local section=${1:-} key=${2:-token} token=()
  mapfile -t token < <(get_config_value "$rcfile" "$section" "$key")
  if (( ${#token[@]} > 0 )); then
    echo "-H"
    echo "Authorization: Bearer ${token[0]}"
    return 0
  fi
  log -d -d -d "Cannot get '$section' $key"
  return 1
}

# Print the length of the longest element
get_longest() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} from ${FUNCNAME[1]}"
  (( $# == 0 )) && { echo 0 ; return 0 ; }
  local max=0 string=""
  for string in "$@"; do
    (( ${#string} > max )) && max=${#string}
  done
  echo "$max"
}

# Wrap mktemp and add tmpfile/tmpdir to TEMPFILES
maketemp() { # utility_function
  local tmpfile="" args=()
  local opt="" OPTARG="" OPTIND=1
  # Pass all args back to mktemp except -p (and arg)
  while getopts ":p:dqut:" opt; do
    case "$opt" in
      d|q|u) args+=("-$opt") ;;
      t) args+=("-$opt" "$OPTARG") ;;
      p) [[ "$OPTARG" == -* ]] && args+=("$OPTARG") ;;
      *) ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  # Re-set args
  set -- "${args[@]}" "$@"
  tmpfile=$(mktemp -p "$TEMPDIR" "$@")
  echo "$tmpfile"
}

# Print arrays
# Usage: print_list [-n 14] -l "Label" "${arr1[@]}"
# Where -n tells print_list to pad for each string being 14 characters
# -n could be passed with $(get_longest "${arr1[@]}" "${arr2[@]}" ...) to have multiple lists line up
print_list() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  local opt="" OPTARG="" OPTIND=1
  local maxlen=0 mark_sudo=false single=false label="List Items" arr=()
  while getopts ":n:l:sm1" opt; do
    case "$opt" in
      n) [[ ! $OPTARG =~ ^[0-9]+$ ]] && { log -e "-n requires a number" ; return 1 ; } || maxlen=$OPTARG ;;
      l) label=$OPTARG ;;
      s) mark_sudo=true ;;
      m) single=false ;;
      1) single=true ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( $# == 0 )) && return 1

  (( maxlen == 0 )) && maxlen=$(get_longest "$@")
  local term_width=100
  term_width=$(tput cols 2>/dev/null) || term_width=100
  local col_width=$(( maxlen + 2 ))   # +2 for minimum padding
  local indent=4
  local usable=$(( term_width - indent ))
  local num_cols=$(( usable / col_width ))
  (( num_cols < 1 )) && num_cols=1
  ( (( num_cols < 1 )) || $single ) && num_cols=1

  # Sort array
  mapfile -t arr < <(printf '%s\n' "$@" | sort -u)

  local item_type="items"
  [[ "$label" == *" "* ]] && item_type=${label##* }
  item_type=$(echo "$item_type" | tr '[:upper:]' '[:lower:]')

  printf "%s (%s %s):" "$label" "$#" "$item_type"
  local i=0
  for (( i = 0; i < ${#arr[@]}; i++ )); do
    (( i % num_cols == 0 )) && printf '\n%*s' "$indent" ""
    needs_sudo=""
    $mark_sudo && for regex in "${sudo_regexes[@]}"; do
      [[ "${arr[i]}" =~ $regex ]] && needs_sudo=" *"
    done
    printf '%-*s' "${col_width}" "${arr[i]}$needs_sudo"
  done
  printf '\n\n'
}

# Strip check modifiers from a check string
strip_modifiers() { # utility_function
  log -d -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "${1:-}" == "-h" ]] && { log "usage: ${FUNCNAME[0]} check_string" ; return 0 ; }
  local check=${1:-}
  log -d -d -d -d "check = '$check'"
  while [[ "$check" =~ ^$CHECK_MODIFIERS ]]; do
    check=${check#*!!}
    log -d -d -d -d "check = '$check'"
  done
  echo "$check"
}

# Run a specific function as $sudo_user
sudo_exec() { # utility_function
  local arg args=()

  # Check to see if this is called with -d
  for arg in "$@"; do
    [[ "$arg" == "SUDO_EXEC_DEBUG="* ]] && { DEBUG=${arg#*=} ; continue ; }
    [[ "$arg" == "DOCKER_SECONDS="* ]] && { docker_seconds=${arg#*=} ; continue ; }
    [[ "$arg" == "DOCKER_FILTER="* ]] && { docker_filter=${arg#*=} ; continue ; }
    [[ "$arg" == "PRINTER="* ]] && { PRINTER=${arg#*=} ; continue ; }
    args+=("$arg")
  done
  [[ ! "$DEBUG" =~ ^[0-9]+$ ]] && DEBUG=${DEBUG:-0}
  [[ ! "$docker_seconds" =~ ^[0-9]+$ ]] && docker_seconds=${docker_seconds:-0}
  [[ "$docker_filter" != true ]] && docker_filter=false
  set -- "${args[@]}"

  cd /

  SUDO_EXEC=true
  export SUDO_EXEC
  # Check to see if function is in app_list
  [[ " ${check_list[*]:-} ${all_checks[*]:-} " != *" ${1:-} "* ]] && { log -e "Invalid app_check function: ${1:-}" ; return 1 ; }
  log -d "Executing '${1:-} ${*:2} as $(id -un)" >&2

  # Execute check function
  "${1:-}" "${@:2}"
}

# Fold the usage lines
usage_fold() { # utility_function
  local opt="" OPTARG="" OPTIND=1
  local first=2 second=4 cols=100 first_set=false second_set=false
  cols=${COLUMNS:-$(tput cols < /dev/tty 2>/dev/null || echo 100)}

  while getopts ":f:s:c:" opt; do
    case "$opt" in
      f) [[ $OPTARG =~ ^[0-9]+$ ]] && first=$OPTARG  && first_set=true ;;
      s) [[ $OPTARG =~ ^[0-9]+$ ]] && second=$OPTARG && second_set=true ;;
      c) [[ $OPTARG =~ ^[0-9]+$ ]] && cols=$OPTARG ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  # If -f passed but not -s, update second to be first + 2
  ! $second_set && $first_set && second=$(( first + 2 ))

  # Set up padding
  local pad1="" pad2="" string="" clean=""
  printf -v pad1 '%*s' "$first" ''
  printf -v pad2 '%*s' "$second" ''

  # Pass output through fold with settings
  if (( $# > 0 )); then
    string="$*"
  elif [[ ! -t 0 ]]; then
    string=$(cat)
  else
    return 1
  fi
  clean=$(printf '%s' "$string" | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g')
  cols=$(( cols + ${#string} - ${#clean} - 1 ))

  # Deal with 2 level folds properly
  local first_width=$(( cols - first ))
  local rest_width=$(( cols - second ))

  # Fold at first-line width, split head from tail
  local folded="" line1="" rest=""
  folded=$(printf '%s\n' "$string" | fold -s -w "$first_width")
  line1=$(printf '%s\n' "$folded" | head -1)
  rest=$(printf '%s\n' "$folded" | tail -n +2 | tr '\n' ' ' | sed 's/[[:space:]]*$//')

  # Print first line
  printf '%s\n' "${pad1}${line1}"
  # Print remaining lines
  if [[ -n "$rest" ]]; then
    printf '%s\n' "$rest" | fold -s -w "$rest_width" | sed "s/^/$pad2/"
  fi
}

## Helper functions
# Search alpine repo for latest version of a package
alpine_repo_package() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog xmllint "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1

  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local pkg=${1:-} url="" out="" tmpfile=""

  if [[ -z "$ALPINE_VER" ]]; then
    ALPINE_VER=$(curl --no-progress-meter "https://pkgs.alpinelinux.org/packages" \
      | xmllint --html --xpath '//select[@id="branch"]/option/text()' - 2>/dev/null | \
      awk '/v[0-9]/{gsub(/^ +/,"");gsub(/ +$/,"");print}' | \
      sort -V | \
      tail -n1)
    export ALPINE_VER
  fi

  [[ -z "$ALPINE_VER" ]] && { log -q "Warning: Could not determine alpine version" ; return 1 ; }

  url="https://pkgs.alpinelinux.org/packages?name=$pkg&branch=$ALPINE_VER&arch=x86_64"
  log -d "DEBUG (${FUNCNAME[0]}): URL = $url"

  tmpfile=$(maketemp)
  curl --no-progress-meter -Lo "$tmpfile" "$url"
  log -d -d "Curl output: $(cat "$tmpfile")"
  [[ ! -s "$tmpfile" ]] && return 1
  out=$(xmllint --html --xpath '//strong[@aria-label="Package version"]/text()' "$tmpfile" 2>/dev/null)
  log -d -d "xmllint output: $out"
  [[ -n "$out" ]] && sort -V <<< "$out" \
    | tail -n1
}

# Extract app image version from filename
appimage_check() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  # Validate appimage_path
  if [[ -n "$appimage_path" && ! -d "$appimage_path" ]]; then
    log -e "AppImage path does not exist: $appimage_path"
    return 1
  fi

  compgen -G "$appimage_path/$1{*.:-}AppImage" | \
    sed -r "s#^.*${1:-}-(.*)\.AppImage#\1#"
}

# Run different variations of 'command --version' to get a version for a command
command_check() { # check_function
  # log -d -d -d "Running: ${FUNCNAME[0]} $*"
  log -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local cmd=${1:-} out="" ret=0
  log -d "cmd = '$cmd'"
  if command -v "$cmd" &> /dev/null; then
    log -d -d "Attemping '$cmd --version'"
    out=$("$cmd" --version 2>&1)
    ret=$?
    log -d -d -d "$cmd --version: $out"
    [[ "$ret" -eq 0 && -n "$out" ]] && { echo "$out" ; return 0 ; }

    log -d -d "Attemping '$cmd -V'"
    out=$("$cmd" -V 2>&1)
    ret=$?
    [[ "$ret" -eq 0 && -n "$out" ]] && { echo "$out" ; return 0 ; }

    log -d -d "Attemping '$cmd version'"
    out=$("$cmd" version 2>&1)
    ret=$?
    [[ "$ret" -eq 0 && -n "$out" ]] && { echo "$out" ; return 0 ; }

    log -d -d "Attemping '$cmd --help'"
    out=$("$cmd" --help 2>&1)
    ret=$?
    [[ "$ret" -eq 0 && -n "$out" ]] && { echo "$out" ; return 0 ; }

    log -e "Could not determine version for ${1:-}"
    return 1
  else
    log -e "Could not find command '$cmd' for ${1:-}"
    return 1
  fi
}

# Use curl with credentials to get version info from an API
# To use this function, there must be a section in $rcfile
# The section should be named after the check using curl_api
# The section must include url and optionally username & password or apikey
curl_api() { # check_function
  log -d "Running ${FUNCNAME[0]} for ${FUNCNAME[1]}"
  local url="" username="" password="" apikey="" out=""

  local check_name=${1:-}
  [[ -z "${check_name:-}" ]] && check_name=${FUNCNAME[1]}

  # shellcheck disable=SC2154
  [[ ! -s "$rcfile" ]] && { log -e "Cannot read $rcfile for $check_name" ; return 1; }
  mapfile -t url      < <(get_config_value "$rcfile" "$check_name" url)
  mapfile -t username < <(get_config_value "$rcfile" "$check_name" username)
  mapfile -t password < <(get_config_value "$rcfile" "$check_name" password)
  mapfile -t apikey   < <(get_config_value "$rcfile" "$check_name" apikey)

  out=$(maketemp)
  (( ${#url[@]} == 0 ))      && { log -e "Could not read $check_name URL from $rcfile" ; return 1 ; }
  if (( ${#apikey[@]} > 0 )); then
    curl --no-progress-meter -Lo "$out" -X GET -H \
      "Authorization: Bearer ${apikey[0]}" \
      "${url[0]}"
  elif (( ${#username[@]} > 0 || ${#password[@]} > 0 )); then
    (( ${#username[@]} == 0 )) && { log -e "Could not read $check_name Username from $rcfile" ; return 1 ; }
    (( ${#password[@]} == 0 )) && { log -e "Could not read $check_name Password from $rcfile" ; return 1 ; }

    curl --no-progress-meter -Lo "$out" -X GET -H \
      "Authorization: Basic $(printf '%s:%s' "${username[0]}" "${password[0]}"|base64|tr -d '\n')" \
      "${url[0]}"
  else
    curl --no-progress-meter -Lo "$out" -X GET "${url[0]}"
  fi
  log -d -d "Curl output: $out"
  cat "$out"
}

# Search for a container name via the image or name fields
docker_container_search() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local docker_ps="" out="" seconds=0 ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d "Returning DOCKER_TOO_OLD";return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  docker_ps=$(docker ps --format='{{.Names}}|{{.Image}}|{{.RunningFor}}')
  log -d -d -d "docker ps output = '$docker_ps'"

  log -d -d "Searching image field for ${1:-}"
  out=$(awk -F '|' -v s="${1:-}" '$2 ~ s {print $1"|"$3;exit}' <<< "$docker_ps")
  log -d -d "awk output searching image field = '$out'"
  if [[ -n "$out" ]]; then
    seconds=$(calc_seconds "${out##*|}")
    log -d -d "${out%%|*} running for ${out##*|} ($seconds seconds)"
    log -d -d "Comparing ${seconds:-${docker_seconds:-1}} > ${docker_seconds:-2}"
    # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
    $docker_filter && (( ${seconds:-${docker_seconds:-1}} > ${docker_seconds:-2} )) && return $DOCKER_TOO_OLD
    echo "${out%%|*}"
    return 0
  fi
  log -d -d "Searching name field for ${1:-}"
  out=$(awk -F '|' -v s="${1:-}" '$1 ~ s {print $1"|"$3;exit}' <<< "$docker_ps")
  log -d -d "awk output search name field = '$out'"
  if [[ -n "$out" ]]; then
    seconds=$(calc_seconds "${out##*|}")
    log -d -d "${out%%|*} running for ${out##*|} ($seconds seconds)"
    # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
    $docker_filter && (( ${seconds:-${docker_seconds:-1}} > ${docker_seconds:-2} )) && return $DOCKER_TOO_OLD
    echo "${out%%|*}"
    return 0
  fi

  return 1
}

# Copy files from a container and search them for a string
docker_copy() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local container="" image="" image_search="" srcfiles="" catfiles="" out="" ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d "Returning DOCKER_TOO_OLD";return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  if (( $# == 1 )); then
    if [[ "${1:-}" == *!!*!!* ]]; then
      image_search=${1%%!!*}
      catfiles=${1##*!!}
      srcfiles=${1#"$image_search"!!}
      srcfiles=${srcfiles%!!"$catfiles"}
    fi
  else
    image_search=${1:-}
    srcfiles=${2:-}
    catfiles=${3:-}
  fi

  log -d "image_search = '$image_search'"
  log -d "srcfiles = '$srcfiles'"
  log -d "catfiles = '$catfiles'"

  container=$(docker_container_search "$image_search")
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  (( $? == DOCKER_TOO_OLD )) && return $DOCKER_TOO_OLD
  log -d -d "container = '$container'"
  [[ -z "$container" ]] && { log -e "Could not determine container for '${1:-}'" ; return 1 ; }

  local tmp="" files=()
  tmp=$(maketemp -d)
  log -d -d "Running: docker cp -q $container:$srcfiles $tmp"
  if ! out=$(docker cp -q "$container":"$srcfiles" "$tmp" 2>&1); then
    log -e "'docker cp $container:$srcfiles $tmp' failed with $?"
    return 1
  fi

  mapfile -t files < <(compgen -G "$tmp/$catfiles")
  log -d -d "Running: cat ${files[*]:-}"
  out=$(cat "${files[@]}")
  log -d -d -d -d "cat output: $out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Run a command in a docker container to get version information
docker_exec() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local container="" image="" image_search="" command=() out="" ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d returning DOCKER_TOO_OLD;return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  if (( $# == 1 )); then
    if [[ "${1:-}" == *!!* ]]; then
      image_search=${1%%!!*}
      read -ra command <<< "${1#*!!}"
    else
      image_search=${1:-}
      read -ra command <<< "$*"
    fi
  else
    image_search=${1:-}
    shift
    command=("$@")
  fi

  log -d -d "Running docker_container_search $image_search"
  container=$(docker_container_search "$image_search")
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  (( $? == DOCKER_TOO_OLD )) && return $DOCKER_TOO_OLD
  log -d -d "container = '$container'"
  [[ -z "$container" ]] && { log -e "Could not determine container for '${1:-}'" ; return 1 ; }

  log -d -d "Executing: docker exec -u nobody $container ${command[*]:-}"
  # shellcheck disable=SC2048,SC2086
  out=$(docker exec -u nobody "$container" "${command[@]}" 2>&1)
  log -d -d "docker exec output = $out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Search name or image fields to get a docker image name
docker_image_search() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local docker_ps="" out="" seconds="" ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d "Returning DOCKER_TOO_OLD";return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  docker_ps=$(docker ps --format='{{.Names}}|{{.Image}}|{{.RunningFor}}')
  log -d -d -d "docker ps output = '$docker_ps'"

  # Search for image by container name
  out=$(awk -F '|' -v s="${1:-}" '$1 == s {print $2"|"$3;exit}' <<< "$docker_ps")
  log -d -d "awk output = '$out'"
  if [[ -n "$out" ]]; then
    seconds=$(calc_seconds "${out##*|}")
    log -d -d "${out%%|*} running for ${out##*|} ($seconds seconds)"
    # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
    $docker_filter && (( ${seconds:-${docker_seconds:-1}} > ${docker_seconds:-2} )) && return $DOCKER_TOO_OLD
    echo "${out%%|*}"
    return 0
  fi

  # Search for image by image string
  out=$(awk -F '|' -v s="${1:-}" '$2 ~ s {print $2"|"$3;exit}' <<< "$docker_ps")
  log -d -d "awk output = '$out'"
  if [[ -n "$out" ]]; then
    seconds=$(calc_seconds "${out##*|}")
    log -d -d "${out%%|*} running for ${out##*|} ($seconds seconds)"
    # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
    $docker_filter && (( ${seconds:-${docker_seconds:-1}} > ${docker_seconds:-2} )) && return $DOCKER_TOO_OLD
    echo "${out%%|*}"
    return 0
  fi
  return 1
}

# Use docker inspect information to get version info
docker_inspect() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local container="" out="" ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d "Returning DOCKER_TOO_OLD";return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  container=$(docker_container_search "${1:-}")
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  (( $? == DOCKER_TOO_OLD )) && return $DOCKER_TOO_OLD
  log -d -d "container = '$container'"
  [[ -z "$container" ]] && { log -e "Could not determine container for '${1:-}'" ; return 1 ; }
  log -d "Running: docker inspect --format='{{index .Config.Labels \"org.opencontainers.image.version\"}}' $container"
  out=$(docker inspect --format='{{index .Config.Labels "org.opencontainers.image.version"}}' "$container" 2> /dev/null)
  log -d -d "org.opencontainers.image.version = '$out'"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }

  out=$(docker inspect --format='{{index .Config.Labels "version"}}' "$container" 2> /dev/null)
  log -d -d "version label = $out"
  [[ -n "$out" ]] && grep -qE "$SEMVER_REGEX" <<< "$out" && { echo "$out" ; return 0 ; }

  out=$(docker_image_search "$container")
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  (( $? == DOCKER_TOO_OLD )) && return $DOCKER_TOO_OLD
  log -d -d "image_search = $out"
  local tag=${out##*:}
  log -d -d "image tag = $tag"
  if [[ -n "$out" && -n "$tag" && "$out" != "$tag" && ! "$out" =~ ^(latest|stable|main|master)$ ]]; then
    echo "$tag"
    return 0
  fi

  log -e "Could not determine version"
  return 1
}

# Look through docker logs for version info
docker_logs() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "You must supply docker name" ; return 1 ; }
  [[ "${1:-}" == "-h" ]] && { log "usage: docker_logs dockername" ; return 0 ; }
  local container="" image="" image_search=${1:-} out="" ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d "Returning DOCKER_TOO_OLD";return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  log -d "image_search = '$image_search'"

  container=$(docker_container_search "$image_search")
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  (( $? == DOCKER_TOO_OLD )) && return $DOCKER_TOO_OLD
  log -d -d "container = '$container'"
  [[ -z "$container" ]] && { log -e "Could not determine container for '${1:-}'" ; return 1 ; }

  out=$(docker logs "$container" 2> /dev/null)
  log -d -d -d "docker logs output: $out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Print a docker environment variable for version info
docker_printenv() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local image="" image_search="" variable="" out="" ret=0

  # Run through sudo exec if necessary
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  out=$(use_sudo_exec "$@") ; ret=$?
  case $ret in 0)echo "$out";return 0;;2|3|4);;"$DOCKER_TOO_OLD")log -d "Returning DOCKER_TOO_OLD";return $DOCKER_TOO_OLD;;*)log -d "use_sudo_exec error $ret";return 1;;esac

  if (( $# == 1 )); then
    if [[ "${1:-}" == *!!* ]]; then
      image_search=${1%%!!*}
      variable=${1##*!!}
    else
      image_search=${1:-}
    fi
  else
    image_search=${1:-}
    variable=${2:-}
  fi
  image=$(docker_image_search "$image_search")
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  (( $? == DOCKER_TOO_OLD )) && return $DOCKER_TOO_OLD
  log -d -d "image_search = '$image_search'"
  log -d -d "variable = '$variable'"
  log -d -d "docker image = '$image'"
  [[ -z "$image" ]] && { log -e "Could not determine docker image for '$image_search'" ; return 1 ; }

  if [[ -n "$variable" ]]; then
    docker image inspect --format \
      '{{ range .Config.Env -}}
       {{ if (eq (index (split . "=") 0) "'"$variable"'") -}}
       {{ index (split . "=") 1 -}}
       {{ end -}}
       {{ end -}}' \
      "$image"
  else
    docker image inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$image"
  fi
}

# Search a docker registry for tags for the latest version of a container
docker_tags() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1

  local useskopeo=true
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  local parts=() site="" org="" repo=""
  IFS=/ read -ra parts <<< "${1:-}"
  case "${#parts[@]}" in
    1) site=docker.io ; repo=${parts[0]} ;;
    2) if [[ "${parts[0]}" == *"."* ]]; then
         site=${parts[0]} ; repo=${parts[1]}
       else
         site=docker.io ; org=${parts[0]} ; repo=${parts[1]}
       fi ;;
    3) site=${parts[0]} ; org=${parts[1]} ; repo=${parts[2]} ;;
    *) log -e "Invalid image name format (${1:-})" && return 1 ;;
  esac

  local username=() token=() authfile="" maxpages=200
  [[ "$site" == "quay.io" ]] && site=docker.io
  case "$site" in
    code.forgejo.org)
      mapfile -t username < <(get_config_value "$rcfile" forgejo username)
      mapfile -t token    < <(get_config_value "$rcfile" forgejo token)
      # uri="https://$site/v1/repos"
      ;;
    codeberg.org)
      mapfile -t username < <(get_config_value "$rcfile" codeberg username)
      mapfile -t token    < <(get_config_value "$rcfile" codeberg token)
      ;;
    docker.gitea.com)
      mapfile -t username < <(get_config_value "$rcfile" gitea username)
      mapfile -t token    < <(get_config_value "$rcfile" gitea token)
      ;;
    docker.io)
      mapfile -t username < <(get_config_value "$rcfile" dockerhub username)
      mapfile -t token    < <(get_config_value "$rcfile" dockerhub token)
      ;;
    ghcr.io|lscr.io)
      site=ghcr.io
      mapfile -t username < <(get_config_value "$rcfile" github username)
      mapfile -t token    < <(get_config_value "$rcfile" github token)
      ;;
    *) log -e "Unknown site for skopeo ($site)" && return 1 ;;
  esac

  local out="" cmdout="" authfile="" hash="" skopeoargs=()
  if ${useskopeo:-false} && command -v skopeo &> /dev/null; then
    if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
      authfile=$(maketemp)
      hash=$(printf "%s:%s" "${username[0]}" "${token[0]}" | base64 | tr -d '\n')
      printf '{\n\t"auths": {\n\t\t"%s": {\n\t\t\t"auth": "%s"\n\t\t}\n\t}\n}\n' "$site" "$hash" > "$authfile"
      skopeoargs=("--authfile=$authfile")
    fi

    log -d -d "Running: skopeo list-tags ${skopeoargs[*]:+ARGS }docker://$site/${org:+$org/}$repo"
    cmdout=$(maketemp)
    if (( DEBUG > 2 )); then
      skopeo list-tags --debug "${skopeoargs[@]}" "docker://$site/${org:+$org/}$repo" > "$cmdout"
    else
      skopeo list-tags --debug "${skopeoargs[@]}" "docker://$site/${org:+$org/}$repo" > "$cmdout" 2> /dev/null
    fi
    log -d -d -d "Skopeo output: $(stat "$cmdout")"
    [[ -s "$cmdout" ]] && out=$(jq -r '.Tags.[]' "$cmdout" 2> /dev/null)
  else
    # Use curl
    local authstring=() curl_args=(-w "%{http_code}" --max-time 30)
    local uri="" uri_path="" hdrfile="" jq_count=0 tag_search=""
    cmdout=$(maketemp)
    case "$site" in
      docker.io)
        if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
          log -d -d "Connecting to hub.docker.com to get token"
          out=$(maketemp)
          curl --no-progress-meter -fo "$out" --max-time 15 -X POST -H "Content-Type: application/json" \
            -d "{\"username\": \"${username[0]}\", \"password\": \"${token[0]}\"}" \
            "https://hub.docker.com/v2/users/login"
          if [[ -s "$out" ]]; then
            out=$(jq -r '.token // ""' "$out" 2>/dev/null)
            [[ -n "$out" ]] && authstring=("-H" "Authorization: JWT $out") && \
              log -d -d "Using downloaded token"
          fi
        fi
        site=hub.docker.com
        uri="https://$site/v2/repositories"
        uri_path="tags/?page_size=100&page=1"
        jq_count='.results | length // 0'
        tag_search='.results[].name?'
        ;;
      ghcr.io)
        if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
          log -d -d "Connecting to ghcr.io to get token"
          out=$(maketemp)
          curl --no-progress-meter -Lo "$out" "https://ghcr.io/token?service=ghcr.io&scope=repository:${org:+$org/}$repo:pull" \
             -u "${username[0]}:${token[0]}"
          if [[ -s "$out" ]]; then
            out=$(jq -r '$j.token // ""' "$out" 2>/dev/null)
            [[ -n "$out" ]] && authstring=("-H" "Authorization: Bearer $out") && \
              log -d -d "Using downloaded token"
          fi
        fi
        hdrfile=$(maketemp)
        uri="https://$site/v2"
        uri_path="tags/list?n=1000"
        curl_args+=(-D "$hdrfile")
        jq_count='.tags | length // 0'
        tag_search='.tags[]?'
        ;;
      *)
        if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
          log -d -d "Downloading auth token from $site"
          out=$(curl --no-progress-meter -i --max-time 10 "https://$site/v2/" 2> /dev/null)
          log -d -d -d "Curl output: $out"
          [[ -n "$out" ]] && out=$(awk -F: 'tolower($1) ~ /www-authenticate/ {sub("^.*"$1":[[:space:]]([Bb]earer )?*","");print}' <<< "$out" | tr -d '\r')
          log -d -d -d "awk output: '$out'"
          local realm="" service="" scope=""
          realm=$(get_bearer_field realm "$out")
          service=$(get_bearer_field service "$out")
          scope=$(get_bearer_field scope "$out")
          log -d -d -d "realm = '$realm'"
          log -d -d -d "service = '$service'"
          log -d -d -d "scope = '$scope'"
          if [[ -n "$realm" && -n "$service" && -n "$scope" ]]; then
            local token_url="$realm?service=$service&scope=$scope:${org:+$org/}$repo:pull"
            out=$(curl --no-progress-meter -f --max-time 15 "$token_url")
            [[ -n "$out" ]] && out=$(jq -rn --argjson j "$out" '$j.token // .access_token // ""' 2> /dev/null)
            log -d -d -d "curl + jq output: $out"
            [[ -n "$out" ]] && authstring=("-H" "Authorization: Bearer $out") && \
              log -d -d "Using token for $site"
          fi
        fi
        hdrfile=$(maketemp)
        uri="https://$site/v2"
        uri_path="tags/list?n=1000"
        curl_args+=(-D "$hdrfile")
        jq_count='.tags | length // 0'
        tag_search='.tags[]?'
        ;;
    esac

    local done=false page=0 code=0 page_url="$uri/${org:+$org/}$repo/$uri_path"
    local results=() arr=() link="" next_path=""
    while [[ -n "$page_url" ]]; do
      (( page++ ))
      log -d -d "Running: curl --no-progress-meter -Lfo $cmdout ${curl_args[*]:-} ${authstring[*]:-} $page_url"
      code=$(curl --no-progress-meter -Lfo "$cmdout" "${curl_args[@]}" "${authstring[@]}" "$page_url") || \
        { log -e "Could not download from $site (page $page)" ; log -d -d -d "Curl output: $(cat "$cmdout")" ; break ; }
      if [[ "$code" == "401" ]]; then
        log -e "Authentication required"
        return 1
      elif [[ "$code" == "404" ]]; then
        log -e "Repo not found: $site/${org:+$org/}$repo"
        return 1
      elif [[ "$code" != 200 ]]; then
        log -e "HTTP error $code on page $page"
        break
      fi

      log -d -d "$site page $page: $(jq "$jq_count" "$cmdout" 2> /dev/null)"
      mapfile -t arr < <(jq -r "$tag_search" "$cmdout" 2> /dev/null)
      results+=("${arr[@]}")

      if [[ -n "$hdrfile" ]]; then
        link=$(grep -i '^link:' "$hdrfile" | tr -d '\r')
        if grep -q 'rel="next"' <<< "$link"; then
          next_path=$(sed -r 's/^.*(<[^>]+>).*$/\1/' <<< "$link" | tr -d '<>' | head -n 1)
          page_url="https://${site}${next_path}"
        else
          page_url=""
        fi
      else
        page_url=$(jq -r '.next // ""' "$cmdout" 2> /dev/null)
      fi
    done
    out=$(printf '%s\n' "${results[@]}")
  fi
  log -d -d -d "Jq output: $out"

  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Search flathub for the newest version of a flatpak
flathub_app() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "${1:-}" == "-h" ]] && { log "usage: ${FUNCNAME[0]} application_id" ; return 0 ; }

  local out=""
  out=$(maketemp)
  curl --no-progress-meter -Lo "$out" "https://flathub.org/api/v2/appstream/${1:-}"
  log -d -d -d "Curl output: $(cat "$out")"
  [[ -s "$out" ]] && jq -r '.releases[0].version' "$out" 2> /dev/null
}

# Check out a git repo and use 'git describe' or 'git tag' to get version info
git_checkout() { # check_function
  log -d -d -d "Running ${FUNCNAME[0]} $*"
  check_prog git "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1

  local mode=describe
  local opt="" OPTARG="" OPTIND=1
  while getopts ":dDt" opt; do
    case "$opt" in
      d) mode=describe ;;
      D) mode=describe-tags ;;
      t) mode=tags ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "${1:-}" == "-h" ]] && { log "usage: ${FUNCNAME[0]} [Options] project/repo" ; return 0 ; }
  local dir="" out=""
  dir=$(maketemp -d)
  log -d -d "Running: git clone -q --tags --mirror '${1:-}' '$dir'"
  git clone -q --tags --mirror "${1:-}" "$dir"
  [[ ! -e "$dir"/HEAD ]] && { log -e "Could not check out ${1:-} " ; return 1 ; }
  case "$mode" in
    describe-tags)
      log -d -d "Executing: git -C '$dir' describe --tags"
      out=$(git -C "$dir" describe --tags)
      log -d -d "git describe --tags output: $out"
      ;;
    describe)
      log -d -d "Executing: git -C '$dir' describe"
      out=$(git -C "$dir" describe)
      log -d -d "git describe output: $out"
      ;;
    tags)
      log -d -d "Executing: git -C '$dir' tag"
      out=$(git -C "$dir" tag)
      log -d -d "git tag output: $out"
      ;;
    *) echo "Unknown mode for ${FUNCNAME[*]:-}" ; return 1 ;;
  esac
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Get version information for an installed pacman package
os_package() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  local pkgtype=flatpak
  local opt="" OPTARG="" OPTIND=1
  while getopts ":aAF" opt; do
    case "$opt" in
      a) pkgtype=pacman  ;;
      A) pkgtype=aur     ;;
      F) pkgtype=flatpak ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local pkg=${1:-} out=""

  case "$pkgtype" in
    aur)
      log -d -d "Using curl/awk via github for $pkg"
      out=$(maketemp)
      curl --no-progress-meter -Lo "$out" "https://raw.githubusercontent.com/archlinux/aur/refs/heads/$pkg/PKGBUILD"
      log -d -d -d "Curl output: $(cat "$out")"
      [[ -s "$out" ]] && out=$(awk -F= '
          /^_major=/ { major = $2 }
          /^_subver=/ { subver = $2 }
          /^pkgver=/ { pkgver = $2 }
          /^pkgrel=/ { pkgrel = $2 }
        END {
          if (major != "" && subver != "")
            out=sprintf("%s.%s-%s\n",major,subver,pkgrel)
          else if (pkgver != "")
            out=sprintf("%s-%s\n",pkgver,pkgrel)
          gsub(/"/,"",out)
          print out
        }' "$out" | sed "s/'//g")
      log -d -d -d "awk output: $out"
      ;;
    flatpak)
      out=$(flatpak list --columns=application,version)
      log -d -d -d "Flatpak list output: $out"
      [[ -n "$out" ]] && out=$(awk -v a="$pkg" '$1==a {print $NF;exit}' <<< "$out")
      log -d -d -d "awk output: $out"
      ;;
    pacman)
      check_prog pacman "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
      out=$(pacman -Q "$pkg" 2> /dev/null)
      log -d -d -d "pacman output: $out"
      out=$(awk '{for (i = 2 ; i <= NF ; i++) o = o " " $i }END{sub(/^ /,"",o);printf "%s\n",o}' <<< "$out")
      log -d -d -d "awk output: $out"
      ;;
    *) log -e "Invalid package type ($pkgtype)" ; return 1 ;;
  esac
  log -d -d -d "awk output: $out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Get version information for an pacman package from the repo
pacman_repo() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local pkg=${1:-} out=""

  check_prog pacman "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  out=$(pacman -Ss "^${pkg//+/\\+}$" 2> /dev/null)
  log -d -d -d "pacman output: $out"
  out=$(awk '{print $2;exit}' <<< "$out")
  log -d -d -d "awk output: $out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

# Search for the latest release of a Codeberg/Forgejo/Gitea/Github/Gitlab repo
scm_project() { # check_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  local mode=release maxpages=20
  local site="https://api.github.com/repos" section=github jqtags='.[].name'
  local release_end=releases/latest tags_end="tags?per_page=100&page" jqstring='.tag_name'
  local opt="" OPTARG="" OPTIND=1
  while getopts ":cfgltRT" opt; do
    case "$opt" in
      g) ;; # github defaults
      R) ;; # release
      c) section=codeberg
         site="https://codeberg.org/api/v1/repos"
         release_end=releases/latest
         tags_end="tags?limit=50&page"
         jqstring='.tag_name'
         jqtags='.[].name'
         ;;
      f) section=forgejo
         site="https://code.forgejo.org/api/v1/repos"
         release_end=releases/latest
         tags_end="tags?limit=50&page"
         jqstring='.tag_name'
         jqtags='.[].name'
         ;;
      l) section=gitlab
         site="https://gitlab.com/api/v4/projects"
         release_end=releases/permalink/latest
         tags_end="repository/tags?order_by_version&sort=desc&per_page"
         jqstring='.tag_name'
         jqtags='.[].name'
         maxpages=1
         ;;
      t) section=gitea
         site="https://gitea.com/api/v1/repos"
         release_end=releases/latest
         tags_end="tags?limit=50&page"
         jqstring='.tag_name'
         jqtags='.[].name'
         ;;
      T) mode=tags ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "${1:-}" == "-h" ]] && { log "usage: ${FUNCNAME[0]} project/repo" ; return 0 ; }

  local repo=${1:-} output=() out="" err="" errmsg=""
  # Encode repo for Gitlab
  if [[ "$section" == "gitlab" ]]; then
    check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
    repo=$(jq -Rr @uri < <(printf '%s' "$repo"))
  fi
  local authstring=() uri=""
  mapfile -t authstring < <(gen_authstring "$section")

  err=$(maketemp)
  out=$(maketemp)
  if [[ "$mode" == "release" ]]; then
    uri="$site/$repo/$release_end"
    log -d -d  "Looking up latest release for ${1:-} using $section API: $uri"
    curl "${authstring[@]}" --no-progress-meter -Lo "$out" "$uri" 2> "$err"
    log -d -d -d "curl output: $(cat "$out")"
    out=$(jq -r "$jqstring" "$out" 2> /dev/null)
    log -d -d "jq output: $out"
    output=("$out")
  else
    jqstring=$jqtags
    local page=0 done=false tmp=""
    uri="$site/$repo/$tags_end"
    log -d -d "Looking up tags for $repo using $section API: $uri=1"
    while ! $done && (( page < maxpages )); do
      page=$(( page + 1 ))
      curl "${authstring[@]}" --no-progress-meter -Lo "$out" "$uri=$page" 2> "$err"
      log -d -d -d "curl output: $(cat "$out")"
      if [[ ! -s "$out" || "$(jq 'length' 2> /dev/null "$out")" -eq 0 ]]; then
        done=true
        break
      fi
      tmp=$(jq -r "$jqtags" "$out" 2> /dev/null)
      log -d -d -d "Jq output: $tmp"
      output+=("$tmp")
    done
  fi
  errmsg=$(cat "$err")
  [[ -n "$errmsg" ]] && log -e "${1:-}: $errmsg"
  (( ${#output[@]} > 0 )) && { printf '%s\n' "${output[@]}" ; return 0 ; }
  log -e "Could not find $section $mode data for $repo"
  return 1
}

# Determine if function should be run with sudo_exec and do it if so
# Return Codes:
#   0: success -- process output
#   1: error -- sudo_regex matched but sudo_exec returned an error
#   2: non-error -- do not process output
#   3: non-error -- running as root
#   4: non-error -- no sudo_regex matches and the check was not configured with use_sudo
#   DOCKER_TOO_OLD: non-error -- docker container should not be checked right now
#   *: error -- do not process output
use_sudo_exec() { # utility_function
  (( $(id -u) == 0 )) && { log -d "running as root" ; return 3 ; }
  $SUDO_EXEC && { log -d "Already running sudo_exec" ; return 2 ; }
  log -d -d -d "Running: ${FUNCNAME[0]} for ${FUNCNAME[1]}"

  local check=${1:-} check_name=${1:-}
  check_name=$(strip_modifiers "$check_name")
  local rcvalue=() regex="" rp="" out="" use_sudo=false ret=0

  # Loop through sudo_regexes to see if $check matches a regex to use sudo
  [[ -n "${sudo_regexes:-}" ]] && for regex in "${sudo_regexes[@]}"; do
    [[ "${FUNCNAME[1]}" =~ $regex ]] && use_sudo=true
  done

  # Read config file to see if there are specific settings for $sw
  if [[ -s "$rcfile" ]]; then
    log -d -d -d "Reading $rcfile for $PROGNAME::$check_name use_sudo setting"
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$check_name" use_sudo)
    log -d -d -d "Config use_sudo == ${rcvalue[*]:-}"
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && use_sudo=${rcvalue[0]}
    log -d -d -d "Reading $rcfile for $PROGNAME::$check_name user_user setting"
    rcvalue=() ; $use_sudo && ! $sudo_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$check_name" sudo_user)
    log -d -d -d "Config sudo_user == ${rcvalue[*]:-}"
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && sudo_user=${rcvalue[0]}
  fi

  # Do not run as sudo_user if $sudo_user is not defined
  [[ -z "${sudo_user:-}" ]] && { log -d "sudo_user not defined" ; return 2 ; }

  if $use_sudo && [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    local func=${FUNCNAME[1]} rp=""
    local args=("$check")
    # If calling from main, run with first argument, otherwise run with calling function
    [[ "${FUNCNAME[1]}" == "main" ]] && { func=$check ; args=() ; }
    args+=(SUDO_EXEC_DEBUG="$DEBUG" DOCKER_FILTER="$docker_filter" DOCKER_SECONDS="$docker_seconds")
    [[ "$check" == "printer_ink_check" ]] && args+=(PRINTER="$PRINTER")
    log -v -v "Using sudo as $sudo_user to $func"
    rp=$(realpath "$0")
    log -d "[sudo] running 'sudo -n -u $sudo_user $rp -X $func ${args[*]:-}'"
    out=$(sudo -n -u "$sudo_user" "$rp" -X "$func" "${args[@]}")
    ret=$?
    # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
    (( ret == DOCKER_TOO_OLD )) && { log -d "Returning DOCKER_TOO_OLD" ; return $DOCKER_TOO_OLD ; }
    (( ret != 0 )) && { log -d "sudo exit error code $ret" ; return 1 ; }
    log -d "sudo_exec $func returned out = '$out'"
    [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
    return 1
  fi
  return 4
}

# Get ink information from an inkjet printer
printer_ink_check() { # app_check_function
  [[ -z "$PRINTER" ]] && { log -e "Printer not defined" ; usage 1 ; }
  local errjson="" inkfile="" inkdata=""

  # Define an error string
  errjson=$(jq -n --arg n "${FUNCNAME[0]}" --arg ip "$PRINTER" \
      --arg t "$(date +%s)" --arg e "ink command not found for ${FUNCNAME[0]}" '{
        "name": $n,
        "version": "---",
        "printer": $ip,
        "ip": $ip,
        "cyan": "null",
        "magenta": "null",
        "yellow": "null",
        "black": "null",
        "photoblack": "null",
        "error": $e,
        "time": ($t|tonumber)
      }' 2> /dev/null || log -e "Could not generate ink command error json")
  check_prog ink || { echo "$errjson" ; return 1 ; }

  errjson=$(jq -n --arg n "${FUNCNAME[0]}" --arg ip "$PRINTER" \
      --arg t "$(date +%s)" --arg e "ping command not found for ${FUNCNAME[0]}" '{
        "name": $n,
        "version": "---",
        "printer": $ip,
        "ip": $ip,
        "cyan": "null",
        "magenta": "null",
        "yellow": "null",
        "black": "null",
        "photoblack": "null",
        "error": $e,
        "time": ($t|tonumber)
      }' 2> /dev/null || log -e "Could not generate ink command error json")
  check_prog ping || { echo "$errjson" ; return 1 ; }

  # Define an error string
  errjson=$(jq -n --arg n "${FUNCNAME[0]}" --arg ip "$PRINTER" \
      --arg t "$(date +%s)" --arg e "ink command could not connect to $PRINTER" '{
        "name": $n,
        "version": "---",
        "printer": $ip,
        "ip": $ip,
        "cyan": "null",
        "magenta": "null",
        "yellow": "null",
        "black": "null",
        "photoblack": "null",
        "error": $e,
        "time": ($t|tonumber)
      }' 2> /dev/null || log -e "Could not generate ink command error json")

  log -d -d "Running: ping -c 5 $PRINTER"
  if ! ping -c 5 "$PRINTER" &> /dev/null; then
    jq -n --arg n "${FUNCNAME[0]}" --arg ip "$PRINTER" \
      --arg t "$(date +%s)" --arg e "Cannot connect to $PRINTER" '{
        "name": $n,
        "version": "---",
        "printer": $ip,
        "ip": $ip,
        "cyan": "null",
        "magenta": "null",
        "yellow": "null",
        "black": "null",
        "photoblack": "null",
        "error": $e,
        "time": ($t|tonumber)
      }' 2> /dev/null || log -e "Could not generate printer connection error json"
    return 1
  fi

  inkfile=$(maketemp)
  log -d -d "Running: ink -b bjnp://$PRINTER"
  if ! ink -b bjnp://"$PRINTER" > "$inkfile" 2>&1; then
    printf '%s' "$errjson"
    return 1
  fi

  log -d -d "Parsing ink command output"
  inkdata=$( awk -v n="${FUNCNAME[0]}" -v ip="$PRINTER" -v t="$(date +%s)" '
    /^ink [^ ]+ \(c\) [0-9]{4}/ {
      next
    }
    /^[^:]+:[[:space:]]+[0-9]+%$/ {
      sub(/:$/,"",$1)
      sub(/%$/,"",$2)
      colors[tolower($1)]=$2
      next
    }
    NR > 1 && $0 {
      printf "  \"name\": \"%s\",\n",n
      printf "  \"version\": \"---\",\n"
      printf "  \"printer\": \"%s\",\n",$0
      printf "  \"ip\": \"%s\",\n",ip
    }
    BEGIN {
      print "{"
    }
    END {
      split("cyan magenta yellow black photoblack", color, " ")
      for (c in color)
        printf "  \"%s\": %s,\n",color[c], colors[color[c]]
      printf "  \"time\": %s\n", t
      printf "}\n"
    }' "$inkfile" )

  [[ -z "$inkdata" ]] && printf '%s' "$errjson" && return 1
  jq -rn --argjson j "$inkdata" '$j' 2> /dev/null
}

# Run version checks
execute_check() { # utility_function
  # log -d -d -d "Running: ${FUNCNAME[0]} $*"
  log -d "Running: ${FUNCNAME[0]} $*"

  local remove=() search=() presed=() postsed=() skipverfilter=false
  local project="" tmp="" prejqfilter="" postjqfilter="" xmlfilter="" sedstring="" tag=""
  local opt="" OPTARG="" OPTIND=1
  while getopts ":p:t:J:j:x:r:s:P:S:vV" opt; do
    case "$opt" in
      p) project=$OPTARG ;;
      t) tag=$OPTARG ;;
      J) prejqfilter=$OPTARG ;;    # Uses last one given
      j) postjqfilter=$OPTARG ;;   # Uses last one given
      x) xmlfilter=$OPTARG ;;      # Uses last one given
      r) remove+=("$OPTARG") ;;
      s) search+=("$OPTARG") ;;
      P) presed+=("$OPTARG") ;;
      S) postsed+=("$OPTARG") ;;
      v) skipverfilter=true ;;
      V) skipverfilter=false ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local check=${1:-}

  log -d -d "check = '$check'"
  log -d -d "tag = '$tag'"
  log -d -d "project = '$project'"
  log -d -d "xmlfilter = '$xmlfilter'"
  log -d -d "prejq = '$prejqfilter'"
  log -d -d "presed = '${presed[*]:-}'"
  log -d -d "search = '${search[*]:-}'"
  log -d -d "remove = '${remove[*]:-}'"
  log -d -d "postjq = '$postjqfilter'"
  log -d -d "postsed = '${postsed[*]:-}'"
  log -d -d "skip = '$skipverfilter'"

  local ret=0
  tag=${tag%_latest}
  [[ "$tag" =~ (aur|docker_inspect|docker_inspect_image|pacman) ]] && skipverfilter=true

  case "$tag" in
    # alpine_docker)     out=$(alpine_docker_package "$project") ; ret=$? ;;
    alpine_repo)       out=$(alpine_repo_package "$project") ; ret=$? ;;
    appimage)          out=$(appimage_check "$project") ; ret=$? ;;
    aur)               out=$(os_package -A "$project") ; ret=$? ;;
    cat)               check_prog envsubst && out=$(cat "$(envsubst <<< "$project")" 2> /dev/null) ; ret=$? ;;
    codeberg)          out=$(scm_project -c "$project") ; ret=$? ;;
    codeberg_tags)     out=$(scm_project -T -c "$project") ; ret=$? ;;
    command)           out=$(command_check "$project") ; ret=$? ;;
    curl)              out=$(curl --no-progress-meter -L "$project") ; ret=$? ;;
    curlapi)           out=$(curl_api "$project") ; ret=$? ;;
    docker_copy)       out=$(docker_copy "$project") ; ret=$? ;;
    docker_exec)       out=$(docker_exec "$project") ; ret=$? ;;
    docker_inspect)    out=$(docker_inspect "$project") ; ret=$? ;;
    docker_logs)       out=$(docker_logs "$project") ; ret=$? ;;
    docker_printenv)   out=$(docker_printenv "$project") ; ret=$? ;;
    docker_tags)       out=$(docker_tags "$project") ; ret=$? ;;
    flatpak)           out=$(os_package -F "$project") ; ret=$? ;;
    flathub)           out=$(flathub_app "$project") ; ret=$? ;;
    forgejo)           out=$(scm_project -f "$project") ; ret=$? ;;
    forgejo_tags)      out=$(scm_project -T -f "$project") ; ret=$? ;;
    gitdescribe)       out=$(git_checkout -d "$project") ; ret=$? ;;
    gittags)           out=$(git_checkout -t "$project") ; ret=$? ;;
    gitea)             out=$(scm_project -t "$project") ; ret=$? ;;
    gitea_tags)        out=$(scm_project -T -t "$project") ; ret=$? ;;
    github)            out=$(scm_project -g "$project") ; ret=$? ;;
    github_tags)       out=$(scm_project -T -g "$project") ; ret=$? ;;
    gitlab)            out=$(scm_project -l "$project") ; ret=$? ;;
    gitlab_tags)       out=$(scm_project -T -l "$project") ; ret=$? ;;
    pacman)            out=$(os_package -a "$project") ; ret=$? ;;
    pacman_repo)       out=$(pacman_repo "$project") ; ret=$? ;;
    printer_ink_check) printer_ink_check ; return ;;
    "$PROGNAME")       out=$("$PROGNAME") ; ret=$? ;;
    *)
      log -e "Unknown package check: $tag"
      return 1 ;;
  esac
  # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
  [[ "$tag" == docker* && "$ret" -eq $DOCKER_TOO_OLD ]] && return $DOCKER_TOO_OLD

  # Apply xml filter, if set
  if [[ -n "$out" && -n "$xmlfilter" ]]; then
    check_prog xmllint || return 1
    log -d -d -d "Using xmllint --html --xpath '$xmlfilter' - 2> /dev/null"
    out=$(xmllint --html --xpath "$xmlfilter" - 2> /dev/null <<< "$out")
    log -d -d -d "xmllint output: $out"
  fi

  # Apply pre-jq filter, if set
  if [[ -n "$out" && -n "$prejqfilter" ]]; then
    check_prog jq || return 1
    log -d -d -d "Using jq -rn --argjson j '\$out' '\$j | $prejqfilter'"
    out=$(jq -rn --argjson j "$out" "\$j | $prejqfilter")
    log -d -d -d "jq output: $out"
  fi

  # Apply presed, if set
  [[ -n "$out" && -n "${presed:-}" ]] && for sedstring in "${presed[@]}"; do
    log -d "Applying presed: sed -r '$sedstring'"
    out=$(sed -r "$sedstring" <<< "$out")
    log -d -d "sed output: $out"
  done

  # Apply search grep filter
  if [[ -n "${search:-}" && "${#search[@]}" -gt 0 ]]; then
    log -d "Searching for '$(IFS='|'; echo "${search[*]:-}")'"
    out=$(grep -E -- "($(IFS='|'; echo "${search[*]:-}"))" <<< "$out")
    log -d -d -d "search grep output: $out"
  fi

  # Apply remove grep filter
  if [[ "${remove:-}" && "${#remove[@]}" -gt 0 ]]; then
    log -d "Searching for '$(IFS='|'; echo "${remove[*]:-}")'"
    out=$(echo "$out" | grep -Ev -- "($(IFS='|'; echo "${remove[*]:-}"))")
    log -d -d -d "remove grep output: $out"
  fi

  # Apply post-jq filter, if set
  if [[ -n "$out" && -n "$postjqfilter" ]]; then
    check_prog jq || return 1
    log -d -d -d "Using jq -rn --argjson j '\$out' '\$j | $postjqfilter'"
    out=$(jq -rn --argjson j "$out" "\$j | $postjqfilter")
    log -d -d -d "jq output: $out"
  fi

  # Trim trailing linefeeds
  [[ -n "$out" ]] && out=$(echo "$out" | tr -d '\r')

  # Sort output
  [[ -n "$out" ]] && out=$(sort -V <<< "$out")

  # Grab the last line of output
  [[ -n "$out" ]] && out=$(tail -n1 <<< "$out")
  log -d -d "tail -n1 output = '$out'"

  # Apply postsed, if set
  [[ -n "$out" && -n "${postsed:-}" ]] && for sedstring in "${postsed[@]}"; do
    log -d "Applying postsed: sed -r '$sedstring'"
    out=$(sed -r "$sedstring" <<< "$out")
    log -d -d "sed output: $out"
  done

  # Apply versionfilter if $skipverfilter is false
  # shellcheck disable=SC2119
  local vout=""
  if [[ -n "$out" ]] && ! $skipverfilter; then
    log -d -d -d "Executing: perl -ne 'print \"\$&\n\" if /$SEMVER_REGEX/'"
    vout=$(perl -ne 'print "$&\n" if /'"$SEMVER_REGEX"'/' <<< "$out")
    log -d -d -d "perl output: $vout"
    grep -Eq "^$SEMVER_REGEX$" <<< "$vout" && out=$(head -n1 <<< "$vout")
  fi

  # If there is still output, print it
  [[ -n "$out" ]] && echo "$out" && return 0

  # Default to printing an error message and returning 1
  log -e "Could not determine version for $check"
  return 1
}

# Print main program usage info
usage() {
  echo "usage: $PROGNAME [Options] SOFTWARE"
  echo "Options:"
  echo "  -h|--help     : print help text"
  echo "  --version     : print version number and exit"
  echo "  -d          + : print debug info (use $DEBUG_EXIT times to print and exit)"
  echo "  -v          + : be verbose"
  echo "  -q          + : be quiet"
  echo
  echo "Program-related options:"
  # Second line indent
  local ss=18
  usage_fold -s "$ss" -- "-c RCFILE     : path to RCFILE file (default: $rcfile)"
  usage_fold -s "$ss" -- "-u USER     x : drop privileges to USER if run as root (default: none)"
  usage_fold -s "$ss" -- "-p PRINTOPT   : print information (${bu}help${ubu} for option list)"
  usage_fold -s "$ss" -- "-1            : print information in a single column with '-p PRINTOPT'"
  usage_fold -s "$ss" -- "-w WAIT     x : latest checks results are cached for WAIT minutes (default: $cache_lifetime minutes)"
  usage_fold -s "$ss" -- "-r RETRY    x : delay between check retries for RETRY seconds (default: $retry_delay seconds)"
  usage_fold -s "$ss" -- "-P PRINTER  x : ip address for printer (for SOFTWARE == ink)"
  usage_fold -s "$ss" -- "-R REGEX   +x : a regex for commands that need sudo"
  usage_fold -s "$ss" -- "-S SECONDS  x : number of SECONDS for docker container updates (default: $docker_seconds seconds)"
  usage_fold -s "$ss" -- "-X FUNC       : Run check with sudo"
  usage_fold -s "$ss" -- "-x SUDOUSER x : User to run sudo command as for -X (default: none)"
  echo
  # Check related options
  usage_fold -s "$ss" -- "-L LIST       : use LIST for each SOFTWARE argument as if LIST:SOFTWARE give as arguments"
  usage_fold -s "$ss" -- "-D            : print versions for docker containers that started in last (-S) SECONDS seconds"
  usage_fold -s "$ss" -- "-V MINVER   x : when getting a version, use the minor version MINVER (e.g ${bu}1.2${ubu} to find ${bu}1.2.4${ubu})"
  usage_fold -s "$ss" -- "-f SOFTWARE + : force updating latest SOFTWARE (default: update if cache expired)"
  usage_fold -s "$ss" -- "-F            : force updating all latest software (default: update if cache expired)"
  echo
  echo " Output related options:"
  usage_fold -s "$ss" -- "-o FILE     x : save JSON output to FILE instead"
  usage_fold -s "$ss" -- "-j          x : print output in JSON format to screen"
  usage_fold -s "$ss" -- "-t          x : print output in text format to screen"
  usage_fold -s "$ss" -- "-m          x : publish output to mqtt server"
  usage_fold -s "$ss" -- "-i          x : include invalid version results ('---') when updating (default: skip)"
  usage_fold -s "$ss" -- "-T            : Test Mode: print what would happen in a run"

  echo
  echo "MQTT-related Options:"
  usage_fold -s "$ss" -- "-M            : mqtt test mode: do not publish to mqtt; print instead"
  usage_fold -s "$ss" -- "-H HOST_NAME  : when prepending key names, use host_name (default: ${bu}${host_name}_${ubu})"
  usage_fold -s "$ss" -- "-I INK_TOPIC  : use INK_TOPIC when publishing printer_ink_check to MQTT (default: $ink_topic)"
  usage_fold -s "$ss" -- "-n          x : prepend mqtt key name with ${bu}${host_name}_${ubu} (default with ${bu}all${ubu})"
  usage_fold -s "$ss" -- "-N          x : do not prepend mqtt key name with ${bu}${host_name}_${ubu} (default with ${bu}latest${ubu})"
  echo "+ : option can be used more than once"
  echo "x : overrides config settings"
  echo
  echo "Notes:"
  usage_fold -f 1 --  "- By default, when using an output file, $PROGNAME detects if it is a json file (-j|-J overrides)"
  usage_fold -f 1 --  "- SOFTWARE options: all docker latest ink applist (${bu}$PROGNAME -p functions${ubu} applist)"
  usage_fold -f 1 --  "- SOFTWARE can be LIST:SOFTWARE: update LIST output with SOFTWARE (default: output full LIST)"
  usage_fold -f 1 --  "- If SOFTWARE matches key in [$PROGNAME] in RCFILE, the given list will be checked (i.e. custom software list)"
  usage_fold -f 1 --  "- ${bu}all${ubu} is a special list that prepends checks with ${bu}HOST_NAME${ubu} (mqtt) and adds $PROGNAME to checks"
  usage_fold -f 1 --  "- ${bu}docker${ubu} is a special list that is all checks for docker containers that have checks defined"
  exit "${1:-0}"
} # usage()

# Main program code
main() {
  # Set up ansi escape codes
  local e=$'\e'
  local b="${e}[1m"
  local ub="${e}[22m"
  local u="${e}[4m"
  local uu="${e}[24m"
  local bu="${b}${u}"
  local ubu="${uu}${ub}"

  # Set default delay and wait values
  local args_orig=("$@")

  # Set some variables
  local rcfile=$HOME/.config/"${PROGNAME}"rc
  [[ ! -r $rcfile && -r "$PROGDATA"/"${PROGNAME}"rc ]] && rcfile="$PROGDATA"/"${PROGNAME}"rc
  local list_reserved_words=(docker user cache_dir cache_lifetime retry_delay max_retries docker_seconds sudo_regex sudo_user printer)

  local host_name=""
  if command -v hostname > /dev/null 2>&1; then
    host_name=$(hostname)
  else
    host_name=$(hostnamectl hostname)
  fi
  host_name=${host_name%%.*}
  host_name=$(echo "$host_name" | tr '[:upper:]' '[:lower:]')
  local cache_dir="$HOME"/.cache/"$PROGNAME"

  # App Lists
  local all_checks=() app_checks=() docker_checks=() latest_checks=() non_auto_latest_checks=()
  local function_list=() check_list=() utility_list=() tmpstring=""
  mapfile -t app_checks < <(awk '
    /^[^#].+[(]) {[[:space:]]+#[[:space:]]*app_check_function/ {
      gsub(/\(\)/,"",$1)
      print $1
    }' "${SOURCED_LIBS[@]}")
  app_checks+=("$PROGNAME")
  all_checks+=("${app_checks[@]}")
  mapfile -t function_list < <(awk '
    /^[^#].+[(]) {[[:space:]]+#[[:space:]]*check_function/ {
      gsub(/\(\)/,"",$1)
      print $1
    }' "${SOURCED_LIBS[@]}")
  tmpstring=${CHECK_LIST%)(_latest)?}
  IFS='|' read -ra check_list <<< "${tmpstring#(}"
  mapfile -t utility_list < <(awk '
    /^[^#].+[(]) {[[:space:]]+#[[:space:]]*utility_function/ {
      gsub(/\(\)/,"",$1)
      print $1
    }' "${SOURCED_LIBS[@]}")

  # Make sure mqtt commands are found
  check_prog curl || exit 1
  check_prog awk || exit 1
  check_prog sed || exit 1
  check_prog grep || exit 1
  check_prog printf || exit 1

  local i=0 n=0
  for i in "$@"; do [[ "$i" == "--help" ]] && usage verbose; done
  for i in "$@"; do [[ "$i" == "--version" ]] && echo "Version $PROGVER" && exit ; done
  local appimage_path=$HOME/Applications
  local cache_lifetime=60    # Number of minutes to wait between _latest checks
  local cache_lifetime_set=false
  local docker_filter=false
  local docker_seconds=30
  local docker_seconds_set=false
  local docker_user=nobody
  local docker_user_set=false
  local force_all=false
  local force_list=()
  local host_name_set=false
  local include_invalid=false
  local include_invalid_set=false
  local ink_topic=ink2mqtt
  local ink_topic_set=false
  local max_retries=1        # Number of times to try getting version
  local mqtt_test=false
  local output_file=/dev/stdout
  local output_file_set=false
  local output_mode=text
  local output_mode_set=false
  local prepend_name=false
  local prepend_name_set=false
  local printer_set=false
  local print_single='-m'
  local printonly=false
  local rcfile_set=false
  local retry_delay=1        # Number of seconds to wait between retries
  local retry_delay_set=false
  local sudo_regexes=()
  local sudo_regex_set=false
  local sudo_user_set=false
  local update=false
  local sudo_user="" exec_user="" PRINTER="" minver="" print_opt="" update_list=""
  local opt="" OPTARG="" OPTIND=1
  while getopts ":hdvqc:u:p:1w:r:P:R:S:X:x:L:DV:f:Fo:OtjmiTMH:INn" opt; do
    case $opt in
      # Base options
      :) case $OPTARG in
           *) log -e "-$OPTARG requires an argument" ; usage 1 ;;
         esac ;;
      d) DEBUG=$(( DEBUG + 1 )) ; QUIET=0 ;;
      v) VERBOSE=$(( VERBOSE + 1 )) ; QUIET=0 ;;
      q) QUIET=$(( QUIET + 1 )) ; VERBOSE=0 ;;

      # Program-related options: -c and -u are silently dropped by drop_privs
      c) rcfile=$OPTARG ; rcfile_set=true ;;
      u) [[ $(id -u) != 0 ]] && log -e "-u only works for root" && exit 1
         if id "$OPTARG" &> /dev/null; then
           exec_user=$OPTARG
         else
           log -e "Invalid user for -u ($OPTARG)"
           exit 1
         fi ;;
      p) print_opt=$(echo "$OPTARG" | tr '[:upper:]' '[:lower:]') ;;
      1) print_single='-1' ;;
      w) if [[ $OPTARG =~ ^[0-9]+$ ]]; then
           cache_lifetime=$OPTARG
           cache_lifetime_set=true
         fi ;;
      r) if [[ $OPTARG =~ ^([0-9]+|\.[0-9]+|[0-9]+\.[0-9]+)$ ]]; then
           retry_delay=$OPTARG
           docker_seconds=$OPTARG
           retry_delay_set=true
         fi ;;
      P) PRINTER=$OPTARG ; printer_set=true ;;
      R) sudo_regexes+=("$OPTARG") ; sudo_regex_set=true ;;
      S) if [[ $OPTARG =~ ^([0-9]+|\.[0-9]+|[0-9]+\.[0-9]+)$ ]]; then
           docker_seconds=$OPTARG
           docker_seconds_set=true
           update=true
         else
           log -e "Invalid value for SECONDS ($OPTARG)" && usage 1
         fi ;;
      X) shift ; sudo_exec "$@" ; exit $? ;;
      x) sudo_user=$OPTARG ; sudo_user_set=true ;;

      # Check related options
      L) update_list=$OPTARG ; update=true ;;
      D) docker_filter=true ;;
      V) if [[ $OPTARG =~ ^[0-9]+\.?[0-9]+$ ]]; then
           minver=$OPTARG
         fi ;;
      f) force_list+=("$OPTARG") ;;
      F) force_all=true ;;

      # Output Options
      o) output_file=$OPTARG     ; output_file_set=true ; output_mode=json ; output_mode_set=true ;;
      j) output_file=/dev/stdout ; output_file_set=true ; output_mode=json ; output_mode_set=true ;;
      t) output_file=/dev/stdout ; output_file_set=true ; output_mode=text ; output_mode_set=true ;;
      m) output_file=/dev/stdout ; output_file_set=true ; output_mode=mqtt ; output_mode_set=true ;;
      i) include_invalid=true ; include_invalid_set=true ;;
      T) printonly=true ;;

      # MQTT Options
      M) mqtt_test=true ;;
      H) host_name=$OPTARG ; host_name_set=true ;;
      I) ink_topic=$OPTARG ; ink_topic_set=true ;;
      n) prepend_name=true  ; prepend_name_set=true ;;
      N) prepend_name=false ; prepend_name_set=true ;;

      # Catch everything else
      *) usage ;;
    esac
  done # while getopts OPTS_LIST opt; do
  shift $(( OPTIND - 1 ))

  # If -c passed and rcfile cannot be read, die
  if $rcfile_set && [[ ! -r "$rcfile" ]]; then
    log -e "Cannot read rcfile"
    exit 1
  fi

  if [[ -n "$rcfile" && -s "$rcfile" ]]; then
    log -d "Using $rcfile for configfile"
  fi
  if [[ ! -s "$rcfile" ]]; then
    log -d -d "Not using a config file (rcfile = '$rcfile)'"
  fi

  local checks=() section_list=() section="" item=""
  local all_output=""

  # Parse entire config in one awk pass
  all_output=$(awk -v progname="$PROGNAME" '
    /^[[:space:]]*\[/ {
      current = $0
      gsub(/^[[:space:]]*\[|[[:space:]]*\].*$/, "", current)
      # Check if this is a vcheck:: section
      if (index(current, progname "::") == 1) {
        in_section = 1
        section = substr(current, length(progname) + 3)
        # Print section marker so we know what sections exist
        print "section|" section
      } else {
        in_section = 0
        section = ""
      }
      next
    }
    in_section {
      ltrimmed = $0
      sub(/^[[:space:]]+/, "", ltrimmed)
      if (index(ltrimmed, "check") == 1) {
        rest = substr(ltrimmed, 6)   # length("check") + 1
        if (rest ~ /^[[:space:]]*[:=]/) {
          sub(/^[^:=]+[:=][[:space:]]*/, "", ltrimmed)
          sub(/[[:space:]]+$/, "", ltrimmed)
          print section "|check|" ltrimmed
        }
      } else if (index(ltrimmed, "list") == 1) {
        rest = substr(ltrimmed, 5)   # length("list") + 1
        if (rest ~ /^[[:space:]]*[:=]/) {
          sub(/^[^:=]+[:=][[:space:]]*/, "", ltrimmed)
          sub(/[[:space:]]+$/, "", ltrimmed)
          print section "|list|" ltrimmed
        }
      }
    }
  ' "$rcfile")

  local cur_section="" cur_type="" cur_val=""
  while IFS='|' read -r cur_section cur_type cur_val; do
    case "$cur_section" in
      section) section_list+=("$cur_type") ; checks=() ;;
      *) section=$cur_section
         case "$cur_type" in
           check)
             (( ${#checks[@]} > 0 )) && log -w "Multiple checks set in $section, using last one"
             checks=("$cur_val")
             if (( ${#checks[@]} > 0 )); then
               all_checks+=("$section")
               if [[ $section == *_latest ]]; then
                 non_auto_latest_checks+=("$section")
               else
                 app_checks+=("$section")
               fi
             fi
             for item in "${checks[@]}"; do
               if [[ "$item" == *!!* && "${item##*!!}" == docker_* && "$section" != *_latest ]]; then
                 docker_checks+=("$section")
               fi
             done
             ;;
           list)
             item=$(strip_modifiers "$cur_val")
             if [[ $section == "latest" ]]; then
               all_checks+=("$item")
               latest_checks+=("$item")
             fi
             if [[ "$item" == *!!* ]]; then
               all_checks+=("$item")
               app_checks+=("$item")
             fi
             if [[ "$item" == *!!* && "${item##*!!}" == docker_* && "$section" != *_latest ]]; then
               all_checks+=("$item")
               docker_checks+=("$item")
             fi
             ;;
          *) ;;
         esac
         ;;
    esac
  done <<< "$all_output"
  all_output=""

  # Validate output_mode
  case "$output_mode" in json);;mqtt)output_file=/dev/stdout;; *)output_mode=text;output_file=/dev/stdout;; esac

  # Read configuration settings
  local rcvalue=()
  if [[ -z "${exec_user:-}" && -s "$rcfile" ]]; then
    mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" user)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && exec_user=${rcvalue[0]}
  fi

  # Drop privileges if running as root and $exec_user is defined
  [[ $(id -u) == 0 && -n "$exec_user" ]] && drop_privs "$exec_user" "${args_orig[@]}"

  # Read configuration file options
  if [[ -s "$rcfile" ]]; then
    rcvalue=(); mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" cache_dir)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && cache_dir=${rcvalue[0]}

    rcvalue=() ; ! $cache_lifetime_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" cache_lifetime)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 && ${rcvalue[0]} =~ ^[0-9]+$ ]] && cache_lifetime=${rcvalue[0]}

    rcvalue=() ; ! $retry_delay_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" retry_delay)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 && ${rcvalue[0]} =~ ^([0-9]+|\.[0-9]+|[0-9]+\.[0-9]+)$ ]] && retry_delay=${rcvalue[0]}

    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" max_retries)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 && ${rcvalue[0]} =~ ^[0-9]+$ ]] && max_retries=${rcvalue[0]}

    rcvalue=() ; ! $docker_seconds_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" docker_seconds)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 && ${rcvalue[0]} =~ ^[0-9]+$ ]] && docker_seconds=${rcvalue[0]}

    rcvalue=() ; ! $docker_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" docker_user)
    if [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]]; then
      if id "${rcvalue[0]}" &> /dev/null; then
        docker_user=${rcvalue[0]}
      else
        log -w "Cannot set docker_user to ${rcvalue[0]}: user does not exist"
      fi
    fi

    rcvalue=() ; ! $printer_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" printer)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && PRINTER=${rcvalue[0]}

    rcvalue=() ; ! $sudo_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" sudo_user)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && sudo_user=${rcvalue[0]}

    # Deal with multiple sudo_regex lines
    local rcsudo_regex=""
    if ! $sudo_regex_set; then
      rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" sudo_regex)
      [[ -n "${rcvalue:-}" ]] && for rcsudo_regex in "${rcvalue[@]}"; do
        sudo_regexes+=("$rcsudo_regex")
      done
    fi

    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME" appimage_path)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && appimage_path=${rcvalue[0]}

    local mqtt_server="" mqtt_username="" mqtt_password=""
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt server)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && mqtt_server=${rcvalue[0]}
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt username)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && mqtt_username=${rcvalue[0]}
    rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt password)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && mqtt_password=${rcvalue[0]}

    rcvalue=() ; ! $host_name_set && mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt host_name)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && host_name=${rcvalue[0]}
    rcvalue=() ; ! $ink_topic_set && mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt ink_topic)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && ink_topic=${rcvalue[0]}
    rcvalue=() ; ! $prepend_name_set && mapfile -t rcvalue < <(get_config_value "$rcfile" mqtt prepend_name)
    [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 && ${rcvalue[0]} =~ ^(true|false)$ ]] && prepend_name=${rcvalue[0]}

  fi # if [[ -s "$rcfile" ]]; then
  local print_opts=(
    help
    app_checks
    latest_checks
    non_auto_latest_checks
    docker_checks
    check_functions
    utility_functions
    example_config
    version
  )
  local print_opt_descriptions=(
    "This help text"
    "Application Version Checks"
    "Latest Application Version Checks"
    "Non-Automatic Latest Application Version Checks"
    "Docker Checks"
    "Check Functions"
    "Utility Functions"
    "Example Configuration File with all options documented"
    "Application Version"
  )

  if [[ -n "${print_opt:-}" ]]; then
    case "$print_opt" in
      help)
          echo "Available print options (-p PRINT_OPTION):"
          n=$(get_longest "${print_opts[@]}")
          for i in "${!print_opts[@]}"; do
            printf '    %-*s : %s\n' "$n" "${print_opts[i]}" "${print_opt_descriptions[i]}"
          done
          exit ;;
        # print_list "$print_single" -l "Available print options" "${print_opts[@]}" ; exit ;;
      a*) print_list "$print_single" -l "Application Version Checks" "${app_checks[@]}" ; exit ;;
      c*) print_list "$print_single" -l "Checks" "${check_list[@]}" ; exit ;;
      f*) print_list "$print_single" -l "Check Functions" "${function_list[@]}" ; exit ;;
      l*) print_list "$print_single" -l "Latest Application Version Checks" "${latest_checks[@]}" ; exit ;;
      n*) print_list "$print_single" -l "Non-Automatic Latest Application Version Checks" "${non_auto_latest_checks[@]}" ; exit ;;
      d*) print_list "$print_single" -l "Docker Checks" "${docker_checks[@]}"
          exit ;;
      u*) print_list "$print_single" -l "Utility Functions" "${utility_list[@]}"
          exit ;;
      v*) echo "Version $PROGVER" ; exit 0 ;;
      e*) # Add new options for [$PROGNAME] to list_reserved_words array above
          echo "Example RCFILE (for \$HOME/.config/${PROGNAME}rc or $PROGDATA/${PROGNAME}rc)"
          echo "  [$PROGNAME]"
          echo "  user: username                $(printf '%*s' "${#PROGNAME}" " ") # no default; only used when run as root"
          echo "  cache_dir: /var/lib/$PROGNAME/.cache    # defaults to \$HOME/.cache/$PROGNAME"
          echo "  cache_lifetime: minutes       $(printf '%*s' "${#PROGNAME}" " ") # defaults to $cache_lifetime"
          echo "  retry_delay: seconds          $(printf '%*s' "${#PROGNAME}" " ") # defaults to $retry_delay"
          echo "  max_retries: number           $(printf '%*s' "${#PROGNAME}" " ") # defaults to $max_retries"
          echo "  docker_seconds: seconds       $(printf '%*s' "${#PROGNAME}" " ") # defaults to $docker_seconds"
          echo "  docker_user: username         $(printf '%*s' "${#PROGNAME}" " ") # defaults to 'nobody'"
          echo "  include_invalid: true/false   $(printf '%*s' "${#PROGNAME}" " ") # defaults to $include_invalid"
          echo "  sudo_regex: _latest$          $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  sudo_regex: ^sudo             $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  sudo_user: username           $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  printer: ip/name              $(printf '%*s' "${#PROGNAME}" " ") # no default"
          echo "  # custom list names cannot be 'docker' or any of the other above config options"
          echo "  all: sw1 sw2 sw3 sw4          $(printf '%*s' "${#PROGNAME}" " ") # no default; ${bu}all${ubu} list"
          echo "  my_custom_list: sw2 sw5       $(printf '%*s' "${#PROGNAME}" " ") # no default; custom list"
          echo "  my_other_list: sw3 sw7 sw9    $(printf '%*s' "${#PROGNAME}" " ") # no default; custom list"
          echo
          echo "  [$PROGNAME:list_name]"
          echo "  output_file: file"
          echo "  output_mode: text/json/mqtt"
          echo "  include_invalid: true/false"
          echo
          echo "  [$PROGNAME:version_check_function_name]"
          echo "  output_file: file"
          echo "  output_mode: text/json/mqtt"
          echo "  include_invalid: true/false"
          echo "  use_sudo: true/false"
          echo "  sudo_user: username"
          echo "  cache_lifetime: minutes"
          echo "  retry_delay: seconds"
          echo "  max_retries: number"
          echo
          echo "  [mqtt]"
          echo "  server: mqtt.example.com"
          echo "  username: mqtt"
          echo "  password: mypassword"
          echo "  host_name: hostname"
          echo "  ink_topic: topicname"
          echo "  prepend_name: true/false      # defaults to false"
          echo
          echo "  [github|codeberg|forgejo|gitea|gitlab]"
          echo "  token: github_pat_TOKEN"
          echo
          echo "  [flip_2_dnd_pro] # This is for making the pro version installable from obtainium"
          echo "  repo_url: private_repo_for_flip_2_dnd_pro local copy"
          echo
          echo "  [joplin|private_aur|plex|privatebin|yourls]"
          echo "  url: server_url"
          echo "  # For yourls, create a ver.php that prints the version:"
          echo '  #   <?php'
          echo '  #   require_once( dirname(__FILE__)."/includes/load-yourls.php" );'
          # shellcheck disable=2028
          echo '  #   print("{\n  \"version\": \"" . YOURLS_VERSION . "\"\n}\n");'
          echo '  #   ?>'
          echo
          echo "  [routeros]"
          echo "  url: routeros_device_url"
          echo "  username: routeros_username"
          echo "  password: routeros_password"
          echo
          echo "  [slzb]"
          echo "  url: slzb_device_url"
          echo "  username: slzb_device_username"
          echo "  password: slzb_device_password"
          echo "  chip: number            # 0=slzb-06p10"
          echo "  type: number            # 0=coordinator"
          echo "  esp_type: TYPE          # type=0=ESP vs. ESPs3 for type>SLZB_06MR4[14]"
          echo
          echo "  [tasmota]"
          echo "  device_name: tasmota_device_name"
          echo "  device_ip: tasmota_device_ip"
          echo "  username: tasmota_device_username"
          echo "  password: tasmota_device_password"
          echo
          echo "  [truenas]"
          echo "  url: truenas_server_url"
          echo "  apikey: truenas_server_api_key"
          echo
          exit ;;
      *) log -e "Invalid option for -p ($print_opt)" && usage 1 ;;
    esac # case "$print_opt" in
  fi

  # If -L was given and no software was listed, add 'docker' to software list
  [[ -n "${update_list:-}" ]] && (( $# == 0 )) && set -- "$update_list" && update_list=""
  (( $# == 0 )) && usage

  # Set up software list from command line arguments, substitute _ for -
  local software=()
  mapfile -t software < <(printf '%s\n' "$@" | sort -u)

  # Prepare cache_dir
  local cache_dir_prepared=false
  # Warn if wait is extreme
  (( cache_lifetime < 30 )) && log -q "Warning: Latest update WAIT set to under 30 minutes"
  (( cache_lifetime > 1440 )) && log -q "Warning: Latest update WAIT set to over $(( cache_lifetime / 60 )) hours/$(( cache_lifetime / 60 / 24 )) days (WAIT is in minutes)"

  # Print debug info
  if (( DEBUG > 1 )); then
    log -d "[GLOBAL SETTINGS] software list = '${software[*]:-}'"
    log -d "[GLOBAL SETTINGS] update_list = '$update_list'"
    log -d "[GLOBAL SETTINGS] running as $(id -un)"
    log -d "[GLOBAL SETTINGS] rcfile = '$rcfile'"
    log -d "[GLOBAL SETTINGS] cache_dir = '$cache_dir'"
    log -d "[GLOBAL SETTINGS] cache_lifetime = '$cache_lifetime'"
    log -d "[GLOBAL SETTINGS] printonly = '$printonly'"
    log -d "[GLOBAL SETTINGS] output_file = '$output_file'"
    log -d -d "[GLOBAL SETTINGS] output_file_set = '$output_file_set'"
    log -d "[GLOBAL SETTINGS] output_mode = '$output_mode'"
    log -d -d "[GLOBAL SETTINGS] output_mode_set = '$output_mode_set'"
    log -d "[GLOBAL SETTINGS] docker_seconds = '$docker_seconds'"
    log -d "[GLOBAL SETTINGS] docker_user = '$docker_user'"
    log -d "[GLOBAL SETTINGS] retry_delay = '$retry_delay'"
    log -d "[GLOBAL SETTINGS] printer = '$PRINTER'"
    log -d "[GLOBAL SETTINGS] include_invalid = '$include_invalid'"
    log -d "[GLOBAL SETTINGS] force_all = '$force_all'"
    (( ${#force_list[@]} > 0 ))     && log -d "[GLOBAL SETTINGS] force_list = '${force_list[*]:-}'"
    [[ -n "$sudo_user" ]]           && log -d "[GLOBAL SETTINGS] sudo_user = '$sudo_user'"
    (( ${#sudo_regexes[@]} > 0 ))   && printf "[DEBUG] [GLOBAL SETTINGS]" && set | grep ^sudo_regexes= >&2
    [[ -n "$mqtt_server" ]]         && log -d "[GLOBAL SETTINGS] mqtt_server = '$mqtt_server'"
    [[ -n "$mqtt_username" ]]       && log -d "[GLOBAL SETTINGS] mqtt_username = '$mqtt_username'"
    [[ -n "$mqtt_server" && -n "$prepend_name" ]] && log -d "[GLOBAL SETTINGS] prepend_name = '$prepend_name'"
    [[ -n "$mqtt_server" && -n "$ink_topic" ]]    && log -d "[GLOBAL SETTINGS] ink_topic = '$ink_topic'"
    echo
  fi

  # Prep variables
  local printlist=()
  local json_string="[]" # json string for printing to the screen
  local saved_prepend_name=$prepend_name
  local saved_output_file=$output_file
  local saved_output_mode=$output_mode
  local saved_include_invalid=$include_invalid
  local saved_docker_seconds=$docker_seconds
  local saved_docker_user=$docker_user

  local list="" sw="" sw_list="" listname="" rcvalue=()
  local sw_skip_vflag=() sw_auto_flags=() sw_latest=false
  local sw_name="" sw_check_set="" tmp_name="" sw_orig="" sw_tag="" sw_project=""
  local docker_seconds_local=0 container_list="" containers=""
  local sw_list_item="" started_at=0 started_secs=0 now=0 stamp=0 lifetime=0 delay=0
  local retries=0 ret=0 version="" update_time=0 use_sudo="" regex="" topic="" tmpjson=""

  # Process software list
  log -d -d "Software list: ${software[*]:-}"
  for list in "${software[@]}"; do
    [[ -z "$list" ]] && continue
    prepend_name=$saved_prepend_name
    output_file=$saved_output_file
    output_mode=$saved_output_mode
    include_invalid=$saved_include_invalid
    docker_seconds=$saved_docker_seconds
    docker_user=$saved_docker_user
    sw_list=()

    # If list=docker, load docker checks
    if [[ "$list" == "docker" ]]; then
      sw_list=("${docker_checks[@]}")
      log -d "Setting software list to '${sw_list[*]:-}'"
      if (( ${#sw_list[@]} == 0 )); then
        log "There are no docker checks"
        exit
      fi

    # If command line parameter is "list:sw", do update
    elif [[ -n "${update_list:-}" || "$list" =~ ^[0-9a-zA_Z_-]+:: ]]; then
      sw_list=("${list#*::}")
      if [[ "$list" == "$update_list" && -s "$rcfile" ]]; then
        log -d "Reading configfile for software list for ${list//\\/\\\\} (update_list)"
        read -ra sw_list <<< "$(get_config_value "$rcfile" "$PROGNAME::${list//\\/\\\\}" "list" | tr '\n' ' ')"
        log -d "Setting software list to '${sw_list[*]:-}' for $list"
      fi
      [[ -n "$update_list" ]] && list=$update_list
      list=${list%::*}

      log -d "Processing an update of ${sw_list[*]:-} for $list"
      update=true

    # If sw is a list defined in the config, load its software in sw list
    elif [[ " ${list_reserved_words[*]:-} " != *" $list "* && "$list" != *!!* && -s "$rcfile" ]]; then
      log -d "Reading configfile for software list for ${list//\\/\\\\}"
      read -ra sw_list <<< "$(get_config_value "$rcfile" "$PROGNAME::${list//\\/\\\\}" "list" | tr '\n' ' ')"
      log -d "Setting software list to '${sw_list[*]:-}' for $list"
      # Add check for this program if list=all
      [[ "$list" == "all" ]] && { sw_list+=("$PROGNAME") ; log -d "Adding self to all sw_list" ; }
    fi # if [[ "$list" == "docker" ]]; then

    log -d -d "Defaulting software list to $list for $list"
    (( ${#sw_list[@]} == 0 )) && sw_list=("$list")

    if [[ -s "$rcfile" && "$list" != *!!* ]]; then
      # output_mode
      rcvalue=() ; ! $output_mode_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::${list//\\/\\\\}" output_mode)
      [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && output_mode=${rcvalue[0]} && \
        case "$output_mode" in json);;mqtt)output_file=/dev/stdout;; *)output_mode=text;output_file=/dev/stdout;; esac

      # output_file
      rcvalue=() ; ! $output_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::${list//\\/\\\\}" output_file)
      [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && output_file=${rcvalue[0]} && output_mode=json
      log -d "Reading ${list//\\/\\\\} config settings: output_file = '$output_file' output_mode = '$output_mode'"

      # prepend_name
      rcvalue=() ; ! $prepend_name_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::${list//\\/\\\\}" prepend_name)
      [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && prepend_name=${rcvalue[0]}

      # include_invalid
      rcvalue=() ; ! $include_invalid_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::${list//\\/\\\\}" include_invalid)
      [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && include_invalid=${rcvalue[0]}

      rcvalue=() ; ! $docker_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$list" docker_user)
      if [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]]; then
        if id "${rcvalue[0]}" &> /dev/null; then
          docker_user=${rcvalue[0]}
        else
          log -w "Cannot set docker_user to ${rcvalue[0]}: user does not exist"
        fi
      fi
    fi

    # If -L docker was given and docker_seconds is set, only look for checks
    # related to containers that were restarted within docker_seconds seconds
    if $update && [[ "$list" == docker ]]; then
      docker_seconds_local=$docker_seconds
      if [[ -s "$rcfile" && "$list" != *!!* ]]; then
        rcvalue=() ; ! $docker_seconds_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$list" docker_seconds)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && docker_seconds_local=${rcvalue[0]}
      fi

      if [[ -n "$docker_seconds_local" ]]; then
        log -d "Checking age for docker containers"
        # Loop through checks (in this case all container checks) and find
        # containers that were restarted within docker_seconds seconds, then
        # reverse check back for the check name and add it to the list
        container_list=()
        for sw_list_item in "${sw_list[@]}"; do
          mapfile -t containers < <(image_search -C "$sw_list_item")

          for container in "${containers[@]}"; do
            log -d "Checking age for docker container: $container"
            started_at=$(docker inspect --format '{{.State.StartedAt}}' "$container")
            [[ ! $started_at =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\.[0-9]+)?Z$ ]] && continue
            started_secs=$(date -d "$started_at" +%s)
            [[ ! $started_secs =~ ^[0-9]+$ ]] && log -e "$started_secs not a number" && continue
            now=$(date +%s)
            log -d "Container Mode ($container): now = '$now' seconds = '$started_secs' diff = '$(( now - started_secs ))' docker_seconds_local = '$docker_seconds_local'"
            (( now - started_secs > docker_seconds_local )) && { log -d -d -d "$container not old enough" ; continue ; }
            log -d -d "Adding $container ($sw_list_item) to sw_list"
            [[ " ${container_list[*]:-} " != *" $sw_list_item "* ]] && container_list+=("$sw_list_item")
          done # for container in "${containers[@]}"; do
        done # for sw in "${sw_list[@]}"; do
        log -d -d "container_list = '${container_list[*]:-}'"
        sw_list=("${container_list[@]}")
      fi # if [[ -n "$docker_seconds_local" ]]; then
    fi # if $update && [[ "$list" == docker ]]; then

    mapfile -t sw_list < <(printf '%s\n' "${sw_list[@]}" | sort -u)
    log -d -d "Sorting software list: ${sw_list[*]:-}"

    case "$list" in
      all)
        log -d "Applying 'all' specific settings"
        [[ "${sw_list[*]:-}" == "all" ]] && log -e "'list' property not defined in [$PROGNAME:all] section of RCFILE" && exit 1
        ! $prepend_name_set && prepend_name=true
        ;;
      latest)
        log -d "Applying 'latest' specific settings"
        ! $prepend_name_set && prepend_name=false
        ;;
      *) ;;
    esac

    if (( DEBUG > 1 )); then
      [[ "$output_file" != "$saved_output_file" ]] && log -d "[$list SETTINGS] output_file = '$output_file'"
      [[ "$output_mode" != "$saved_output_mode" ]] && log -d "[$list SETTINGS] output_mode = '$output_mode'"
      [[ "$include_invalid" != "$saved_include_invalid" ]] && log -d "[$list SETTINGS] include_invalid = '$include_invalid'"
      [[ "$docker_seconds" != "$saved_docker_seconds" ]] && log -d "[$list SETTINGS] docker_seconds = '$docker_seconds'"
      [[ "$docker_user" != "$saved_docker_user" ]] && log -d "[$list SETTINGS] docker_user = '$docker_user'"
      log -d "[$list SETTINGS] list = '${sw_list[*]:-}'"
      echo
    fi

    for sw in "${sw_list[@]}"; do
      [[ -z "$sw" ]] && continue
      sw_check_set=false
      sw_auto_flags=()
      sw_skip_vflag=(-V)

      log -d "Starting $sw"
      listname=$list
      [[ "$listname" == "$sw" ]] && listname=""
      tmp_name=$sw

      rcvalue=() ; [[ -s "$rcfile" && "$sw" != *!!* ]] && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::${sw//\\/\\\\}" check)
      [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && sw=${rcvalue[0]} && sw_check_set=true && \
        log -d "Read check '$sw' for $tmp_name"
      sw_orig=$sw

      # For dynamic/auto checks, strip off preceding 
      sw_name=$sw
      sw_latest=false
      # sw_tag=$(grep -Po "(?<=!!)$CHECK_LIST$" <<< "$sw_name")
      sw_tag=$(sed -r "s/^.*"'!!'"$CHECK_LIST$/\1/" <<< "$sw_name")
      while [[ "$sw_name" =~ ^$CHECK_MODIFIERS ]]; do
        case "$sw_name" in
          prejq=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#prejq=*!!}
            sw_auto_flags+=(-J "${tmpstring#prejq=}")   # The last one will be used
            ;;
          postjq=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#postjq=*!!}
            sw_auto_flags+=(-j "${tmpstring#postjq=}")  # The last one will be used
            ;;
          xml=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#xml=*!!}
            sw_auto_flags+=(-x "${tmpstring#xml=}")     # The last one will be used
            ;;
          presed=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#presed=*!!}
            sw_auto_flags+=(-P "${tmpstring#presed=}")
            ;;
          postsed=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#postsed=*!!}
            sw_auto_flags+=(-S "${tmpstring#postsed=}")
            ;;
          remove=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#remove=*!!}
            sw_auto_flags+=(-r "${tmpstring#remove=}")
            ;;
          search=*)
            tmpstring=${sw_name%%!!*}
            sw_name=${sw_name#search=*!!}
            sw_auto_flags+=(-s "${tmpstring#search=}")
            ;;
          noskip_version_filter*)
            sw_name=${sw_name#noskip_version_filter!!}
            sw_skip_vflag=(-V)
            ;;
          skip_version_filter*)
            sw_name=${sw_name#skip_version_filter!!}
            sw_skip_vflag=(-v)
            ;;
          *) ;;
        esac
      done
      [[ "$tmp_name" == *_latest ]] && sw_latest=true
      sw_project=${sw_name%!!"$sw_tag"*}
      ! $sw_check_set && tmp_name=$sw_project
      sw_name=${tmp_name%_latest}
      $docker_filter && [[ "$sw_name" != *_docker && ! "$sw_tag" =~ docker ]] && continue

      log -d -d "list = '$list'"
      log -d -d "listname = '$listname'"
      log -d -d "sw_name = '$sw_name'"
      log -d -d "tmp_name = '$tmp_name'"
      log -d -d "sw_check_set = '$sw_check_set'"
      log -d -d "sw_latest = '$sw_latest'"
      log -d -d "sw_tag = '$sw_tag'"
      log -d -d "sw_project = '$sw_project'"
      log -d -d "sw_skip_vflag = '${sw_skip_vflag[*]:-}'"
      log -d -d "sw_auto_flags = '${sw_auto_flags[*]:-}'"
      log -d -d "sw_orig = '$sw_orig'"

      log -d "Processing $sw_name${listname:+ for "$listname"}"

      if [[ -s "$rcfile" ]]; then
        # See if check is defined
        # rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$list" check)
        # [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && sw=${rcvalue[0]} && \
        #   log -d "Read check '$sw' for $sw_name"

        # output_mode
        rcvalue=() ; ! $output_mode_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" output_mode)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && output_mode=${rcvalue[0]} && \
          case "$output_mode" in json);;mqtt)output_file=/dev/stdout;; *)output_mode=text;output_file=/dev/stdout;; esac

        # output_file
        rcvalue=() ; ! $output_file_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" output_file)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && output_file=${rcvalue[0]} && output_mode=json
        log -d "Reading $sw_name config settings: output_file = '$output_file' output_mode = '$output_mode'"

        # prepend_name
        rcvalue=() ; ! $prepend_name_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" prepend_name)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && prepend_name=${rcvalue[0]}

        # include_invalid
        rcvalue=() ; ! $include_invalid_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" include_invalid)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && include_invalid=${rcvalue[0]}

        rcvalue=() ; ! $docker_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" docker_user)
        if [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]]; then
          if id "${rcvalue[0]}" &> /dev/null; then
            docker_user=${rcvalue[0]}
          else
            log -w "Cannot set docker_user to ${rcvalue[0]}: user does not exist"
          fi
        fi
      fi

      # If software is "ink" but printer is not set, go to the next software
      if [[ "$sw_name" == "printer_ink_check" && -z "$PRINTER" ]]; then
        log -e "No printer defined for $sw"
        continue
      fi

      # Reset lifetime to cache_lifetime, delay to retry_delay and retries to max_retries
      lifetime=$cache_lifetime
      delay=$retry_delay
      retries=$max_retries

      if [[ -s "$rcfile" ]]; then
        log -d "Reading cache_lifetime retry_delay max_retries settings from config for $sw_name"
        # Check if this version check has a setting for cache_lifetime and use it if it does
        rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" cache_lifetime)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && lifetime=${rcvalue[0]}

        # Check if this version check has a setting for retry_delay and use it if it does
        rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" retry_delay)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && delay=${rcvalue[0]}

        # Check if this version check has a setting for max_retries and use it if it does
        rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" max_retries)
        [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && retries=${rcvalue[0]}
      fi

      # If printonly mode, add to list and continue to next
      $printonly && printlist+=("$sw") && continue

      # Validate output_file
      if [[ "$output_file" != "/dev/stdout" ]]; then
        # Ensure parent directory exists and is writable
        local out_dir=""
        out_dir=$(dirname "$output_file")
        if [[ ! -d "$out_dir" ]]; then
          log -e "Output directory does not exist: $out_dir"
          exit 1
        fi
        if [[ ! -w "$out_dir" ]]; then
          log -e "Output directory is not writable: $out_dir"
          exit 1
        fi
        if [[ -e "$output_file" && ! -w "$output_file" ]]; then
          log -e "Output file is not writable: $output_file"
          exit 1
        fi
      fi

      if (( DEBUG > 1 )) && [[ "$listname" != "$sw_name" ]]; then
        [[ "$output_file" != "$saved_output_file" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] output_file = '$output_file'"
        [[ "$output_mode" != "$saved_output_mode" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] output_mode = '$output_mode'"
        [[ "$include_invalid" != "$saved_include_invalid" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] include_invalid = '$include_invalid'"
        [[ "$docker_seconds" != "$saved_docker_seconds" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] docker_seconds = '$docker_seconds'"
        [[ "$docker_user" != "$saved_docker_user" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] docker_user = '$docker_user'"
        [[ "$lifetime" != "$cache_lifetime" ]] && log -d "[${listname:+$listname:}$sw_name SETTINGS] lifetime = '$lifetime'"
        [[ "$delay" != "$retry_delay" ]]       && log -d "[${listname:+$listname:}$sw_name SETTINGS] delay = '$delay'"
        [[ "$retries" != "$max_retries" ]]     && log -d "[${listname:+$listname:}$sw_name SETTINGS] retries = '$retries'"
        log -d "[${listname:+$listname:}$sw_name SETTINGS] sw = '$sw_name'"
        echo
      fi

      (( DEBUG >= DEBUG_EXIT )) && continue

      # If not-force and check is for latest version, respect timestamp
      i=0
      update_time==0
      while (( i <= retries )); do
        # If a retry, sleep for $delay
        (( i > 0 )) && log -d "Retrying for $sw_name (try $i of $retries) after $delay wait" && sleep "$delay"

        ret=0 version=""
        if $sw_latest && ! ${cache_dir_prepared:-false}; then
          # && prepare_cache_dir "$cache_dir"
          local cache_parent=""
          if [[ -n "$cache_dir" ]]; then
            if [[ ! -d "$cache_dir" ]]; then
              [[ -e "$cache_dir" ]] && log -e "Cache directory '$cache_dir' exists but is not a directory" && exit 1
              mkdir -p "$cache_dir" &> /dev/null
              # If cache_dir does not exist, ensure parent is writable
              cache_parent=$(realpath "$cache_dir")
              cache_parent=${cache_parent%/*}
              if [[ ! -w "$cache_parent" ]]; then
                log -e "Cannot write to $cache_parent to create cache dir: $cache_dir"
                exit 1
              fi
            else
              # If cache_dir exists, make sure it is writable
              if [[ ! -w "$cache_dir" ]]; then
                log -e "Cannot write to cache dir: $cache_dir"
                exit 1
              fi
            fi
            [[ ! -d "$cache_dir" ]] && mkdir -p "$cache_dir"
          fi
          log -d "Cache directory prepared"
          cache_dir_prepared=true
        fi

        log -d -d -d "Determining if using cache:"
        log -d -d -d "sw_latest = '$sw_latest' (looking for true)"
        log -d -d -d "force_all = '$force_all' (looking for false)"
        log -d -d -d "id -u = '$(id -u)' (looking for != 0)"
        log -d -d -d "force_list = '${force_list[*]:-}'"
        log -d -d -d "sw_name = '$sw_name' (should not be in force_list)"
        log -d -d -d "sw = '$sw' (should not be in force_list)"
        log -d -d -d "cache_file = '$cache_dir"/"${sw_name//\//__}${minver:+_$minver}' (should be readable)"
        # If -f and -F not used, user is not root, sw IS a latest check, and 
        # cache_file is readable, read the cache file if not stale
        if $sw_latest && ! $force_all && [[ $(id -u) != 0 && \
          " ${force_list[*]:-} " != *" $sw_name "* && " ${force_list[*]:-} " != *" $sw "* && \
            -r "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}" ]]; then

          log -d "Using cache for $sw_name"
          stamp=$(stat -c "%Y" "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}")
          now=$(date +%s)

          # If the timestamp is less than 1 hour
          if (( now - stamp < lifetime * 60 - 1 )) ; then
            log -v "$sw_name was updated $(( (now - stamp) / 60 )) minutes ago, using cache ($lifetime minutes)"
            log -d "Reading $sw_name info from cache ($(( (now - stamp) / 60 )) of $lifetime minutes)"
            version=$(cat "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}")
            ret=$?
            update_time=$stamp
          fi
        else
          log -d "Not using cache for $sw_name"
          (( DEBUG > 0 )) && $force_all && log -d "Forced update"
          (( DEBUG > 0 )) && [[ " ${force_list[*]:-} " == *" $sw "* ]] && log -d "Forced update"

          use_sudo=false
          # Loop through sudo_regexes to see if $sw_name matches a regex to use sudo
          [[ -n "${sudo_regexes:-}" ]] && for regex in "${sudo_regexes[@]}"; do
            [[ "$sw_name" =~ $regex ]] && use_sudo=true
          done
          log -d -d "Checking to see if $sw should be run with sudo (use_sudo = '$use_sudo)'"

          if [[ -s "$rcfile" ]]; then
            # Read config file to see if there are specific settings for $sw
            rcvalue=() ; mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" use_sudo)
            [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && use_sudo=${rcvalue[0]}
            rcvalue=() ; $use_sudo && ! $sudo_user_set && mapfile -t rcvalue < <(get_config_value "$rcfile" "$PROGNAME::$sw_name" sudo_user)
            [[ -n "${rcvalue:-}" && ${#rcvalue[@]} -gt 0 ]] && sudo_user=${rcvalue[0]}
          fi

          ## EXECUTE CHECK
          # Run through sudo exec if necessary
          # Return code DOCKER_TOO_OLD when docker_filter is enabled and container is older than seconds
          local version=""
          version=$(use_sudo_exec "$sw")
          ret=$?

          # If check not run as sudo_user, run normally
          if [[ -z "$version" ]]; then
            log -d -d "Running 'execute_check -p $sw_project -t $sw_tag ${sw_skip_vflag[*]:-} ${sw_auto_flags[*]:-}$sw_name' to get version"
            version=$(execute_check -p "$sw_project" -t "$sw_tag" "${sw_skip_vflag[@]}" \
              "${sw_auto_flags[@]:-}" "$sw_name")

            ret=$?
          fi
          [[ $ret -eq $DOCKER_TOO_OLD && "$sw_tag" == docker* ]] && continue 2
          update_time=$(date +%s)

          if [[ "$ret" != "0" || -z "$version" || "$version" == "null" ]]; then
            if [[ "$sw_name" == "printer_ink_check" ]]; then
              log -d "Could not get printer info for $sw, returning error json"
            else
              log -d "Could not get a version for $sw, returning '---'"
              version="---"
            fi
            update_time=$(date +%s)
            rm -f "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
            break
          fi

          if $sw_latest; then
            log -d "Writing latest update for $sw_name to cache"
            echo "$version" > "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
            (( $(id -u) == 0 )) && [[ -n "$SUDO_USER" ]] && \
              chown "$SUDO_USER":"$(id -g "$SUDO_USER")" "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
          fi
        fi
        # If version is set, move on
        [[ "$ret" == "0" && -n "$version" && "$version" != "null" ]] && break
        # Otherwise, set to --- and delete cache file
        version="---"
        rm -f "$cache_dir"/"${sw_name//\//__}${minver:+_$minver}"
        i=$(( i + 1 ))
      done # while (( i <= retries )); do

      # Strip leading v
      version=${version#v}
      version=${version#V}

      # Append _latest to the end of sw_name for latest checks
      $sw_latest && sw_name+=_latest

      # Prepare Output
      log -d "${listname:+$listname:}$sw_name printing $output_mode to $output_file"

      local out=""
      # Output text immediately and go to next software
      if (( QUIET == 0 )) && [[ "$output_mode" == "text" || "$output_file" != "/dev/stdout" ]]; then
        if [[ "$sw_name" == "printer_ink_check" ]]; then
          # If cannot print using jq, use echo + some tr's
          if ! jq -rn --arg n "$sw_name" --argjson j "$version" \
            '$j | "\($n): \(.printer) - cyan=\(.cyan) magenta=\(.magenta) yellow=\(.yellow) black=\(.black) photoblack=\(.photoblack)"' 2> /dev/null; then
            echo "$out" | tr -d '\n' | tr -s ' '
          fi
        else
          echo "$sw_name: $version"
        fi
      fi
      [[ "$output_mode" == "text" ]] && continue
      if [[ "$output_mode" == "mqtt" ]]; then
        local mqtt_output=""
        check_prog mosquitto_pub || continue
        log -d -d "Publishing MQTT version info for ${listname:+$listname:}$sw_name"
        printf -v mqtt_output '{ "version": "%s" }' "$version"
        [[ "$sw_name" == "printer_ink_check" ]] && mqtt_output=$version

        if ! $prepend_name_set && [[ "$sw_name" == *"_latest" ]]; then
          prepend_name=false
        fi

        if ! $prepend_name_set && [[ " ${app_checks[*]:-} " == *" $sw "* ]]; then
          prepend_name=true
        fi

        # Set up MQTT topic
        if $prepend_name; then
          topic="software_versions/${host_name}_$sw_name"
        else
          topic="software_versions/$sw_name"
        fi
        [[ "$sw_name" == "printer_ink_check" ]] && topic="$ink_topic/$PRINTER"

        log -d -d "$sw_name = $mqtt_output"
        if $mqtt_test; then
          printf '%s: %s\n' "$topic" "$version"
        else
          log -v "$sw_name: $version"
          mosquitto_pub -r -h "${mqtt_server:?}" -u "${mqtt_username:?}" -P "${mqtt_password:?}" \
            -i "$PROGNAME" -t "${topic:?}" -m "${mqtt_output:?}"
        fi
        log -v "Version published to MQTT"
        ! $mqtt_test && log -v "Updated $topic: $version"
        continue
      fi

      # Printing to screen
      if [[ "$output_file" == "/dev/stdout" ]]; then
        tmpjson=${json_string:-"[]"}
      # Printing to json file
      elif [[ -s "$output_file" ]] && jq -r '.[]' "$output_file" &> /dev/null; then
        tmpjson=$(jq -r '.' "$output_file" 2> /dev/null)
      fi

      # If tmpjson is not valid json with "[ ... ]", reset to "[]"
      if ! jq -n --argjson j "$tmpjson" '$j[]' &> /dev/null; then
        tmpjson="[]"
      fi

      # Save printer ink info to json string
      if [[ "$sw_name" == "printer_ink_check" ]]; then
        ! $include_invalid && grep -q '^[[:space:]]*"error":' <<< "$version" && continue
        tmpjson=$(jq -n --argjson j "$tmpjson" --argjson new "$version" '
          if $j | any(.[]; .name == $new.name and .ip == $new.ip)
          then $j | map(if .name == $new.name and .ip == $new.ip then $new else . end)
          else $j + [$new]
          end | sort_by(.name | ascii_downcase)
        ' 2> /dev/null)
      # Save software version info to json string
      else
        ! $include_invalid && [[ "$version" == "---" ]] && continue
        tmpjson=$(jq -n --argjson j "$tmpjson" --arg n "$sw_name" --arg v "$version" --arg t "${update_time:-$(date +%s)}" '
          if $j | any(.[]; .name == $n)
          then $j | map(if .name == $n then {name: $n, version: $v, time: ($t|tonumber)} else . end)
          else $j + [{name: $n, version: $v, time: ($t|tonumber)}]
          end | sort_by(.name | ascii_downcase)
        ' 2> /dev/null)
      fi

      # Could not generate valid json string
      # shellcheck disable=SC2181
      if (( $? != 0 )); then
        log -e "Could not add $sw_name to $listname json string"
        continue
      # Generated valid json for ouput
      else
        local direct_write=false
        # If printing to screen, save to global json_string
        if [[ "$output_file" == "/dev/stdout" ]]; then
          json_string=$tmpjson
        # Printing to a file
        else
          log -d -d "Removing $output_file.new"
          if [[ -e "$output_file".new ]]; then
            rm -f "$output_file".new
          fi
          # Could not delete .new file
          if [[ -e "$output_file".new ]]; then
            log -d -d "Could not remove $output_file.new"
            direct_write=true
          else
            log -d -d "Writing to $output_file.new"
            jq -rn --argjson j "$tmpjson" '$j' 2> /dev/null > "$output_file".new
            if [[ ! -s "$output_file".new ]]; then
              log -d -d "Could not write to $output_file.new"
              direct_write=true
            else
              log -d -d "Moving $output_file.new to $output_file"
              mv "$output_file".new "$output_file" || \
                log -e "Error: Could not move .new to $output_file"
            fi
          fi
          if $direct_write; then
            log -d -d "Writing directly to $output_file"
            jq -rn --argjson j "$tmpjson" '$j' 2> /dev/null > "$output_file" || \
              log -e "Error: Could not write to file $output_file"
          fi
          if [[ -s "$output_file" ]]; then
            log -v "JSON Output saved to '$output_file'"
          else
            log -e "Could not write '$tmpjson' to '$output_file'"
            continue
          fi
        fi
      fi
    done # for sw in "${sw_list[@]}"; do
  done # for list in "${software[@]}"; do
  (( DEBUG >= DEBUG_EXIT )) && exit

  # Print global json_string to the screen
  if [[ "$output_mode" == "json" && "$output_file" == "/dev/stdout" ]]; then
    log -d "Printing json string to the screen"
    jq -rn --argjson j "$json_string" '$j'
  fi

  # If in Print Only mode, print list of software
  if $printonly && (( ${#printlist[@]} > 0 )); then
    print_list "$print_single" -s -l "[Test Mode] List of checks" "${printlist[@]}"
  fi
}

if (return 2> /dev/null); then
  # If included as a library
  return 0
else
  # If run as a program
  main "$@"
fi

