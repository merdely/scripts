#!/usr/bin/env bash

# Define variables for this program
PROGNAME=vcheck
PROGVER=1.1.0
PROGDATA=/etc/"$PROGNAME"
ALPINE_VER=""
SUDO_EXEC=false

# Define check for this program
eval "$PROGNAME() { echo \$PROGVER; }" # { # utility_function

TMPFILES=()
trap 'rm -Rf -- "${TMPFILES[@]}"' EXIT
trap 'exit 1' INT TERM

# Add common bin dirs to the PATH
export PATH=$PATH:$HOME/.local/bin:/bin:/usr/bin:/usr/local/bin:/sbin:/usr/sbin:/usr/local/sbin

# Define a SEMVER_REGEX to be used in functions to validate version strings
# From https://semver.org/#is-there-a-suggested-regular-expression-regex-to-check-a-semver-string
# Their major, minor, patch, and prerelease groups break bookstack because of its leading 0
# Changed 0|[1-9] to [0-9]
SEMVER_MAJOR='(?P<major>[0-9]\d*)'
SEMVER_MINOR='\.(?P<minor>[0-9]\d*)'
SEMVER_PATCH='(?:\.(?P<patch>[0-9]\d*))?'
SEMVER_PRERELEASE='(?:-(?P<prerelease>(?:[0-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\.(?:[0-9]\d*|\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?'
SEMVER_BUILDMETA='(?:\+(?P<buildmetadata>[0-9a-zA-Z-]+(?:\.[0-9a-zA-Z-]+)*))?'
HOTFIX='(?:\.(?P<hotfix>[0-9]\d*))?'
VER_YMD='(?P<year>[0-9]{4})[\._-](?P<month>[01]?[0-9])[\._-](?P<day>[0123]?[0-9])'
LSVER='(?:-(?P<lsver>ls[0-9]+))?'
SEMVER_REGEX="(?:$SEMVER_MAJOR$SEMVER_MINOR$SEMVER_PATCH$HOTFIX|$VER_YMD)$SEMVER_PRERELEASE$SEMVER_BUILDMETA$LSVER"

AUTO_CHECKS='(aur_latest|cat|codeberg|codeberg_latest|command|docker_exec|docker_inspect|docker_inspect_image|docker_printenv|docker_tags|docker_tags_latest|flatpak|flatpak_latest|forgejo|forgejo_latest|github|github_latest|gitlab|github_tags|github_tags_latest|gitlab_latest|pacman)'

# Handle temp files
TEMPDIR=$(mktemp -d)
_cleanup() { # utility_function
  local ret=$?
  log -d -d -d "Cleaning up $TEMPDIR"
  rm -Rf -- "$TEMPDIR"
  exit "$ret"
}
trap '_cleanup' EXIT
trap 'exit 1' INT TERM

## FUNCTIONS

# Older versions of bash don't have mapfile
if ! command -v mapfile &> /dev/null; then
  mapfile() { # utility_function
    [[ "$1" == "-t" ]] && shift
    local arr=$1 i=0 line
    # shellcheck disable=SC2034
    while IFS= read -r line; do
      eval "${arr}[i]=\"\$line\""
      i=$(( i + 1 ))
    done
  }
fi

# Function to log messages respecting -d, -v, -q, and -e
log() { # utility_function
  # Comment out printing Running here because it is too noisy
  # (( debug == 3 )) && echo "[DEBUG] (${FUNCNAME[0]}) Running: ${FUNCNAME[0]} $*" >&2
  local OPTIND=1 opt OPTARG
  local print_error=false check_debug=0 check_quiet=0 check_verbose=0 prepend
  while getopts ":edwqv" opt; do
    case "$opt" in
      e) print_error=true ; prepend="[ERROR] (${FUNCNAME[1]}): " ;;
      d) check_debug=$(( check_debug + 1 )) ; ! $print_error && prepend="[DEBUG] (${FUNCNAME[1]}): " ;;
      q) check_quiet=$(( check_quiet + 1 )) ;;
      v) check_verbose=$(( check_verbose + 1 )) ;;
      w) prepend="[WARNING] (${FUNCNAME[1]}): " ;;
      *) echo "[WARNING] Invalid flag ($OPTARG)" >&2 ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  ! $print_error && (( check_quiet < quiet )) && return 0
  ! $print_error && (( check_debug > debug )) && return 0
  ! $print_error && (( check_verbose > verbose && check_verbose > quiet )) && ! $mqtt_test && return 0
  echo "${prepend}$*" >&2
  return 0
}

# Use get_config_value from my _config library
get_config_value() {
  # No section: variable=( $(get_config_value file key) )
  # Section:    variable=( $(get_config_value file section key) )

  local opt OPTARG OPTIND=1 ltrim=1 rtrim=1

  # Try to respect a global debug variable; supports true/on/yes/debug/1-999 or false/0
  local localdebug=${debug:-false} ncm=false
  shopt -q nocasematch && ncm=true ; shopt -s nocasematch
  case "$localdebug" in true|debug|y|yes|on|[1-9]|[1-9]0|[0-9][1-9]|[1-9][0-9]0|[0-9][0-9][1-9])localdebug=true;;*)localdebug=false;;esac
  ! $ncm && shopt -u nocasematch ; unset ncm

  # Handle options -L and -T for preserving leading/trailing whitespace in values
  while getopts ":LT" opt;do case "$opt" in L)ltrim=0;;T)rtrim=0;;*);;esac;done;shift $((OPTIND-1))

  # Require at least two arguments (file and key with section being optional)
  (( $# < 2 )) && return 1

  local configfile=$1 section="" key=$2
  # Replace ^~ with $HOME
  [[ "$configfile" == ~* ]] && configfile=$HOME${configfile#~}

  # If 3 arguments provided
  (( $# >= 3 )) && section=$2 && key=$3

  # Validate that configfile can be read
  if [[ ! -r "$configfile" ]]; then
    $localdebug && echo "Warning: Cannot read ${configfile##*/} for ${section:+[$section] }$key" >&2
    return 1
  fi
  if [[ -n "$section" ]]; then
    awk -v section="$section" -v key="$key" -v ltrim=${ltrim:-1} -v rtrim=${rtrim:-1} '
      BEGIN {
        in_section = 0
      }
      $0 ~ /^[[:space:]]*\[/ {
        in_section = 0
      }
      $0 ~ "^[[:space:]]*\\["section"\\]" {
        in_section = 1
      }
      in_section == 1 && $0 ~ "^[[:space:]]*"key"[[:space:]]*[:=]" {
        sub(/^[^:=]+[:=]/, "")
        if (ltrim == 1) sub(/^[[:space:]]+/, "")
        if (rtrim == 1) sub(/[[:space:]]+$/,"")
        print
      }' "$configfile"
  else
    awk -v key="$key" -v ltrim=${ltrim:-1} -v rtrim=${rtrim:-1} '
      $0 ~ "^[[:space:]]*"key"[[:space:]]*[:=]" {
        sub(/^[^:=]+[:=]/, "")
        if (ltrim == 1) sub(/^[[:space:]]+/, "")
        if (rtrim == 1) sub(/[[:space:]]+$/, "")
        print
      }' "$configfile"
  fi
}

# Function to find which index matches "$1" in a array passed as $2...
arr_index() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "usage: ${FUNCNAME[0]} needle stack1 [stack2 stack3...]" ; echo "-1" ; return 1 ; }
  local needle=$1 i=0
  shift
  local arr=("$@")
  for (( i = 0 ; i < $# ; i++ )) do
    if [[ "$needle" == "${arr[i]}" ]]; then
      echo "$i"
      return 0
    fi
  done
  echo "-1"
  return 1
}

# Function to calculate the number of seconds from docker's CREATED field
calc_seconds() { # utility_function
  [[ ! "$1" =~ ^[0-9]+" "[^[:space:]]+" ago"$ ]] && return 1

  case "$1" in
    *second*) echo "${1%% *}" ;;
    *minute*) echo $((${1%% *}*60)) ;;
    *hour*)   echo $((${1%% *}*60*60)) ;;
    *day*)    echo $((${1%% *}*60*60*24)) ;;
    *week*)   echo $((${1%% *}*60*60*24*7)) ;;
    *month*)  echo $((${1%% *}*60*60*24*30)) ;;
    *)        echo $((${1%% *}*60*60*24*365)) ;;  # everything else should be years
  esac
}

# Function to check if a program exists and print an error message
check_prog() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { echo "usage: check_prog prog" ; return 1 ; }
  local dirs dir prog=$1 func=" (needed for ${FUNCNAME[1]})"
  [[ -n "$2" ]] && func=" (needed for $2)"
  [[ -z "$2" && "${FUNCNAME[1]}" == "main" ]] && unset func
  IFS=: read -ra dirs <<< "$PATH"
  for dir in "${dirs[@]}"; do
    if [[ -x "$dir"/"$prog" ]]; then
      return 0
    fi
  done
  log -e "$prog command not found$func"
  return 1
}

# Function to get a list of docker checks with name|image|state|age
# shellcheck disable=SC2120
docker_checks() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  ! command -v docker &> /dev/null && { log -d "docker command not found" ; return 1 ; }
  local checks=() check name image state
  while IFS='|' read -r name image state; do
    [[ "$state" != "running" ]] && continue
    check=$(image_search -c "$image")
    [[ -z "$check" ]] && log -v "Could not find check for $name" >&2
    checks+=("$check")
  done < <(docker container ls --format='{{.Names}}|{{.Image}}|{{.State}}')
  mapfile -t checks < <(printf '%s\n' "${checks[@]}" | sort -u)
  printf '%s\n' "${checks[@]}"
}

# Function to drop privileges and run this program as $exec_user
drop_privs() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# < 2 )) && { log -d "Not enough arguments" ; return 1 ; }
  local exec_user=$1 user_id=0
  shift
  user_id=$(id -u 2> /dev/null)
  if [[ "$user_id" != "0" ]] || ! id "$exec_user" &> /dev/null; then
    log -d -d -d "Executing user must be root (is $user_id) and $exec_user must exist"
    return 1
  fi
  local args=() prev=false arg full_command
  for arg in "$@"; do
    [[ "$arg" =~ ^-(u|c)$ ]] && prev=true && continue
    $prev && prev=false && continue
    args+=("$arg")
  done

  full_command=$(realpath "$0")
  echo "Dropping privileges to $exec_user to run '$full_command ${args[*]}'"

  cd /
  if command -v sudo &> /dev/null; then
    exec sudo -i -u "$exec_user" "$full_command" "${args[@]}"
  else
    case "$(uname -s)" in
      Linux)
        if command -v runuser &> /dev/null; then
          exec runuser -l -u "$exec_user" -- "$full_command" "${args[@]}"
        else
          exec su - -s "$(command -v bash)" "$exec_user" -c "$full_command ${args[*]}"
        fi ;;
      *)
        exec su - -m "$exec_user" -c "$full_command ${args[*]}" ;;
    esac
  fi
}

# Function to ensure that a check function exists
function_exists() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Missing argument for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "$1" == "$PROGNAME" ]] && return 0
  local flist=()
  flist+=("${function_list[@]}")
  flist+=("${function_alias_list[@]}")
  (( debug >= 3 )) && set -x
  [[ ! " ${flist[*]} " == *" "$1" "* ]] && { set +x ; return 1; }
  set +x
  return 0
}

# Function to generate an authstring for curl from a token in the config file
# Called with 'gen_authstring github'
gen_authstring() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Site parameter missing" ; return 1 ; }
  local section=$1 key=${2:-token} file=${3:-$rcfile}
  [[ ! -s "$file" ]] && { log -e "Cannot read config file ($file)" ; return 1 ; }
  local token authstring=()
  mapfile -t token < <(get_config_value "$file" "$section" "$key")
  if (( ${#token[@]} > 0 )); then
    echo "-H"
    echo "Authorization: Bearer ${token[-1]}"
    return 0
  fi
  log -d -d -d "Cannot get '$section' $key from '$file'"
  return 1
}

# Function to return the running system architecture
get_arch() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  if command -v dpkg > /dev/null 2>&1; then
    dpkg --print-architecture
  else
    case $(uname -m) in
      x86_64)
        echo amd64 ;;
      aarch64|armv7l)
        echo arm64 ;;
      *)
        echo error ;;
    esac
  fi
}

# Print the length of the longest element
get_longest() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} from ${FUNCNAME[1]}"
  (( $# == 0 )) && { echo 0 ; return 0 ; }
  local max=0 s
  for s in "$@"; do
    (( ${#s} > max )) && max=${#s}
  done
  echo "$max"
}

# Function to wrap mktemp and add tmpfile/tmpdir to TEMPFILES
maketemp() { # utility_function
  local tmpfile args=()
  local OPTIND=1 OPTARG opt
  # Pass all args back to mktemp except -p (and arg)
  while getopts ":p:dqut:" opt; do
    case "$opt" in
      d|q|u) args+=("-$opt") ;;
      t) args+=("-$opt" "$OPTARG") ;;
      p) [[ "$OPTARG" == -* ]] && args+=("$OPTARG") ;;
      *) ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  # Re-set args
  set -- "${args[@]}" "$@"
  tmpfile=$(mktemp -p "$TEMPDIR" "$@")
  echo "$tmpfile"
}

# Function to make sure program can write to cache directory/create directory
prepare_cache_dir() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} from ${FUNCNAME[1]}"
  $CACHE_DIR_PREPARED && return 0
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local cache_dir=$1 cache_parent
  if [[ -n "$cache_dir" ]]; then
    if [[ ! -d "$cache_dir" ]]; then
      [[ -e "$cache_dir" ]] && log -e "Cache directory '$cache_dir' exists but is not a directory" && exit 1
      mkdir -p "$cache_dir" &> /dev/null
      # If cache_dir does not exist, ensure parent is writable
      cache_parent=$(realpath "$cache_dir")
      cache_parent=${cache_parent%/*}
      if [[ ! -w "$cache_parent" ]]; then
        log -e "Cannot write to $cache_parent to create cache dir: $cache_dir"
        exit 1
      fi
    else
      # If cache_dir exists, make sure it is writable
      if [[ ! -w "$cache_dir" ]]; then
        log -e "Cannot write to cache dir: $cache_dir"
        exit 1
      fi
    fi
    [[ ! -d "$cache_dir" ]] && mkdir -p "$cache_dir"
  fi
  log -d "Cache directory prepared"
  CACHE_DIR_PREPARED=true
}

# Function to print arrays
# Usage: print_list [-n 14] -l "Label" "${arr1[@]}"
# Where -n tells print_list to pad for each string being 14 characters
# -n could be passed with $(get_longest "${arr1[@]}" "${arr2[@]}" ...) to have multiple lists line up
print_list() { # utility_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  local opt OPTARG OPTIND=1
  local maxlen=0 mark_sudo=false single=false label="List Items" arr=()
  while getopts ":n:l:sm1" opt; do
    case "$opt" in
      n) [[ ! $OPTARG =~ ^[0-9]+$ ]] && { log -e "-n requires a number" ; return 1 ; } || maxlen=$OPTARG ;;
      l) label=$OPTARG ;;
      s) mark_sudo=true ;;
      m) single=false ;;
      1) single=true ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( $# == 0 )) && return 1

  (( maxlen == 0 )) && maxlen=$(get_longest "$@")
  local term_width=100
  term_width=$(tput cols 2>/dev/null) || term_width=100
  local col_width=$(( maxlen + 2 ))   # +2 for minimum padding
  local indent=4
  local usable=$(( term_width - indent ))
  local num_cols=$(( usable / col_width ))
  (( num_cols < 1 )) && num_cols=1
  ( (( num_cols < 1 )) || $single ) && num_cols=1

  # Sort array
  mapfile -t arr < <(printf '%s\n' "$@" | sort -u)

  local item_type="items"
  [[ "$label" == *" "* ]] && item_type=${label##* }
  item_type=$(echo "$item_type" | tr '[:upper:]' '[:lower:]')

  printf "%s (%s %s):" "$label" "$#" "$item_type"
  local i=0
  for (( i = 0; i < ${#arr[@]}; i++ )); do
    (( i % num_cols == 0 )) && printf '\n%*s' "$indent" ""
    unset needs_sudo
    $mark_sudo && for regex in "${sudo_regexes[@]}"; do
      [[ "${arr[i]}" =~ $regex ]] && needs_sudo=" *"
    done
    printf '%-*s' "${col_width}" "${arr[i]}$needs_sudo"
  done
  printf '\n\n'
}

# Function to allow a user to run a specific function with sudo
sudo_exec() { # utility_function
  local saved_debug=$debug saved_trap
  saved_trap=$(trap -p RETURN)
  trap 'debug="$saved_debug";${saved_trap:-trap - RETURN}' RETURN
  local arg args=() dflags=()
  debug=0

  # Check to see if this is called with -d
  for arg in "$@"; do
    [[ "$arg" == "-d" ]] && { (( debug++ )) ; dflags+=(-d) ; continue ; }
    args+=("$arg")
  done
  set -- "${args[@]}"

  cd /
  log -d "Running: ${FUNCNAME[0]} $* ${dflags[*]}"

  export SUDO_EXEC=true
  # Check to see if function is in app_list
  [[ " ${helper_list[*]} ${app_list[*]} " != *" $1 "* ]] && { log -e "Invalid app_check function: $1" ; return 1 ; }
  log -d "Executing '$1 ${*:2} ${dflags[*]}' as $(id -un)"
  # Execute check function
  export debug
  "$1" "${@:2}" "${dflags[@]}"
}

# Function to fold the usage lines
usage_fold() { # utility_function
  local opt OPTARG OPTIND=1
  local first=2 second=4 cols=100 first_set=false second_set=false
  cols=${COLUMNS:-$(tput cols < /dev/tty 2>/dev/null || echo 100)}

  while getopts ":f:s:c:" opt; do
    case "$opt" in
      f) [[ $OPTARG =~ ^[0-9]+$ ]] && first=$OPTARG  && first_set=true ;;
      s) [[ $OPTARG =~ ^[0-9]+$ ]] && second=$OPTARG && second_set=true ;;
      c) [[ $OPTARG =~ ^[0-9]+$ ]] && cols=$OPTARG ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  # If -f passed but not -s, update second to be first + 2
  ! $second_set && $first_set && second=$(( first + 2 ))

  # Set up padding
  local pad1 pad2
  printf -v pad1 '%*s' "$first" ''
  printf -v pad2 '%*s' "$second" ''

  # Pass output through fold with settings
  local string clean
  if (( $# > 0 )); then
    string="$*"
  elif [[ ! -t 0 ]]; then
    string=$(cat)
  else
    return 1
  fi
  clean=$(printf '%s' "$string" | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g')
  cols=$(( cols + ${#string} - ${#clean} - 1 ))

  # Deal with 2 level folds properly
  local first_width=$(( cols - first ))
  local rest_width=$(( cols - second ))

  # Fold at first-line width, split head from tail
  local folded line1 rest
  folded=$(printf '%s\n' "$string" | fold -s -w "$first_width")
  line1=$(printf '%s\n' "$folded" | head -1)
  rest=$(printf '%s\n' "$folded" | tail -n +2 | tr '\n' ' ' | sed 's/[[:space:]]*$//')

  # Print first line
  printf '%s\n' "${pad1}${line1}"
  # Print remaining lines
  if [[ -n "$rest" ]]; then
    printf '%s\n' "$rest" | fold -s -w "$rest_width" | sed "s/^/$pad2/"
  fi
}

## helper functions
alpine_docker_package() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  if [[ -z "$COMPOSE_FILE" ]]; then
    log -e "${FUNCNAME[1]}: COMPOSE_FILE not set"
    [[ -n "$SUDO_USER" ]] && log -e "Check sudoers: add COMPOSE_FILE to env_keep for $LOGNAME"
    return 1
  fi
  [[ ! -r "$COMPOSE_FILE" ]] && { log -e "${FUNCNAME[1]}: Cannot read compose file ($COMPOSE_FILE)" ; return 1 ; }
  local package=$1 containername out
  log -d "Checking alpine_docker_package for $package"
  containername=$(_docker_container_search "${FUNCNAME[1]%_docker}") || return 1
  [[ -z "$package" ]] && package=$containername
  log -d -d "Executing docker compose -f $COMPOSE_FILE exec -u nobody $containername apk list --installed"
  out=$(docker compose -f "$COMPOSE_FILE" exec -u nobody "$containername" apk list --installed 2>&1)
  log -d -d -d "docker compose output: $out"
  log -d -d "Searching output for '$package'"
  [[ -n "$out" ]] && awk -v p="$package" '$0 ~ "^" p {sub("^" p "-?","",$1);print $1;exit}' 2>/dev/null <<< "$out"
}

alpine_repo_package() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog xmllint "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1

  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local pkg=$1 url out

  if [[ -z "$ALPINE_VER" ]]; then
    ALPINE_VER=$(curl -s "https://pkgs.alpinelinux.org/packages" \
      | xmllint --html --xpath '//select[@id="branch"]/option/text()' - 2>/dev/null | \
      awk '/v[0-9]/{gsub(/^ +/,"");gsub(/ +$/,"");print}' | \
      sort -V | \
      tail -n1)
  fi

  [[ -z "$ALPINE_VER" ]] && { log -q "Warning: Could not determine alpine version" ; return 1 ; }

  url="https://pkgs.alpinelinux.org/packages?name=$pkg&branch=$ALPINE_VER&arch=x86_64"
  log -d "DEBUG (${FUNCNAME[0]}): URL = $url"

  out=$(maketemp)
  curl -sLo "$out" "$url"
  log -d -d "Curl output: $(cat "$out")"
  [[ ! -s "$out" ]] && return 1
  out=$(xmllint --html --xpath '//strong[@aria-label="Package version"]/text()' "$out" 2>/dev/null)
  log -d -d "xmllint output: $out"
  [[ -n "$out" ]] && sort -V <<< "$out" \
    | tail -n1
}

_aur_package() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local pkg=$1 out

  if command -v aur &> /dev/null; then
    log -d -d "Using aur command for $1"
    out=$(aur query -t info "$1")
    log -d -d -d "aur query output: $out"
    out=$(jq -rn --argjson j "$out" '$j.results[].Version' 2> /dev/null)
    log -d -d -d "jq output: $out"
  else
    log -d -d "Using curl/awk via github for $1"
    out=$(maketemp)
    curl -sLo "$out" "https://raw.githubusercontent.com/archlinux/aur/refs/heads/$pkg/PKGBUILD"
    log -d -d -d "Curl output: $(cat "$out")"
    [[ -s "$out" ]] && out=$(awk -F= '
        /^_major=/ { m = $2 }
        /^_subver=/ { s = $2 }
        /^pkgver=/ { pv = $2 }
        /^pkgrel=/ { pr = $2 }
      END {
        if (m != "" && s != "")
          o=sprintf("%s.%s-%s\n",m,s,pr)
        else if (pv != "")
          o=sprintf("%s-%s\n",pv,pr)
        gsub(/"/,"",o)
        print o
      }' "$out")
  fi
  [[ -z "$out" ]] && return 1
  echo "$out"
  return 0
}

_auto_check() { # helper_function
  # log -d -d -d "Running: ${FUNCNAME[0]} $*"
  log -d "Running: ${FUNCNAME[0]} $*"

  local search=() project tmp jqfilter sedstring skipverfilter=false
  local opt OPTARG OPTIND=1
  while getopts ":p:t:j:r:s:S:vV" opt; do
    case "$opt" in
      p) project=$OPTARG ;;
      t) tag=$OPTARG ;;
      j) jqfilter=$OPTARG ;;       # Uses last one given
      r) search+=(-r "$OPTARG") ;;
      s) search+=(-s "$OPTARG") ;;
      S) sedstring=$OPTARG ;;      # Uses last one given
      v) skipverfilter=true ;;
      V) skipverfilter=false ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local check=$1

  log -d -d check=$check
  log -d -d tag=$tag
  log -d -d project=$project
  log -d -d "search=${search[*]}"
  log -d -d sedstring=$sedstring
  log -d -d skip=$skipverfilter

  [[ "$tag" =~ (aur_latest|command|docker_inspect|docker_inspect_image|pacman) ]] && skipverfilter=true

  case "$tag" in
    aur_latest) out=$(_aur_package "$project") ;;
    cat) out=$(cat "$project" 2> /dev/null) ;;
    codeberg|codeberg_latest) out=$(_codeberg_project "$project") ;;
    command) out=$(_command_check "$project") ;;
    docker_exec) out=$(_docker_exec "$project") ;;
    docker_inspect) out=$(_docker_inspect "$project") ;;
    docker_printenv) out=$(_docker_printenv "$project") ;;
    docker_tags|docker_tags_latest) out=$(_docker_tags "${search[@]}" "$project") ;;
    flatpak) out=$(_flatpak_version "$project") ;;
    flatpak_latest) out=$(_flatpak_appstream "$project") ;;
    forgejo|forgejo_latest) out=$(_codeberg_project -f "$project") ;;
    github|github_latest) out=$(_github_project "$project") ;;
    github_tags|github_tags_latest) out=$(_github_tags "${search[@]}" "$project") ;;
    gitlab|gitlab_latest) out=$(_gitlab_project "$project") ;;
    pacman)
      check_prog pacman "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
      out=$(pacman -Q "$project" 2> /dev/null)
      log -d -d -d "pacman output: $out"
      out=$(awk '{for (i = 2 ; i <= NF ; i++) o = o " " $i }END{sub(/^ /,"",o);printf "%s\n",o}' <<< "$out")
      log -d -d -d "awk output: $out"
      ;;
    *)
      log -e "Unknown package check: $tag"
      return 1 ;;
  esac

  # Apply jq filter, if set
  if [[ -n "$out" && -n "$jqfilter" ]]; then
    log -d -d -d "Using jq -rn --argjson j '\$out' '$jqfilter'"
    out=$(jq -rn --argjson j "$out" "\$j | $jqfilter")
    log -d -d -d "jq output: $out"
  fi

  # Apply sedstring, if set
  if [[ -n "$out" && -n "$sedstring" ]]; then
    log -d -d -d "Using sed -r 's$sedstring'"
    out=$(sed -r "s$sedstring" <<< "$out")
    log -d -d -d "sed output: $out"
  fi

  # Apply versionfilter if $skipverfilter is false
  [[ -n "$out" ]] && ! $skipverfilter && out=$(_version_filter <<< "$out")

  # If there is still output, print it
  [[ -n "$out" ]] && echo "$out" && return 0

  # Default to printing an error message and returning 1
  log -e "Could not determine version for $check"
  return 1
}

_command_check() { # helper_function
  # log -d -d -d "Running: ${FUNCNAME[0]} $*"
  log -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local cmd=${1%/command}
  if command -v "$cmd" &> /dev/null; then
    log -d -d "Attemping '$cmd --version'"
    if out=$("$cmd" --version 2>&1 | _version_filter); then
      echo "$out"
      return 0
    fi
    log -d -d "Attemping '$cmd -V'"
    if out=$("$cmd" -V 2>&1 | _version_filter); then
      echo "$out"
      return 0
    fi
    log -d -d "Attemping '$cmd version'"
    if out=$("$cmd" version 2>&1 | _version_filter); then
      echo "$out"
      return 0
    fi
    log -d -d "Attemping '$cmd --help'"
    if out=$("$cmd" --help 2>&1 | _version_filter); then
      echo "$out"
      return 0
    fi
    log -e "Could not determine version for $1"
    return 1
  else
    log -e "Could not find command '$cmd' for $1"
    return 1
  fi
}

_codeberg_project() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  local site="https://codeberg.org" section=codeberg out
  local opt OPTARG OPTIND=1
  while getopts ":f" opt; do
    case "$opt" in
      f) section=forgejo
         site="https://code.forgejo.org"
         ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( $# == 0 )) && { log -d "${FUNCNAME[0]} requires a project argument" ; return 1 ; }

  local uri="$site/$1/releases/latest"
  log -d "uri: $uri"

  local authstring=()
  mapfile -t authstring < <(gen_authstring "$section")

  out=$(maketemp)
  curl "${authstring[@]}" --no-progress-meter -o "$out" "$uri"
  log -d -d -d "Curl output: $(cat "$out")"
  if [[ -s "$out" ]]; then
    awk -F'["/]' '{print $7;exit}' "$out"
    return 0
  fi
  log -e "Invalid curl output"
  return 1
}

# To use this function, there must be a section in $rcfile
# The section should be named after the check using curl_api
# The section must include url and optionally username & password or apikey
curl_api() { # helper_function
  log -d "Running ${FUNCNAME[0]} for ${FUNCNAME[1]}"
  local url username password apikey out

  # shellcheck disable=SC2154
  [[ ! -s "$rcfile" ]] && { log -e "Cannot read $rcfile for ${FUNCNAME[1]}" ; return 1; }
  mapfile -t url      < <(get_config_value "$rcfile" "${FUNCNAME[1]}" url)
  mapfile -t username < <(get_config_value "$rcfile" "${FUNCNAME[1]}" username)
  mapfile -t password < <(get_config_value "$rcfile" "${FUNCNAME[1]}" password)
  mapfile -t apikey   < <(get_config_value "$rcfile" "${FUNCNAME[1]}" apikey)

  out=$(maketemp)
  (( ${#url[@]} == 0 ))      && { log -e "Could not read ${FUNCNAME[1]} URL from $rcfile" ; return 1 ; }
  if (( ${#apikey[@]} > 0 )); then
    curl -sLo "$out" -X GET -H \
      "Authorization: Bearer ${apikey[-1]}" \
      "${url[-1]}"
  elif (( ${#username[@]} > 0 || ${#password[@]} > 0 )); then
    (( ${#username[@]} == 0 )) && { log -e "Could not read ${FUNCNAME[1]} Username from $rcfile" ; return 1 ; }
    (( ${#password[@]} == 0 )) && { log -e "Could not read ${FUNCNAME[1]} Password from $rcfile" ; return 1 ; }

    curl -sLo "$out" -X GET -H \
      "Authorization: Basic $(printf '%s:%s' "${username[-1]}" "${password[-1]}"|base64|tr -d '\n')" \
      "${url[-1]}"
  else
    curl -sLo "$out" -X GET "${url[-1]}"
  fi
  log -d -d "Curl output: $out"
  cat "$out"
}

_docker_exec() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  # Run through sudo exec if necessary
  out=$(_use_sudo_exec "$@") ; ret=$?
  case $ret in 0) echo "$out" ; return 0 ;; 2|4) ;; *) log -d "_use_sudo_exec error $ret" ; return 1 ;; esac

  local image image_search command=() out
  if (( $# == 1 )); then
    if [[ "$1" == */* ]]; then
      image_search=${1%%/*}
      command=${1#*/}
    else
      image_search=$1
      command=($*)
    fi
  else
    image_search=$1
    shift
    command=("$@")
  fi

  container=$(_docker_container_search "$image_search")
  log -d -d "container=$container"
  [[ -z "$container" ]] && { log -e "Could not determine container for '$1'" ; return 1 ; }

  log -d -d "Executing: docker exec -t -u nobody $container ${command[*]}"
  out=$(docker exec -t -u nobody "$container" ${command[*]})
  log -d -d "docker exec output = $out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
  return 1
}

docker_compose_exec() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  if [[ -z "$COMPOSE_FILE" ]]; then
    log -e "${FUNCNAME[1]}: COMPOSE_FILE not set"
    [[ -n "$SUDO_USER" ]] && log -e "Check sudoers: add COMPOSE_FILE to env_keep for $LOGNAME"
    return 1
  fi
  [[ ! -r "$COMPOSE_FILE" ]] && { log -e "${FUNCNAME[1]}: Cannot read compose file ($COMPOSE_FILE)" ; return 1 ; }
  local copy_mode=false i=0 containername
  [[ "$1" == "--copy" ]] && copy_mode=true && shift
  (( $# == 0 )) && return 1
  for (( i=1; i < ${#FUNCNAME[@]}; i++ )); do
    [[ ! ${FUNCNAME[-$i]} =~ ^(main|sudo_exec) ]] && break
  done
  containername=$(_docker_container_search "${FUNCNAME[-$i]%_docker}") || return 1
  log -d -d "containername = $containername"

  if ! $copy_mode; then
    log -d -d "Executing: docker compose -f $COMPOSE_FILE exec -u nobody $containername $*"
    docker compose -f "$COMPOSE_FILE" exec -u nobody "$containername" "$@"
    return "$?"
  else
    (( $# != 2 )) && echo "usage: ${FUNCNAME[1]} CONTAINER:SRC_PATH DEST_PATH" >&2 && return 1
    log -d -d "Executing: docker compose -f $COMPOSE_FILE cp $containername:$1 $2"
    out=$(docker compose -f "$COMPOSE_FILE" cp "$containername":"$1" "$2" 2>&1)
    ret=$?
    log -d -d -d "Docker compose output: $out"
    return "$ret"
  fi
}

docker_compose_cp() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  docker_compose_exec --copy "$@"
}

_docker_container_search() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  # Run through sudo exec if necessary
  out=$(_use_sudo_exec "$@") ; ret=$?
  case $ret in 0) echo "$out" ; return 0 ;; 2|4) ;; *) log -d "_use_sudo_exec error $ret" ; return 1 ;; esac

  local docker_ps out
  docker_ps=$(docker ps --format='{{.Names}}|{{.Image}}')
  log -d -d -d "docker ps output=$docker_ps"

  out=$(awk -F '|' -v s="$1" '$2 ~ s {print $1;exit}' <<< "$docker_ps")
  log -d -d "awk output searching image field=$out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }

  out=$(awk -F '|' -v s="$1" '$1 ~ s {print $1;exit}' <<< "$docker_ps")
  log -d -d "awk output search name field=$out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }

  return 1
}

_docker_image_search() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  # Run through sudo exec if necessary
  out=$(_use_sudo_exec "$@") ; ret=$?
  case $ret in 0) echo "$out" ; return 0 ;; 2|4) ;; *) log -d "_use_sudo_exec error $ret" ; return 1 ;; esac

  local docker_ps out
  docker_ps=$(docker ps --format='{{.Names}}|{{.Image}}')
  log -d -d -d "docker ps output=$docker_ps"

  # Search for image by container name
  out=$(awk -F '|' -v s="$1" '$1 == s {print $2;exit}' <<< "$docker_ps")
  log -d -d "awk output=$out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }

  # Search for image by image string
  out=$(awk -F '|' -v s="$1" '$2 ~ s {print $2;exit}' <<< "$docker_ps")
  log -d -d "awk output=$out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }

  return 1
}

_docker_inspect() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  local container out

  # Run through sudo exec if necessary
  out=$(_use_sudo_exec "$@") ; ret=$?
  case $ret in 0) echo "$out" ; return 0 ;; 2|4) ;; *) log -d "_use_sudo_exec error $ret" ; return 1 ;; esac

  container=$(_docker_container_search "$1")
  log -d -d "container=$container"
  [[ -z "$container" ]] && { log -e "Could not determine container for '$1'" ; return 1 ; }
  log -d "Running: docker inspect --format='{{index .Config.Labels \"org.opencontainers.image.version\"}}' $container"
  out=$(docker inspect --format='{{index .Config.Labels "org.opencontainers.image.version"}}' "$container" 2> /dev/null)
  log -d -d "org.opencontainers.image.version=$out"
  [[ -n "$out" ]] && { echo "$out" ; return 0 ; }

  out=$(docker inspect --format='{{index .Config.Labels "version"}}' "$container" 2> /dev/null)
  log -d -d "version label = $out"
  [[ -n "$out" ]] && grep -qP "$SEMVER_REGEX" <<< "$out" && { echo "$out" ; return 0 ; }

  out=$(_docker_image_search "$container")
  log -d -d "image_search = $out"
  local tag=${out##*:}
  log -d -d "image tag = $tag"
  if [[ -n "$out" && -n "$tag" && "$out" != "$tag" && ! "$out" =~ ^(latest|stable|main|master)$ ]]; then
    echo "$tag"
    return 0
  fi

  log -e "Could not determine version"
  return 1
}

docker_logs() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  if [[ -z "$COMPOSE_FILE" ]]; then
    log -e "${FUNCNAME[1]}: COMPOSE_FILE not set"
    [[ -n "$SUDO_USER" ]] && log -e "Check sudoers: add COMPOSE_FILE to env_keep for $LOGNAME"
    return 1
  fi
  [[ ! -r "$COMPOSE_FILE" ]] && { log -e "${FUNCNAME[1]}: Cannot read compose file ($COMPOSE_FILE)" ; return 1 ; }
  (( $# == 0 )) && { log -e "You must supply docker name" ; return 1 ; }
  [[ "$1" == "-h" ]] && { log "usage: docker_logs dockername" ; return 0 ; }

  # Run through sudo exec if necessary
  out=$(_use_sudo_exec "$@") ; ret=$?
  case $ret in 0) echo "$out" ; return 0 ;; 2|4) ;; *) log -d "_use_sudo_exec error $ret" ; return 1 ;; esac

  local name
  name=$(docker compose -f "$COMPOSE_FILE" ps --format '{{.Name}}' "$1" 2> /dev/null)
  docker logs "$name" 2> /dev/null
}

_docker_printenv() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog docker "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  # Run through sudo exec if necessary
  out=$(_use_sudo_exec "$@") ; ret=$?
  case $ret in 0) echo "$out" ; return 0 ;; 2|4) ;; *) log -d "_use_sudo_exec error $ret" ; return 1 ;; esac

  local image image_search variable out
  if (( $# == 1 )); then
    if [[ "$1" == */* ]]; then
      image_search=${1%%/*}
      variable=${1##*/}
    else
      image_search=$1
    fi
  else
    image_search=$1
    variable=$2
  fi
  image=$(_docker_image_search "$image_search")
  log -d -d "image_search=$image_search"
  log -d -d "variable=$variable"
  log -d -d "docker image=$image"
  [[ -z "$image" ]] && { log -e "Could not determine docker image for '$image_search'" ; return 1 ; }

  if [[ -n "$variable" ]]; then
    docker image inspect --format \
      '{{ range .Config.Env -}}
       {{ if (eq (index (split . "=") 0) "'"$variable"'") -}}
       {{ index (split . "=") 1 -}}
       {{ end -}}
       {{ end -}}' \
      "$image"
  else
    docker image inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$image"
  fi
}

_docker_tags() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1

  local OPTIND=1 OPTARG opt dosort=true removegrep searchgrep useskopeo=true
  while getopts ":r:R:p:s:S" opt; do
    case "$opt" in
      #  remove matchings strings from output, can be used more than once
      r) removegrep="$removegrep|$OPTARG" && removegrep="${removegrep#|}" ;;
      #  remove matchings strings from output using perl/grep, can be used more than once
      R) removegrep="$removegrep|$OPTARG" && removegrep="${removegrep#|}" ;;
      #  search for matching strings in output, can be used more than once
      s) searchgrep="$searchgrep|$OPTARG" && searchgrep="${searchgrep#|}" ;;
      # search for matching strings in output using perl/grep, can be used more than once
      p) searchperl="$searchperl|$OPTARG" && searchperl="${searchperl#|}" ;;
      #  Do not perform version sort
      S) dosort=false ;;
      *) log -w "Invalid flag ($OPTARG)" ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }

  local parts site org repo
  IFS=/ read -ra parts <<< "$1"
  case "${#parts[@]}" in
    1) site=docker.io ; repo=${parts[0]} ;;
    2) if [[ "${parts[0]}" == *"."* ]]; then
         site=${parts[0]} ; repo=${parts[1]}
       else
         site=docker.io ; org=${parts[0]} ; repo=${parts[1]}
       fi ;;
    3) site=${parts[0]} ; org=${parts[1]} ; repo=${parts[2]} ;;
    *) log -e "Invalid image name format ($1)" && return 1 ;;
  esac

  local token authfile
  local foundstop=false maxpages=200 pagesize=100 jqfilter='.results[].name'
  [[ "$site" == "quay.io" ]] && site=docker.io
  case "$site" in
    code.forgejo.org)
      mapfile -t username < <(get_config_value "$rcfile" forgejo username)
      mapfile -t token    < <(get_config_value "$rcfile" forgejo token)
      # uri="https://$site/v1/repos"
      ;;
    codeberg.org)
      mapfile -t username < <(get_config_value "$rcfile" codeberg username)
      mapfile -t token    < <(get_config_value "$rcfile" codeberg token)
      ;;
    docker.gitea.com)
      mapfile -t username < <(get_config_value "$rcfile" gitea username)
      mapfile -t token    < <(get_config_value "$rcfile" gitea token)
      ;;
    docker.io)
      mapfile -t username < <(get_config_value "$rcfile" dockerhub username)
      mapfile -t token    < <(get_config_value "$rcfile" dockerhub token)
      ;;
    ghcr.io|lscr.io)
      site=ghcr.io
      mapfile -t username < <(get_config_value "$rcfile" github username)
      mapfile -t token    < <(get_config_value "$rcfile" github token)
      jqfilter='.[].metadata.container.tags[] | select(. != "")'
      foundstop=true
      ;;
    *) log -e "Unknown site for skopeo ($site)" && return 1 ;;
  esac

  local cmdout authfile hash skopeoargs=()
  if ${useskopeo:-false} && command -v skopeo &> /dev/null; then
    if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
      authfile=$(maketemp)
      hash=$(printf "${username[-1]}:${token[-1]}" | base64 | tr -d '\n')
      printf '{\n\t"auths": {\n\t\t"%s": {\n\t\t\t"auth": "%s"\n\t\t}\n\t}\n}\n' "$site" "$hash" > "$authfile"
      skopeoargs=("--authfile=$authfile")
    fi

    log -d -d "Running: skopeo list-tags ${skopeoargs[*]:+ARGS }docker://$site/${org:+$org/}$repo"
    cmdout=$(maketemp)
    if (( debug > 2 )); then
      skopeo list-tags --debug "${skopeoargs[@]}" "docker://$site/${org:+$org/}$repo" > "$cmdout"
    else
      skopeo list-tags --debug "${skopeoargs[@]}" "docker://$site/${org:+$org/}$repo" > "$cmdout" 2> /dev/null
    fi
    log -d -d -d "Skopeo output: $(stat "$cmdout")"
    [[ -s "$cmdout" ]] && out=$(jq -r '.Tags.[]' "$cmdout" 2> /dev/null)
  else
    # Use curl
    local authstring=() curl_args=(-w "%{http_code}" --max-time 30)
    local uri hdrfile jq_count tag_search
    cmdout=$(maketemp)
    case "$site" in
      docker.io)
        if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
          log -d -d "Connecting to hub.docker.com to get token"
          out=$(maketemp)
          curl -sfo "$out" --max-time 15 -X POST -H "Content-Type: application/json" \
            -d "{\"username\": \"${username[-1]}\", \"password\": \"${token[-1]}\"}" \
            "https://hub.docker.com/v2/users/login"
          if [[ -s "$out" ]]; then
            out=$(jq -r '.token // ""' "$out" 2>/dev/null)
            [[ -n "$out" ]] && authstring=("-H" "Authorization: JWT $out") && \
              log -d -d "Using downloaded token"
          fi
        fi
        site=hub.docker.com
        uri="https://$site/v2/repositories"
        uri_path="tags/?page_size=100&page=1"
        jq_count='.results | length // 0'
        tag_search='.results[].name?'
        ;;
      ghcr.io)
        if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
          log -d -d "Connecting to ghcr.io to get token"
          out=$(maketemp)
          curl -sLo "$out" "https://ghcr.io/token?service=ghcr.io&scope=repository:${org:+$org/}$repo:pull" \
             -u "${username[-1]}:${token[-1]}"
          if [[ -s "$out" ]]; then
            out=$(jq -r '$j.token // ""' "$out" 2>/dev/null)
            [[ -n "$out" ]] && authstring=("-H" "Authorization: Bearer $out") && \
              log -d -d "Using downloaded token"
          fi
        fi
        hdrfile=$(maketemp)
        uri="https://$site/v2"
        uri_path="tags/list?n=1000"
        curl_args+=(-D "$hdrfile")
        jq_count='.tags | length // 0'
        tag_search='.tags[]?'
        ;;
      *)
        if (( ${#token[@]} > 0 && ${#username[@]} > 0 )); then
          log -d -d "Downloading auth token from $site"
          out=$(curl -si --max-time 10 "https://$site/v2/" 2> /dev/null)
          log -d -d -d "Curl output: $out"
          [[ -n "$out" ]] && out=$(awk -F: 'tolower($1) ~ /www-authenticate/ {sub("^.*"$1":[[:space:]]([Bb]earer )?*","");print}' <<< "$out" | tr -d '\r')
          log -d -d -d "awk output: '$out'"
          if [[ -n "$out" && $out =~ ^realm=\"[^\"]+\",service=\"[^\"]+\",scope=\"[^\"]+\"$ ]]; then
            eval "${out//,/;}"
            log -d -d -d "realm=$realm"
            log -d -d -d "service=$service"
            log -d -d -d "scope=$scope"
            if [[ -n "$realm" && -n "$service" && -n "$scope" ]]; then
              local token_url="$realm?service=$service&scope=$scope:${org:+$org/}$repo:pull"
              out=$(curl -sf --max-time 15 "$token_url")
              [[ -n "$out" ]] && out=$(jq -rn --argjson j "$out" '$j.token // .access_token // ""' 2> /dev/null)
              log -d -d -d "curl + jq output: $out"
              [[ -n "$out" ]] && authstring=("-H" "Authorization: Bearer $out") && \
                log -d -d "Using token for $site"
            fi
          fi
        fi
        hdrfile=$(maketemp)
        uri="https://$site/v2"
        uri_path="tags/list?n=1000"
        curl_args+=(-D "$hdrfile")
        jq_count='.tags | length // 0'
        tag_search='.tags[]?'
        ;;
    esac

    local done=false page=0 code=0 url="$uri/${org:+$org/}$repo/$uri_path"
    local results=() arr=() link next_path
    while [[ -n "$url" ]]; do
      (( page++ ))
      log -d -d "Running: curl -sLfo $cmdout ${curl_args[@]} ${authstring[@]} $url"
      code=$(curl -sLfo "$cmdout" "${curl_args[@]}" "${authstring[@]}" "$url") || \
        { log -e "Could not download from $site (page $page)" ; log -d -d -d "Curl output: $(cat "$cmdout")" ; break ; }
      if [[ "$code" == "401" ]]; then
        log -e "Authentication required"
        return 1
      elif [[ "$code" == "404" ]]; then
        log -e "Repo not found: $site/${org:+$org/}$repo"
        return 1
      elif [[ "$code" != 200 ]]; then
        log -e "HTTP error $code on page $page"
        break
      fi

      log -d -d "$site page $page: $(jq "$jq_count" "$cmdout" 2> /dev/null)"
      mapfile -t arr < <(jq -r "$tag_search" "$cmdout" 2> /dev/null)
      results+=("${arr[@]}")

      if [[ -n "$hdrfile" ]]; then
        link=$(grep -i '^link:' "$hdrfile" | tr -d '\r')
        if grep -q 'rel="next"' <<< "$link"; then
          next_path=$(grep -oP '<[^>]+>' <<< "$link" | tr -d '<>' | head -n 1)
          url="https://${site}${next_path}"
        else
          unset url
        fi
      else
        url=$(jq -r '.next // ""' "$cmdout" 2> /dev/null)
      fi
    done
    out=$(printf '%s\n' "${results[@]}")
  fi

  log -d -d -d "Jq output: $out"
  if [[ -n "$out" ]] && [[ -n "$searchgrep" ]]; then
    log -d "Searching for '${searchgrep#|}'"
    out=$(grep -E -- "(${searchgrep#|})" <<< "$out")
    log -d -d -d "searchgrep output: $out"
  fi
  if [[ -n "$out" ]] && [[ -n "$searchperl" ]]; then
    log -d "Searching for '${searchperl#|}'"
    out=$(grep -P -- "(${searchperl#|})" <<< "$out")
    log -d -d -d "searchperl output: $out"
  fi
  if [[ -n "$out" ]] && [[ -n "$removegrep" ]]; then
    log -d "Searching for '${removegrep#|}'"
    out=$(grep -Ev -- "(${removegrep#|})" <<< "$out")
    log -d -d -d "removegrep output: $out"
  fi
  if [[ -n "$out" ]] && [[ -n "$removeperl" ]]; then
    log -d "Searching for '${removeperl#|}'"
    out=$(grep -Pv -- "(${removeperl#|})" <<< "$out")
    log -d -d -d "removeperl output: $out"
  fi

  [[ -n "$out" ]] && $dosort && { log -d -d -d "Sorting" ; out=$(sort -V <<< "$out") ; }
  log -d -d -d "Grabbing the last line of output"
  tail -n1 <<< "$out"
}

_flatpak_appstream() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "$1" == "-h" ]] && { log "usage: ${FUNCNAME[0]} application_id" ; return 0 ; }

  local out
  out=$(maketemp)
  curl -sLo "$out" "https://flathub.org/api/v2/appstream/$1"
  log -d -d -d "Curl output: $(cat "$out")"
  [[ -s "$out" ]] && jq -r '.releases[0].version' "$out" 2> /dev/null
}

_flatpak_version() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog flatpak "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "$1" == "-h" ]] && { log "usage: ${FUNCNAME[0]} application_id" ; return 0 ; }

  local out
  out=$(flatpak list --columns=application,version)
  log -d -d -d "Flatpak list output: $out"
  [[ -n "$out" ]] && awk -v a="$1" '$1==a {print $NF;exit}' <<< "$out"
}

_github_project() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "$1" == "-h" ]] && { log "usage: ${FUNCNAME[0]} project/repo" ; return 0 ; }

  local authstring=() err errmsg out
  mapfile -t authstring < <(gen_authstring github)

  err=$(maketemp)
  out=$(maketemp)
  echo "Looking up latest release for $1 using github api" >> "$err"
  curl "${authstring[@]}" --no-progress-meter -Lo "$out" \
    "https://api.github.com/repos/$1/releases/latest" 2>> "$err"
  log -d -d -d "curl output: $(cat "$out")"
  out=$(jq -r '.tag_name' "$out" 2> /dev/null)
  errmsg=$(cat "$err")
  [[ -n "$errmsg" ]] && log -d "$1: $errmsg"
  echo "$out"
}

_gitlab_project() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  (( $# == 0 )) && { log -e "Argument required for ${FUNCNAME[0]}" ; return 1 ; }
  [[ "$1" == "-h" ]] && { log "usage: ${FUNCNAME[0]} project/repo" ; return 0 ; }

  local authstring=() err errmsg out
  mapfile -t authstring < <(gen_authstring gitlab)

  # URL-encode the owner/repo slug (GitLab requires this for namespaced projects)
  local encoded
  encoded=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=''))" "$1")

  err=$(maketemp)
  out=$(maketemp)
  echo "Looking up latest release for $1 using gitlab api" >> "$err"
  curl "${authstring[@]}" --no-progress-meter -Lo "$out" \
    "https://gitlab.com/api/v4/projects/${encoded}/releases/permalink/latest" 2>> "$err"
  log -d -d -d "curl output: $(cat "$out")"
  out=$(jq -r '.tag_name' "$out" 2> /dev/null)
  errmsg=$(cat "$err")
  [[ -n "$errmsg" ]] && log -d "$sw: $errmsg"
  echo "$out"
}

_github_tags() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  check_prog jq "${FUNCNAME[0]} via ${FUNCNAME[1]}" || return 1
  local version_sort=true output err out

  # aruments are processed this way to handle arguments with a leading dash
  while (( $# > 0 )); do
    case $1 in
      # remove matchings strings from output, can be specified more than once
      -r) [[ -n "$2" ]] && remove_grep="$remove_grep|$2" && shift 2 ;;
      # search for matching strings in output, can be specified more than once
      -s) [[ -n "$2" ]] && search_grep="$search_grep|$2" && shift 2 ;;
      # Do not perform version sort
      -S) version_sort=false && shift ;;
      -h|--help) log "usage: github_tags project/repo" && return 0 ;;
      -*)        log -e "Unknown option $1" && return 1 ;;
      *) # This should be the project_name
         if [[ -z "$project_name" ]]; then
           project_name=$1
         else
           log -e "Multiple project names provided"
           exit 1
         fi
         shift
         ;;
    esac
  done
  [[ -z "$project_name" ]] && { log -e "You must supply project/repo" ; return 1 ; }

  local authstring=()
  mapfile -t authstring < <(gen_authstring github)

  err=$(maketemp)
  local maxpages=20 page=0 done=false
  while ! $done && (( page < maxpages )); do
    page=$(( page + 1 ))
    echo "Looking up tags for $project_name using github_api" >> "$err"
    out=$(maketemp)
    curl "${authstring[@]}" --no-progress-meter -Lo "$out" \
      "https://api.github.com/repos/$project_name/tags?per_page=100&page=$page" 2> "$err"
    [[ ! -s "$out" || "$(jq 'length' 2> /dev/null "$out")" -eq 0 ]] && done=true && break
    out=$(jq -r '.[].name' "$out" 2> /dev/null)
    log -d -d -d "Jq output: $out"
    [[ -n "$search_grep" ]] && out=$(grep -E -- "(${search_grep#|})" <<< "$out")
    log -d -d -d "search grep output: $out"
    [[ -n "$remove_grep" ]] && out=$(grep -Ev -- "(${remove_grep#|})" <<< "$out")
    log -d -d -d "remove grep output: $out"
    output="${output# } $out"
  done
  [[ -z "${output# }" ]] && { log -e "Could not find github tags data for $project_name" ; return 1 ; }

  $version_sort && output=$(sort -V <<< "${output# }")
  output=$(tail -n1 <<< "${output# }")

  errmsg=$(cat "$err")
  [[ -n "$errmsg" ]] && log -d "$1: $errmsg"
  echo "$output"
}

# This function cannot use curl_api because of the dynamic URL with $1
myaur_package() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  (( $# == 0 )) && { log -e "Package name required for ${FUNCNAME[0]}" ; return 1 ; }
  local url out
  [[ ! -s "$rcfile" ]] && { log -e "Cannot read $rcfile for ${FUNCNAME[0]}" ; return 1; }
  mapfile -t url < <(get_config_value "$rcfile" private_aur url)
  (( ${#url[@]} == 0 )) && { log -e "Could not read ${FUNCNAME[0]} URL from $rcfile" ; return 1 ; }
  out=$(curl -s "${url[-1]}/raw/branch/main/$1/PKGBUILD")
  log -d -d -d "Curl output: $out"
  [[ -n "$out" ]] && awk -F= '/^pkgver=/{pv=$2}/^pkgrel=/{pr=$2}END{printf "%s-%s\n",pv,pr;exit}' <<< "$out"
}

# Function to validate STDIN contains a version string and
# prints that string as output, returning 0 for success and 1 for failure
# Example usage: if out=$(command | _version_filter); then
_version_filter() { # helper_function
  log -d -d -d "Running: ${FUNCNAME[0]} $*"
  out=$(grep -oP "$SEMVER_REGEX")
  if grep -oPq "^$SEMVER_REGEX$" <<< "$out"; then
    echo "$out" | head -n1
    return 0
  fi
  return 1
}

# Function to determine if function should be run with sudo_exec and do it if so
_use_sudo_exec() { # helper_function
  $SUDO_EXEC && { log -d "Already running sudo_exec" ; return 2 ; }
  log -d -d -d "Running: ${FUNCNAME[0]} for ${FUNCNAME[1]}"

  for regex in "${sudo_regexes[@]}"; do
    if [[ "${FUNCNAME[1]}" =~ $regex ]]; then
      used_sudo=true
      log -v -v "Using sudo as $sudo_user to ${FUNCNAME[1]}"
      for (( i = 0 ; i < debug ; i++ )); do debug_args+=("-d"); done
      rp=$(realpath "$0")
      log -d "[sudo] running 'sudo -n -u $sudo_user $rp -X ${FUNCNAME[1]} $1 ${debug_args[*]}'"
      out=$(sudo -n -u "$sudo_user" "$rp" -X "${FUNCNAME[1]}" "$1" "${debug_args[@]}")
      log -d "sudoexec ${FUNCNAME[1]} returned out='$out'"
      [[ -n "$out" ]] && { echo "$out" ; return 0 ; }
      return 3
    fi
  done
  return 4
}

