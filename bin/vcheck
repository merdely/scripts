librewolf() {
  if [[ -x /usr/bin/librewolf ]]; then
    /usr/bin/librewolf --version | awk '{ print $NF;exit }'
  elif [[ -x /usr/local/bin/librewolf ]]; then
    /usr/local/bin/librewolf --version | awk '{ print $NF;exit }'
  elif [[ -x /Applications/LibreWolf.app/Contents/MacOS/librewolf ]]; then
    /Applications/LibreWolf.app/Contents/MacOS/librewolf --version | awk '{ print $NF;exit }'
  else
    printf '{ "Error": "Librewolf not found" }'
  fi
}

librewolf_flatpak() {
