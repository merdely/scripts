IMAGE_SEARCH+=("jitsi_meet_docker|(jitsi/web|jitsi-meet-web)")
jitsi_meet_docker() {
  local v
  v=$(docker_inspect)
  if [[ -n "$v" ]]; then
    "stable/jitsi-meet_$v"
  else
    docker_inspect -i | sed -r 's/stable-/stable\/jitsi-meet_/'
  fi
}

jitsi_meet_docker_latest() {
  docker_tags -s '^stable-[0-9]+' jitsi/web | sed -r 's#^(stable)-#\1/jitsi-meet_#'
}

jitsi_meet_latest() { # no_auto
  github_project jitsi/jitsi-meet
}

