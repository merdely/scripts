#!/usr/bin/env bash

progname=${0##*/}

usage() {
  echo "usage: $progname [-h] [-c] [-b] [-m|-2|-5|-B] passwdfile username [password] | -n username [password]"
  echo "  -h         : This help text"
  echo "  -c         : Clear passwd file before writing to it"
  echo "  -n         : Print password line to stdout instead of updating a file"
  echo "  -m         : Use MD5 hash (default)"
  echo "  -2         : Use SHA-256 hash (more secure)"
  echo "  -5         : Use SHA-512 hash (more secure)"
  echo "  -B         : Use bcrypt hash (very secure)"
  echo "  -b         : Read password from command line instead of prompting"
  echo "  -C N       : Not implemented"
  echo "  -r N       : Not implemented"
  echo "  passwdfile : password file"
  echo "  username   : user"
  exit 1
}

clearfile=false
justprint=false
prompt=true
hash_set=false
hash="-bcrypt"


while getopts ":hbcnm25BC:r:" opt; do
  case $opt in
    c)
      clearfile=true
      ;;
    b)
      prompt=false
      ;;
    n)
      justprint=true
      ;;
    m)
      $hash_set && echo "Error: Only one of -m, -2, -5, and -B can be used" && exit 1
      hash="-apr1"
      hash_set=true
      ;;
    2)
      $hash_set && echo "Error: Only one of -m, -2, -5, and -B can be used" && exit 1
      hash="-5"
      hash_set=true
      ;;
    5)
      $hash_set && echo "Error: Only one of -m, -2, -5, and -B can be used" && exit 1
      hash="-6"
      hash_set=true
      ;;
    B)
      $hash_set && echo "Error: Only one of -m, -2, -5, and -B can be used" && exit 1
      hash="bcrypt"
      hash_set=true
      ;;
    r|C)
      ;;
    h|\?) usage
      ;;
  esac
done
shift $((OPTIND -1))

if ! $prompt && [ -z "$2" ]; then
  echo "Error: -b given, but no password on the command line"
  exit 1
fi

if [ $hash = bcrypt ]; then
  command -v bcrypt > /dev/null 2>&1
  [ $? -eq 0 ] && { echo "Error: mkpasswd command not installed" >&2; exit 1; }
  if $prompt; then
    IFS= read -rsp "Password: " pass1
    echo
    IFS= read -rsp "Verifying - Password: " pass2
    echo
    if [ "$pass1" != "$pass2" ]; then
      echo "Verify failure"
      exit 1
    fi
  else
    pass1=$2
  fi
  newpasswd=$(mkpasswd -m $hash -s <<< "$pass1")
else
  if $prompt; then
    newpasswd=$(openssl passwd $hash)
  else
    newpasswd=$(openssl passwd $hash -stdin <<< "$2")
  fi
fi
if ! $justprint; then
  [ -z "$2" ] && usage

  passwdfile=$1
  username=$2

  [ -e $passwdfile -a ! -w $passwdfile ] && echo "$progname: $passwdfile: Permission denied" && exit 1
  ! $clearfile ] && [ ! -e $passwdfile ] && echo "$progname: $passwdfile: File does not exist" && exit 1
  touch $passwdfile 2> /dev/null
  [ $? != 0 ] && $clearfile && echo "$progname: cannot create $passwdfile: Permission denied" && exit 1
  $clearfile && cp /dev/null $passwdfile

  if [ $? = 0 ]; then
    ! $clearfile && sed -i "/^$username:/d" $passwdfile
    echo "$username:$newpasswd" | tee -a $passwdfile > /dev/null
  fi
else
  [ -z "$1" ] && usage
  username=$1
  [ $? = 0 ] && echo "$username:$newpasswd"
fi
