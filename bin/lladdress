#!/bin/sh

# http://ben.akrin.com/?p=1347

mac_to_ipv6 () {
        IFS=':'; set $1; unset IFS
        echo ":$(printf %x $((0x$1 ^ 2)))$2:${3}ff:fe$4:$5$6"
}

progname=${0##*/}
progname=${progname%.sh}
if [ "$1" = "" ]; then
	echo "Usage: $progname NIC|MAC"
	exit 1
fi

if [ ${#1} = 17 ]; then
        MAC=$1
else
	ifconfig $1 > /dev/null 2>&1
	if [ $? != 0 ]; then
		echo "Error: $1 is not a recognized network interface." >&2
		exit 1
	fi
	if [ `uname -s` = "OpenBSD" ]; then
        	MAC=`ifconfig $1 | awk '/^\tlladdr/ { print $2 }'`
	fi
	if [ `uname -s` = "Linux" ]; then
		MAC=`ifconfig $1 | awk '$4 == "HWaddr" {print $5}'`
	fi
fi

if [ $MAC != $1 ]; then
        echo "The MAC Address is: $MAC"
fi

echo -n "The Link Local Address for $1 is: fe80:"
mac_to_ipv6 $MAC
echo -n "The host portion is: "
mac_to_ipv6 $MAC
