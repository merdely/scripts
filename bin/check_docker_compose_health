#!/usr/bin/env bash
# Nagios check script for Docker Compose services
# Returns:
#   0 (OK) - All services running and healthy
#   1 (WARNING) - Some services not running
#   2 (CRITICAL) - Some services unhealthy
#   3 (UNKNOWN) - Script error

set -o pipefail

progname=${0##*/}
progname=${progname%.sh}
usage() {
  echo "usage: $progname [-h] COMPOSE_FILE"
  exit "${1:-0}"
}

ignore_list=()
while getopts ":hi:" opt; do
  case $opt in
    i) ignore_list+=("$OPTARG") ;;
    h) usage ;;
    :) echo "-$OPTARG requires an argument" ; exit 1 ;;
    \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
  esac
done
shift $(( OPTIND - 1 ))

# Configuration
COMPOSE_FILE="${1:-docker-compose.yaml}"

# Check if compose file exists
if [[ ! -f "$COMPOSE_FILE" ]]; then
    echo "UNKNOWN: Compose file $COMPOSE_FILE not found"
    exit 3
fi

COMPOSE_DIR=${COMPOSE_FILE%/*}
COMPOSE_CMD="docker compose"  # Use "docker-compose" for v1

cd "$COMPOSE_DIR" || {
    echo "UNKNOWN: Cannot change to directory $COMPOSE_DIR"
    exit 3
}

# Get expected services
EXPECTED_SERVICES=$($COMPOSE_CMD -f "$(basename "$COMPOSE_FILE")" config --services 2>/dev/null)
if [[ $? -ne 0 ]]; then
    echo "UNKNOWN: Failed to parse compose file"
    exit 3
fi

EXPECTED_COUNT=$(echo "$EXPECTED_SERVICES" | wc -l)

# Get running containers with their status
CONTAINERS=$($COMPOSE_CMD -f "$(basename "$COMPOSE_FILE")" ps --format json 2>/dev/null)
if [[ $? -ne 0 ]]; then
    echo "UNKNOWN: Failed to get container status"
    exit 3
fi

# Arrays to track issues
NOT_RUNNING=()
UNHEALTHY=()
HEALTHY_COUNT=0
RUNNING_COUNT=0

# Parse each expected service
while IFS= read -r service; do
    # Get container info for this service
    SERVICE_INFO=$(echo "$CONTAINERS" | jq -r --arg svc "$service" 'select(.Service == $svc)')

    if [[ -z "$SERVICE_INFO" && " ${ignore_list[*]} " != *" $service "* ]]; then
        # Service not running at all
        NOT_RUNNING+=("$service")
        continue
    fi

    # Check state and health
    STATE=$(echo "$SERVICE_INFO" | jq -r '.State')
    HEALTH=$(echo "$SERVICE_INFO" | jq -r '.Health // "none"')

    if [[ "$STATE" != "running"  && " ${ignore_list[*]} " != *" $service "* ]]; then
        NOT_RUNNING+=("$service")
        continue
    fi

    RUNNING_COUNT=$((RUNNING_COUNT + 1))

    # Check health status
    case "$HEALTH" in
        "healthy")
            HEALTHY_COUNT=$((HEALTHY_COUNT + 1))
            ;;
        "unhealthy")
             [[ " ${ignore_list[*]} " != *" $service "* ]] && UNHEALTHY+=("$service")
            ;;
        "none"|"starting")
            # No health check defined or still starting - count as healthy
            HEALTHY_COUNT=$((HEALTHY_COUNT + 1))
            ;;
    esac

done <<< "$EXPECTED_SERVICES"

# Determine exit status and message
if [[ ${#UNHEALTHY[@]} -gt 0 ]]; then
    echo "CRITICAL: ${#UNHEALTHY[@]} unhealthy service(s): ${UNHEALTHY[*]} | running=$RUNNING_COUNT expected=$EXPECTED_COUNT healthy=$HEALTHY_COUNT unhealthy=${#UNHEALTHY[@]}"
    exit 2
elif [[ ${#NOT_RUNNING[@]} -gt 0 ]]; then
    echo "WARNING: ${#NOT_RUNNING[@]} service(s) not running: ${NOT_RUNNING[*]} | running=$RUNNING_COUNT expected=$EXPECTED_COUNT healthy=$HEALTHY_COUNT unhealthy=${#UNHEALTHY[@]}"
    exit 1
else
    echo "OK: All $EXPECTED_COUNT services running and healthy | running=$RUNNING_COUNT expected=$EXPECTED_COUNT healthy=$HEALTHY_COUNT unhealthy=0"
    exit 0
fi
