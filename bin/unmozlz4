#!/usr/bin/env python3

import lz4.block
import sys
import os

def decompress_mozlz4(input_file):
    # Check if file has .mozlz4 extension
    if not input_file.endswith('.mozlz4'):
        print(f"Error: Input file must have .mozlz4 extension", file=sys.stderr)
        sys.exit(1)

    # Check if input file exists
    if not os.path.exists(input_file):
        print(f"Error: Input file '{input_file}' not found", file=sys.stderr)
        sys.exit(1)

    # Generate output filename by removing .mozlz4 extension
    output_file = input_file[:-7]  # Remove last 7 characters (.mozlz4)

    # Check if output file already exists
    if os.path.exists(output_file):
        print(f"Error: Output file '{output_file}' already exists", file=sys.stderr)
        sys.exit(1)

    try:
        with open(input_file, 'rb') as f:
            # Read the file
            data = f.read()

            # Check for mozLz40 magic number and skip it
            if data[:8] == b'mozLz40\0':
                data = data[8:]
            else:
                print(f"Warning: File doesn't have mozLz40 magic header", file=sys.stderr)

            # Decompress
            decompressed = lz4.block.decompress(data)

            # Write output
            with open(output_file, 'wb') as out:
                out.write(decompressed)

        print(f"Successfully decompressed '{input_file}' to '{output_file}'")

    except Exception as e:
        print(f"Error during decompression: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <file.mozlz4>", file=sys.stderr)
        sys.exit(1)

    decompress_mozlz4(sys.argv[1])
