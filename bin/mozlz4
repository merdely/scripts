#!/usr/bin/env python3

import lz4.block
import sys
import os

def compress_to_mozlz4(input_file):
    # Check if input file exists
    if not os.path.exists(input_file):
        print(f"Error: Input file '{input_file}' not found", file=sys.stderr)
        sys.exit(1)

    # Generate output filename by appending .mozlz4
    output_file = input_file + '.mozlz4'

    # Check if output file already exists
    if os.path.exists(output_file):
        print(f"Error: Output file '{output_file}' already exists", file=sys.stderr)
        sys.exit(1)

    try:
        with open(input_file, 'rb') as f:
            # Read the file
            data = f.read()

            # Compress
            compressed = lz4.block.compress(data)

            # Write output with mozLz40 magic header
            with open(output_file, 'wb') as out:
                out.write(b'mozLz40\0')  # Magic header
                out.write(compressed)

        print(f"Successfully compressed '{input_file}' to '{output_file}'")

    except Exception as e:
        print(f"Error during compression: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    if len(sys.argv) != 2:
        print(f"Usage: {sys.argv[0]} <input_file>", file=sys.stderr)
        sys.exit(1)

    compress_to_mozlz4(sys.argv[1])
