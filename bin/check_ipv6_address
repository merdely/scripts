#!/usr/bin/env bash

[ ! -d ${HOME}/.local/state ] && mkdir -p ${HOME}/.local/state
state_file=${HOME}/.local/state/ipv6_address

get_address() {
  interface=$(ip -6 route show default | awk '{print $5}')
  ip -6 address show dev $interface | awk '
    /inet6 [0-9a-f]{1,4}:[0-9a-f]{1,4}:[0-9a-f]{1,4}:[0-9a-f]{1,4}::[0-9a-f]{1,4}\/128/ {
      sub(/\/[0-9]+/, "", $2);
      print $2;
    }'
}

new_address=$(get_address)
if [[ ! $new_address =~ ^[0-9a-f]{1,4}:[0-9a-f]{1,4}:[0-9a-f]{1,4}:[0-9a-f]{1,4}::[0-9a-f]{1,4}$ ]]; then
  echo "UNKNOWN: Could not get current address ($new_address)"
  exit 3
fi

[ ! -r $state_file ] && echo $new_address > $state_file

old_address=$(cat $state_file)

if [ "$new_address" != $old_address ]; then
  echo "CRITICAL: Address has changed (old: $old_address, new: $new_address)"
  exit 2
else
  echo "OK: Address is $new_address"
  exit 0
fi


