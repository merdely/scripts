#!/usr/bin/env bash

progname=${0##*/}
progname=${progname%.sh}

usage() {
  echo "usage: $progname [-h] [-D] [-x PROXY] -c SITE [-S IP | [-X PROXY] -C SITE]"
  echo "               -h                       : Print this help text"
  echo "               -D                       : Check that check and reference IPs are different (default: check they match)"
  echo "               -x PROXY                 : Use PROXY URL for check IP"
  echo "               -X PROXY                 : Use PROXY URL for reference IP"
  echo "               -S IP                    : Use SITE URL for reference IP (should return bare IP)"
  echo "               -c SITE                  : Use SITE URL for check IP (should return bare IP)"
  echo "               -C SITE                  : Use SITE URL for reference IP (should return bare IP)"
  exit $1
}

difference=false
while getopts ":hDx:X:c:C:S:" opt; do
  case $opt in
    D) difference=true ;;
    x) check_proxy=$OPTARG ;;
    X) reference_proxy=$OPTARG ;;
    c) check_url=$OPTARG ;;
    C) reference_url=$OPTARG ;;
    S) reference_string=$OPTARG ;;
    *) usage ;;
  esac
done
shift $((OPTIND -1))

[[ ! $check_url ]] && usage 1
[[ ! $reference_url ]] && [[ ! $reference_string ]] && usage 1
[[ $reference_url ]] && [[ $reference_string ]] && usage 1

validate_ip() {
  local ret=1
  if [[ $1 =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
    ret=0
    IFS='.' read -ra octets <<< "$ip"
    for octet in "${octets[@]}"; do
      if ((octet > 255)); then
        ret=1
        break
      fi
    done
  fi
  return $ret
}

invalid=false

unset proxy_string
[ -n "$check_proxy" ] && proxy_string="-x $check_proxy"
check_ip=$(curl -4sLf $proxy_string $check_url 2>&1)
#check_ip="error 404"
! validate_ip $check_ip && invalid=true && invalid_list="$invalid_list $check_ip"

if [[ $reference_string ]]; then
  reference_ip=$reference_string
else
  unset proxy_string
  [ -n "$reference_proxy" ] && proxy_string="-x $reference_proxy"
  reference_ip=$(curl -4sLf $proxy_string $reference_url 2>&1)
fi
! validate_ip $reference_ip && invalid=true && invalid_list="$invalid_list $reference_ip"

if $invalid; then
  echo "UNKNOWN - Invalid IP (check_ip:\"$check_ip\", ref_ip:\"$reference_ip\")"
  exit 3
elif ! $difference && [ $check_ip != $reference_ip ]; then
  echo "CRITICAL - IPs are different ($check_ip != $reference_ip)"
  exit 2
elif $difference && [ $check_ip = $reference_ip ]; then
  echo "CRITICAL - IPs are the same ($check_ip == $reference_ip)"
  exit 2
elif ! $difference && [ $check_ip = $reference_ip ]; then
  echo "OK - IPs are the same ($check_ip == $reference_ip)"
  exit 0
else
  echo "OK - IPs are different ($check_ip != $reference_ip)"
  exit 0
fi

