#!/usr/bin/env python3

import configparser
import json
import os
import re
import requests
import sys

configfile = os.path.expanduser('~/.config/jellyfinrc')

if len(sys.argv) > 1:
    configfile = sys.argv[1]
    try:
        if not os.path.exists(configfile):
            print(f"Error: Cannot find supplied configfile ({configfile})")
            quit(1)

        if not os.access(configfile, os.R_OK):
            print(f"Error: Cannot read supplied configfile ({configfile})")
            quit(1)
    except OSError as e:
        print(f"Error checking configfile: {e}")
        quit(1)

# Load Config File
try:
    conf_file = configparser.ConfigParser()
    conf_file.read(configfile)
    server = conf_file.get('admin', 'server')
    token = conf_file.get('admin', 'token')
except:
    print(f"Error: Could not parse config file")
    quit(1)

if 'server' not in globals() or 'token' not in globals():
    print("Error: Could not load config file")
    quit(1)

proxies = None
headers = {
    'Content-Type': 'application/json',
    'Authorization': f'MediaBrowser Token={token}'
    }

response = requests.get(f"{server}/Sessions", headers=headers, proxies=proxies)
data = response.json()
sessions = {}
count = 0
for session in data:
    if "NowPlayingItem" in session.keys():
        if session['PlayState']['IsPaused'] == True:
            continue
        count = count + 1
        if "SeriesName" in session["NowPlayingItem"].keys():
            season = session['NowPlayingItem']['SeasonName'].replace("Season ", "")
            episode = session['NowPlayingItem']['IndexNumber']
            sessions = sessions | { f"{session['UserName']} - {session['Client']}":  f"{session['NowPlayingItem']['SeriesName']} - s{season:02}e{episode:02} - {session['NowPlayingItem']['Name']}" }
        elif "AlbumArtist" in session["NowPlayingItem"].keys():
            sessions = sessions | { f"{session['UserName']} - {session['Client']}":  f"{session['NowPlayingItem']['AlbumArtist']} - {session['NowPlayingItem']['Album']} - {session['NowPlayingItem']['Name']}" }
        else:
            sessions = sessions | { f"{session['UserName']} - {session['Client']}":  session["NowPlayingItem"]["Name"] }

print(count)

