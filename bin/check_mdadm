#!/usr/bin/env bash

if [[ "$(id -u)" != 0 ]]; then
  echo "UNKONWN - mdadm must be run as root"
  exit 3
fi

code=0
state=""
rebuild=0
failed=0
label=OK

mapfile -t arrays < <(mdadm --detail --scan | awk '$1 == "ARRAY" { print $2 }')
for array in "${arrays[@]}"; do
  unset state rebuild failed
  out=$(mdadm --detail "$array" | awk '
    BEGIN { regex = "^[[:space:]]*(Rebuild Status|Failed Devices|State) : " }
    $0 ~ regex {
      label=tolower($1)
      sub(regex, "")
      sub(/[[:space:]]*$/,"")
      printf "%s=\"%s\" ",label,$0
    }
  ')

  # Validate awk output so that it is made up of rebuild=
  if [[ "$out" =~ ^((rebuild|failed|state)=\"[a-zA-Z0-9, -]+\" ){1,3}$ ]]; then
    eval "$out"
  fi

  if [[ -z "$state" ]]; then
    echo "UNKONWN - mdadm command error"
    exit 3
  fi

  if [[ ", $state, " == *", clean, "* || ", $state, " == *", active, "* ]]; then
    msg="$msg$array OK ($state); "
  fi

  if [[ ", $state, " != *", clean, "* && ", $state, " != *", active, "* && "$failed" == 0 ]]; then
    (( code == 0 )) && { code=1 ; label=WARNING ; }
    if [[ -z "$rebuild" ]]; then
      msg="$msg$array WARNING ($state); "
    else
      msg="$msg$array WARNING ($state, rebuild=$rebuild); "
    fi
  fi

  if [[ ", $state, " != *", clean, "* && ", $state, " != *", active, "* && "$failed" != 0 ]]; then
    code=2 && label=CRITICAL
    msg="$msg$array CRITICAL ($failed drives failed; $state); "
  fi
done

echo "$label - ${msg%; }"
exit "$code"
