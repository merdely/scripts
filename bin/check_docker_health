media_status() {
  docker compose exec $container true
}
torrent() {
  docker compose exec $container bash -c 'ping -c 2 -W 1 9.9.9.9 > /dev/null 2>&1 && curl -s http://127.0.0.1:3080/ | grep -q "<title>qBittorrent WebUI</title>" && { test -x /usr/lib/nagios/plugins/check_ping || apk add --no-cache --update nagios-plugins-ping > /dev/null 2>&1; true; }'
}
unpackerr() {
  docker compose exec $container /unpackerr -v
}
yts() {
  docker compose exec $container curl -s http://127.0.0.1:8558/status | grep -q "^OK$"
}

if [ $? != 0 ]; then
  echo "UNKONWN - Command error ($(echo $state))"
  exit 3
fi

# Run health check function
status=$(get_status $container)
output=$($health_check 2>&1)
state=$?

if [ "$state" != 0 ]; then
  echo "CONTAINER CRITICAL - $1: $status state='$state' output='$output'"
  exit 2
fi

if echo "$status" | grep -qi "starting"; then
  echo "CONTAINER WARNING - $1: $status"
  exit 1
fi

if [ -n "$output" ]; then
  echo "CONTAINER OK - $1: $status output='$output'"
else
  echo "CONTAINER OK - $1: $status"
fi
exit 0
