#!/usr/bin/env bash

export COMPOSE_FILE=/srv/docker/compose.yaml

[ "$1" = "-h" -o -z "$1" ] && echo "usage: $0 [-h] containername" >&2 && exit 1

# Alias which to 'command -v' if not found
! which which > /dev/null 2>&1 && alias which='command -v'

# Function to check if a program exists and print an error message
check_prog() {
  [[ ! $1 ]] && echo "usage: check_prog prog" && exit 1
  ! which $1 &> /dev/null && echo "UNKNOWN - Cannot find $1 command" && exit 3
}

# Check to see if required commands are found
check_prog docker
check_prog jq

# helper functions
get_checks() {
  echo $(awk '/() {$/ && $1 !~ /^(usage|get_checks|get_name|get_status)\(\)$/ {gsub(/\(\)$/,"",$1);print $1}' $0)
}
[ "$1" = "-l" ] && printf "Configured health checks: %s\n" "$(get_checks)" && exit 0

get_name() {
  [ -z "$1" ] && echo "Error: You must supply container name" && return 1
  [ "$1" = "-h" ] && echo "usage: get_name CONTAINER" && return 0

  docker compose ps --format '{{.Name}}' $1
}

get_status() {
  [ -z "$1" ] && echo "Error: You must supply container name" && return 1
  [ "$1" = "-h" ] && echo "usage: get_status CONTAINER" && return 0

  docker compose ps --all --format {{.Status}} $1
}

container=$1
health_check=${container//-/_}

# Check to make sure health check exists
if [[ ! " $(get_checks) " == *" $health_check "* ]]; then
  echo "CONTAINER CRITICAL - $health_check health check not found"
  exit 2
fi

# Check to see if container is running or found
docker compose ps $container > /dev/null 2>&1
if [ $? != 0 ]; then
  echo "CONTAINER CRITICAL - $container container not found"
  exit 2
fi
docker_name=$(get_name $container)

# health checks
